From cca54f5b62c4912f6ef51ff75f9ac98d528d133d Mon Sep 17 00:00:00 2001
From: eatradish <sakiiily@aosc.io>
Date: Tue, 20 May 2025 14:00:32 +0800
Subject: [PATCH 2/4] unix: fix language match

In Linux, it is possible for the `LANGUAGE` variable to exist but have a empty value,
and for the `LANG` variable to be adapted so that the value is separated by `_` instead of `:`.
---
 src/sys/unix.rs | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/src/sys/unix.rs b/src/sys/unix.rs
index be80c59..9bfcb74 100644
--- a/src/sys/unix.rs
+++ b/src/sys/unix.rs
@@ -526,9 +526,13 @@ pub fn preferred_languages(arena: &Arena) -> Vec<ArenaString<'_>, &Arena> {
     let mut locales = Vec::new_in(arena);
 
     for key in ["LANGUAGE", "LC_ALL", "LANG"] {
-        if let Ok(val) = std::env::var(key) {
+        if let Ok(val) = std::env::var(key)
+            && !val.is_empty()
+        {
             locales.extend(
-                val.split(':').filter(|s| !s.is_empty()).map(|s| ArenaString::from_str(arena, s)),
+                val.split([':', '_'])
+                    .filter(|s| !s.is_empty())
+                    .map(|s| ArenaString::from_str(arena, s)),
             );
             break;
         }
