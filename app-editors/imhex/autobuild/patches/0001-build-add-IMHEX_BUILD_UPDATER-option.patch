From d1a012ec9a235dee20c43e3ff0b9b675c4b5eba0 Mon Sep 17 00:00:00 2001
From: xtex <xtexchooser@duck.com>
Date: Thu, 1 Jan 2026 09:14:19 +0800
Subject: [PATCH] build: add IMHEX_BUILD_UPDATER option
X-Developer-Signature: v=1; a=openpgp-sha256; l=1785; i=xtexchooser@duck.com;
 h=from:subject; bh=uuCEw3zE5iAq6rltnpjeg3yQGrR/8pEgUzlua7JYOfA=;
 b=owGbwMvMwCW2U4Ij7wZL9ETG02pJDJmhp56saZqn1uaTuvLggmyOvkaWOZVB2adSbfkcOcr3Z
 hsp6bZ3lLIwiHExyIopshQZNniz6qTziy4rl4WZw8oEMoSBi1MAJuJ8gOGf/gK3/7mHOlhe5ole
 N3r+VWZiKOeN4oJtOrHx5zU/afbwMfzhjd5yaIna45NbYryCc36tb+GU+RYzZ/Vq1Y4tHfwfGyY
 yAwA=
X-Developer-Key: i=xtexchooser@duck.com; a=openpgp;
 fpr=7231804B052C670F15A6771DB918086ED8045B91

It is a self-updater which many Linux distributions
don't want. It does not support all architectures
and fails builds on those architectures.

Signed-off-by: xtex <xtexchooser@duck.com>
---
 CMakeLists.txt      | 1 +
 main/CMakeLists.txt | 2 +-
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 8ecb1bd5c4bb..982fd73fdbe8 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -19,6 +19,7 @@ option(IMHEX_ENABLE_PRECOMPILED_HEADERS "Enable precompiled headers"
 option(IMHEX_ENABLE_CXX_MODULES         "Enable C++20 Module compilation. Testing only!"                                        OFF)
 option(IMHEX_ENABLE_CPPCHECK            "Enable cppcheck static analysis"                                                       OFF)
 option(IMHEX_BUNDLE_PLUGIN_SDK          "Enable bundling of Plugin SDK into install package"                                    ON )
+option(IMHEX_BUILD_UPDATER              "Build ImHex updater"                                                                   ON )
 ## Testing
 option(IMHEX_ENABLE_UNIT_TESTS          "Enable building unit tests"                                                            ON )
 option(IMHEX_ENABLE_IMGUI_TEST_ENGINE   "Enable the ImGui Test Engine"                                                          OFF)
diff --git a/main/CMakeLists.txt b/main/CMakeLists.txt
index 068970440153..11c3c1b72f91 100644
--- a/main/CMakeLists.txt
+++ b/main/CMakeLists.txt
@@ -9,6 +9,6 @@ if (WIN32)
     add_subdirectory(forwarder)
 endif ()
 
-if (NOT EMSCRIPTEN)
+if (IMHEX_BUILD_UPDATER AND NOT EMSCRIPTEN)
     add_subdirectory(updater)
 endif ()
\ No newline at end of file

