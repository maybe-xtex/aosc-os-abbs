if ab_match_arch loongarch64; then
    abinfo "Overriding Electron mirror for loongarch64 ..."
    export ELECTRON_MIRROR="https://github.com/darkyzhou/electron-loong64/releases/download/"
    export electron_use_remote_checksums=1

    abinfo "Overriding go-ole version ..."
    cd "$SRCDIR"/kernel
    go get github.com/go-ole/go-ole@6c7f902
fi

abinfo "Building SiYuan Kernel ..."
cd "$SRCDIR"/kernel
go build -tags "fts5" -o "../app/kernel-linux/SiYuan-Kernel"

abinfo "Installing NPM dependencies ..."
cd "$SRCDIR"/app
pnpm install

abinfo "Building ..."
pnpm build
pnpm electron-builder --dir --config electron-builder-linux.yml

abinfo "Installing siyuan ..."
install -dvm755 "$PKGDIR"/usr/lib/siyuan
cp -av "$SRCDIR"/app/build/linux*-unpacked/* "$PKGDIR"/usr/lib/siyuan/

abinfo "Creating symbolic link ..."
mkdir -pv "$PKGDIR"/usr/bin
ln -sv ../lib/siyuan/siyuan "$PKGDIR"/usr/bin/siyuan

abinfo "Installing application icon ..."
install -Dvm644 "$SRCDIR"/app/electron/icon.png \
		"$PKGDIR"/usr/share/pixmaps/siyuan.png
