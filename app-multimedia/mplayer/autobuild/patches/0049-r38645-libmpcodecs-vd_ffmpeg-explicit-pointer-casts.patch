From 4e671d618e9a1f5cbcb607a02f60fb0f6cd7efc3 Mon Sep 17 00:00:00 2001
From: CAB233 <yidaduizuoye@outlook.com>
Date: Mon, 28 Apr 2025 19:25:32 +0800
Subject: [PATCH 49/66] [r38645] libmpcodecs/vd_ffmpeg: explicit pointer casts

Recent compilers consider implicit casts an error.

(From upstream SVN r38645)
---
 libmpcodecs/vd_ffmpeg.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/libmpcodecs/vd_ffmpeg.c b/libmpcodecs/vd_ffmpeg.c
index d8adbe3..e324893 100644
--- a/libmpcodecs/vd_ffmpeg.c
+++ b/libmpcodecs/vd_ffmpeg.c
@@ -728,7 +728,7 @@ static int get_buffer(AVCodecContext *avctx, AVFrame *pic, int isreference){
     if (ctx->use_vdpau) {
         VdpVideoSurface surface = (VdpVideoSurface)mpi->priv;
         avctx->draw_horiz_band= NULL;
-        mpi->planes[3] = surface;
+        mpi->planes[3] = (char *)surface;
     }
 #endif
 
