From d60aee65dc7cabd780d227288940e73e096fb167 Mon Sep 17 00:00:00 2001
From: CAB233 <yidaduizuoye@outlook.com>
Date: Mon, 28 Apr 2025 19:39:04 +0800
Subject: [PATCH 60/62] [r38658] sub/sub: explicit pointer casts

Recent compilers consider implicit casts an error.

(From upstream SVN r38658)
---
 sub/sub.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/sub/sub.c b/sub/sub.c
index 1422421..7bad030 100644
--- a/sub/sub.c
+++ b/sub/sub.c
@@ -727,7 +727,7 @@ static inline void vo_update_text_sub(mp_osd_obj_t *obj, int dxs, int dys)
 	    // reading the subtitle words from vo_sub->text[]
           while (*t) {
             if (sub_utf8)
-              c = utf8_get_char(&t);
+              c = utf8_get_char((const char **)&t);
             else if ((c = *t++) >= 0x80 && sub_unicode)
               c = (c<<8) + *t++;
 	      if (k==MAX_UCS){
