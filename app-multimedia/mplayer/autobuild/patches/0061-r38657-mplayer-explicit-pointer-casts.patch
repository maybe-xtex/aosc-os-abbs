From ac656a00da98a164287274f413bb9636ebc50599 Mon Sep 17 00:00:00 2001
From: CAB233 <yidaduizuoye@outlook.com>
Date: Mon, 28 Apr 2025 11:01:49 +0800
Subject: [PATCH 61/66] [r38657] mplayer: explicit pointer casts

Recent compilers consider implicit casts an error.

(From upstream SVN r38657)
---
 mplayer.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mplayer.c b/mplayer.c
index 924876c..99e99bf 100644
--- a/mplayer.c
+++ b/mplayer.c
@@ -3534,7 +3534,7 @@ goto_enable_cache:
                 break;
             if ((mpctx->demuxer->file_format == DEMUXER_TYPE_AVI || mpctx->demuxer->file_format == DEMUXER_TYPE_ASF || mpctx->demuxer->file_format == DEMUXER_TYPE_MOV)
                 && stream_dump_type == 2)
-                stream_write_buffer(os, &in_size, 4);
+                stream_write_buffer(os, (unsigned char *)&in_size, 4);
             if (in_size > 0) {
                 stream_write_buffer(os, start, in_size);
                 stream_dump_progress(in_size, mpctx->stream);
-- 
2.54.0

