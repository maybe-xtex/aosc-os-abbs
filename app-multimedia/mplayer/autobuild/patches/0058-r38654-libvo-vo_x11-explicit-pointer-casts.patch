From ce5423d87000dc13c3af94e9bd478a27d7953df4 Mon Sep 17 00:00:00 2001
From: CAB233 <yidaduizuoye@outlook.com>
Date: Mon, 28 Apr 2025 18:59:45 +0800
Subject: [PATCH 58/66] [r38654] libvo/vo_x11: explicit pointer casts

Recent compilers consider implicit casts an error.

(From upstream SVN r38654)
---
 libvo/vo_x11.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/libvo/vo_x11.c b/libvo/vo_x11.c
index 58e1762..e29dfe5 100644
--- a/libvo/vo_x11.c
+++ b/libvo/vo_x11.c
@@ -492,7 +492,7 @@ static int draw_slice(uint8_t * src[], int stride[], int w, int h,
         dst[0] += dstStride[0] * (image_height - 1);
         dstStride[0] = -dstStride[0];
     }
-    sws_scale(swsContext, src, stride, y, h, dst, dstStride);
+    sws_scale(swsContext, (const uint8_t *const *)src, stride, y, h, dst, dstStride);
     return 0;
 }
 
