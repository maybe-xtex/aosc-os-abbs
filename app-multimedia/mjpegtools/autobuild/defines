PKGNAME=mjpegtools
PKGSEC=utils
PKGDEP="libdv libjpeg-turbo libpng sdl12-compat sdl-gfx v4l-utils"
PKGDES="Tools to work with MPEG media files"

AUTOTOOLS_AFTER=(
    '--enable-largefile'
    '--with-v4l'
    '--without-gtk'
    # FIXME: libquicktime requires FFmpeg < 5. To revisit.
    '--without-libquicktime'
)
# Note: powerpc => PowerPC pre-G4 (no AltiVec).
AUTOTOOLS_AFTER__POWERPC=(
    "${AUTOTOOLS_AFTER[@]}"
    '--disable-simd-accel'
)
