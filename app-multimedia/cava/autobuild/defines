PKGNAME=cava
PKGSEC=sound
PKGDEP="alsa-lib fftw glibc iniparser jack ncurses pipewire portaudio \
		pulseaudio sdl2 sndio"
PKGDES="Console-based Audio Visualizer for Alsa (MPD and Pulseaudio)"

