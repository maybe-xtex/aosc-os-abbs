ABSHADOW=0

ABTYPE=autotools
AUTOTOOLS_AFTER=(
	'--enable-input-alsa'
	'--enable-input-pulse'
	'--enable-input-pipewire'
	'--enable-input-portaudio'
	'--enable-input-sndio'
	'--enable-input-jack'
)
