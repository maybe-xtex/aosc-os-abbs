From 15659b33cb76bbd4ca458b9ebe78bdac1f85d6d6 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sun, 12 Oct 2025 17:15:48 +0800
Subject: [PATCH 4/4] AOSCOS: conf: add speakersafetyd to the audio group

This will fix any remaining permission issues, causing the service to fail
to start.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 speakersafetyd.sysusers | 1 +
 1 file changed, 1 insertion(+)

diff --git a/speakersafetyd.sysusers b/speakersafetyd.sysusers
index b4900ce..5226f5a 100644
--- a/speakersafetyd.sysusers
+++ b/speakersafetyd.sysusers
@@ -1,2 +1,3 @@
 u speakersafetyd - "speakersafetyd Daemon Owner" /var/lib/speakersafetyd
 g speakersafetyd
+m speakersafetyd audio
-- 
2.51.0

