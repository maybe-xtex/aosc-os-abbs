OPTIONS=(
    system.zlib=1
    platform=linux
    release=1
    qt.includes=/usr/include/qt5
    tools.uic=uic-qt5
    tools.moc=moc-qt5
    tools.rcc=rcc-qt5
    CXX_MODE_FLAGS="${CPPFLAGS} ${CXXFLAGS} -DNDEBUG"
    LD_MODE_FLAGS="${LDFLAGS}"
)

abinfo "Building zxtune ..."
make \
    "${OPTIONS[@]}" \
    -C "$SRCDIR"/apps/bundle/

abinfo "Installing zxtune ..."
make install_linux \
    "${OPTIONS[@]}" \
    DESTDIR="$PKGDIR" \
    -C "$SRCDIR"/apps/bundle/
