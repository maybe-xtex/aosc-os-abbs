+struct _ics2115_state
+{
+	DEV_DATA _devData;
+
+	void (*irq_func)(void *, UINT8);	// IRQ callback
+	void *irq_param;
+
+	DEVCB_SRATE_CHG SmpRateFunc;
+	void* SmpRateData;
+
+	UINT8 *rom;
+	UINT32 rom_size;
+	UINT32 rom_mask;
+
+	ics2115_voice voice[32];
+	//ics2115_timer timer[2];
+
+	// tables
+	INT16 ulaw[256];
+	UINT16 volume[4096];
+	UINT16 panlaw[256];
+
+	/* global sound parameters */
+	UINT32 clock;
+	UINT32 output_rate;
+
+	/* chip registers */
+	UINT8 active_osc;
+	UINT8 osc_select;
+	UINT8 reg_select;
+	UINT8 irq_enabled;
+	UINT8 irq_pending;
+	UINT8 irq_on;
+
+	UINT16 regs[0x40]; // global registers
+
+	/*
+	    Unknown variable, seems to be effected by 0x12. Further investigation
+	    Required.
+	*/
+	UINT8 vmode;
