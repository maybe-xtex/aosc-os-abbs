+		v->state.on = false;
+		v->state.ramp = 0;
+	}
+	chip->output_rate = ics2115_get_output_rate(chip);
+	if (chip->SmpRateFunc != NULL)
+		chip->SmpRateFunc(chip->SmpRateData, chip->output_rate);
+	
+}
