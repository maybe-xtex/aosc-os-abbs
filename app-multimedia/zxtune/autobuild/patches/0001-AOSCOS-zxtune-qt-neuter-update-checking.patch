-        StoreLastCheckTime();
-        (this->*cb)(state.GetUpdate());
-      });
-    }
-
-    void ProcessUpdate(Product::Update::Ptr update)
-    {
-      if (update)
-      {
-        ProcessUpdateSilent(std::move(update));
