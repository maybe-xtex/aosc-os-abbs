     void addHistory(const std::string& key);
     std::vector<std::string> getHistoryList();
     void setHistory(const std::vector<std::string>& list);
@@ -289,7 +289,7 @@ public:
     void checkOnTop();
 
     std::vector<CustomTheme> customThemes;
-    Cookie cookie = {{"DedeUserID", "0"}};
