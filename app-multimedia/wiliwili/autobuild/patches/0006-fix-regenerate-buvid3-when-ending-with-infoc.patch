From d52d9bb7767e7270304c591715ee751a2d726330 Mon Sep 17 00:00:00 2001
From: xfangfang <2553041586@qq.com>
Date: Sat, 24 Jan 2026 15:52:55 +0800
Subject: [PATCH 6/6] fix: regenerate buvid3 when ending with "infoc"

---
 wiliwili/source/utils/config_helper.cpp | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/wiliwili/source/utils/config_helper.cpp b/wiliwili/source/utils/config_helper.cpp
index 0985f34..cdd276e 100644
--- a/wiliwili/source/utils/config_helper.cpp
+++ b/wiliwili/source/utils/config_helper.cpp
@@ -24,6 +24,8 @@
 #include "utils/thread_helper.hpp"
 #include "utils/image_helper.hpp"
 #include "utils/config_helper.hpp"
+
+#include "pystring.h"
 #include "utils/crash_helper.hpp"
 #include "utils/vibration_helper.hpp"
 #include "utils/ban_list.hpp"
@@ -334,7 +336,8 @@ void ProgramConfig::setCookie(const Cookie& data) {
 
 Cookie ProgramConfig::getCookie() {
     // 生成虚假的 buvid3，在获取直播分区时需要此字段
-    if (!this->cookie.count("buvid3")) {
+    // buvid3 不应以 infoc 结尾，否则会报错误码 352
+    if (!this->cookie.count("buvid3") || pystring::endswith(this->cookie["buvid3"], "infoc")) {
         this->cookie["buvid3"] = wiliwili::getRandomHex(32, false);
     }
     // 生成虚假的 DedeUserID，在未登录时使用
-- 
