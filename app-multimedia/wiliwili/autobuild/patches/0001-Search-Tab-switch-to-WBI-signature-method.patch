From bfeebd2291a36346c42a6d9f5eb5efc8c2ac47ae Mon Sep 17 00:00:00 2001
From: xfangfang <2553041586@qq.com>
Date: Sat, 3 Jan 2026 13:26:47 +0800
Subject: [PATCH 1/6] Search Tab: switch to WBI signature method

---
 wiliwili/include/api/bilibili/api.h | 2 +-
 wiliwili/source/api/search_api.cpp  | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/wiliwili/include/api/bilibili/api.h b/wiliwili/include/api/bilibili/api.h
index 40746b2..66f5b7f 100644
--- a/wiliwili/include/api/bilibili/api.h
+++ b/wiliwili/include/api/bilibili/api.h
@@ -200,7 +200,7 @@ const std::string WatchLater = _apiBase + "/x/v2/history/toview/web";
 /// ===
 /// 搜索页API
 /// ===
-const std::string Search     = _apiBase + "/x/web-interface/search/type";
+const std::string Search     = _apiBase + "/x/web-interface/wbi/search/type";
 const std::string TVSuggest  = _apiBase + "/x/tv/suggest";
 const std::string SearchHots = _apiBase + "/x/web-interface/search/square";
 
diff --git a/wiliwili/source/api/search_api.cpp b/wiliwili/source/api/search_api.cpp
index 3aa5005..88fc5a0 100644
--- a/wiliwili/source/api/search_api.cpp
+++ b/wiliwili/source/api/search_api.cpp
@@ -12,7 +12,7 @@ namespace bilibili {
 void BilibiliClient::search_video(const std::string &key, const std::string &search_type, unsigned int index,
                                   const std::string &order, const std::function<void(SearchResult)> &callback,
                                   const ErrorCallback &error) {
-    HTTP::getResultAsync<SearchResult>(Api::Search,
+    HTTP::getResultWithWbiAsync<SearchResult>(Api::Search,
                                        {{"__refresh__", "true"},
                                         {"_extra", ""},
                                         {"context", ""},
