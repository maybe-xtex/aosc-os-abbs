PKGNAME=sunshine
PKGDES="A Gamestream host for Moonlight"
PKGSEC=video
PKGDEP="mesa pulseaudio libdrm libevdev icu ffmpeg wayland libva glslang \
        shaderc openssl miniupnpc opus vulkan pipewire x11-lib x264 x265 \
        libnotify libappindicator libvdpau nlohmann-json svt-av1"
PKGRECOM="avahi"
BUILDDEP="boost nodejs doxygen ffmpeg-static-libs-for-sunshine jinja2"
PKGRECOM__AMD64="${PKGRECOM} intel-media-driver"

BUILDDEP__AMD64="${BUILDDEP} cuda"
BUILDDEP__ARM64="${BUILDDEP} cuda"
PKGSUG__AMD64="cuda"
PKGSUG__ARM64="cuda"

ABTYPE=cmakeninja

# SUNSHINE_ASSETS_DIR is set to make data files follow FHS, otherwise it will
# come at /usr/assets
#
CMAKE_AFTER=(
    "-DBOOST_USE_STATIC=OFF"
    "-DFFMPEG_USE_SYSTEM_LIBRARIES=ON"
    "-DSUNSHINE_ENABLE_CUDA=OFF"
    "-DSUNSHINE_ASSETS_DIR=share/sunshine"
    "-DSUNSHINE_SYSTEM_VULKAN_HEADERS=ON"
    "-DSUNSHINE_SYSTEM_VULKAN_PROTOCOL=ON"
    "-DBUILD_DOCS=OFF"
    "-DBUILD_TESTS=OFF"
    "-DSUNSHINE_PUBLISHER_NAME='AOSC OS'"
    "-DSUNSHINE_PUBLISHER_WEBSITE='https://aosc.io'"
    "-DSUNSHINE_PUBLISHER_ISSUE_URL='https://github.com/aosc-dev/aosc-os-abbs'"
)

CMAKE_AFTER__AMD64=(
    "${CMAKE_AFTER[@]}"
    "-DSUNSHINE_ENABLE_CUDA=ON"
)
CMAKE_AFTER__ARM64=(
    "${CMAKE_AFTER[@]}"
    "-DSUNSHINE_ENABLE_CUDA=ON"
)
