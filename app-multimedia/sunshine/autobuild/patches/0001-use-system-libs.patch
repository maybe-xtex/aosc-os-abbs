From 7da7e6403c2092cf16d437227fc64f6fa836d645 Mon Sep 17 00:00:00 2001
From: "Lain \"Fearyncess\" Yang" <i@lain.vg>
Date: Wed, 3 Jun 2026 21:51:46 +0800
Subject: [PATCH 1/2] use system libs

---
 cmake/dependencies/common.cmake        |  7 +++-
 cmake/dependencies/ffmpeg-system.cmake | 50 ++++++++++++++++++++++++++
 2 files changed, 56 insertions(+), 1 deletion(-)
 create mode 100644 cmake/dependencies/ffmpeg-system.cmake

diff --git a/cmake/dependencies/common.cmake b/cmake/dependencies/common.cmake
index 119ad8e6..a375c451 100644
--- a/cmake/dependencies/common.cmake
+++ b/cmake/dependencies/common.cmake
@@ -30,7 +30,12 @@ pkg_check_modules(MINIUPNP miniupnpc REQUIRED)
 include_directories(SYSTEM ${MINIUPNP_INCLUDE_DIRS})
 
 # ffmpeg pre-compiled binaries
-include("${CMAKE_MODULE_PATH}/dependencies/ffmpeg.cmake")
+
+if(FFMPEG_USE_SYSTEM_LIBRARIES)
+    include("${CMAKE_MODULE_PATH}/dependencies/ffmpeg-system.cmake")
+else()
+    include("${CMAKE_MODULE_PATH}/dependencies/ffmpeg.cmake")
+endif()
 
 # Opus
 # Homebrew provides opus as a dynamic library only, so disable static linking for Homebrew builds
diff --git a/cmake/dependencies/ffmpeg-system.cmake b/cmake/dependencies/ffmpeg-system.cmake
new file mode 100644
index 00000000..25b164d3
--- /dev/null
+++ b/cmake/dependencies/ffmpeg-system.cmake
@@ -0,0 +1,50 @@
+#
+# Loads FFmpeg pre-compiled binaries from GitHub releases or a user-specified path
+#
+include_guard(GLOBAL)
+# Set platform-specific libraries
+if(WIN32)
+    set(FFMPEG_PLATFORM_LIBRARIES mfplat ole32 strmiids mfuuid vpl)
+elseif(FREEBSD)
+    # numa is not available on FreeBSD
+    set(FFMPEG_PLATFORM_LIBRARIES va va-drm va-x11 X11)
+elseif(UNIX AND NOT APPLE)
+    set(FFMPEG_PLATFORM_LIBRARIES numa va va-drm va-x11 X11)
+endif()
+
+set(FFMPEG_LIBRARIES
+    avcodec
+    avutil
+    swscale
+    "/usr/lib/libcbs.a"
+    ${FFMPEG_PLATFORM_LIBRARIES})
+
+set(ENCODING_LIBRARIES SvtAv1Enc x264 x265 hdr10plus)
+
+list(APPEND FFMPEG_LIBRARIES ${FFMPEG_PLATFORM_LIBRARIES})
+list(APPEND FFMPEG_LIBRARIES ${ENCODING_LIBRARIES})
+
+set(FFMPEG_INCLUDE_DIRS "${FFMPEG_PREPARED_BINARIES}/include")
+
+
