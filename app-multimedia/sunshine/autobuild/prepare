abinfo "Fetching nessecery git submodules ..."
git -c submodule."packaging/linux/flatpak/deps/shared-modules".update=none \
    -c submodule."packaging/linux/flatpak/deps/flatpak-builder-tools".update=none \
    -c submodule."third-party/build-deps".update=none \
  submodule update --init --recursive

abinfo "Setting build version"
export BRANCH="master"
export BUILD_VERSION="${PKGVER}"
export COMMIT="$(git rev-parse HEAD)"

abinfo "Setting CUDA path"
export CUDA_PATH=/usr/lib/cuda
export NVCC_CCBIN="/usr/lib/cuda/bin/g++"

abinfo "Preparing NPM modules ..."
if ab_match_arch loongson3; then
    abinfo "Install @rollup/wasm-node on loongson3 ..."
    npm install -D rollup@npm:@rollup/wasm-node
fi
npm install --package-lock-only
