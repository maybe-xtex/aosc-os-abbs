abinfo "Copying file from original game..."
mkdir -vp "$PKGDIR"/usr/share/migrant-demo
# 10157515 is the depot BuildID of Migrant Demo.
# See https://steamdb.info/depot/2249001/ for detail.
# We consider this never changing thus we hardcode it.
cp -av "$SRCDIR"/10157515/* "$PKGDIR"/usr/share/migrant-demo/

abinfo "Removing unneeded files..."
rm -rv "$PKGDIR"/usr/share/migrant-demo/lib

abinfo "Linking with system installation of renpy..."
rm -rv "$PKGDIR"/usr/share/migrant-demo/renpy
ln -sv ../renpy/renpy \
    "$PKGDIR"/usr/share/migrant-demo/renpy

rm -v "$PKGDIR"/usr/share/migrant-demo/MigrantDemo.py
ln -sv ../renpy/renpy.py  \
    "$PKGDIR"/usr/share/migrant-demo/MigrantDemo.py
