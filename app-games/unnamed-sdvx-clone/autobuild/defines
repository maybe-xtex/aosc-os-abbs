PKGNAME=unnamed-sdvx-clone
PKGSEC=games
PKGDEP="curl freetype zlib libjpeg-turbo libarchive libvorbis libogg libpng \
        sdl2 sqlite soundtouch glew lua-5.3"
PKGRECOM="noto-cjk-fonts"
BUILDDEP="cmake noto-cjk-fonts rapidjson"
