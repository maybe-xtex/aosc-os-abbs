From daf8733630c239217f305a441050622bd6f349a1 Mon Sep 17 00:00:00 2001
From: Henry Chen <henry.chen@oss.cipunited.com>
Date: Mon, 1 Sep 2025 00:10:31 +0800
Subject: [PATCH 3/4] AOSCOS: use shared libs

namely sqlite3 and lua-5.3
---
 CMakeLists.txt             | 3 +++
 GUI/CMakeLists.txt         | 3 +--
 Main/CMakeLists.txt        | 4 +++-
 Shared/CMakeLists.txt      | 9 ++++++++-
 third_party/CMakeLists.txt | 9 ---------
 5 files changed, 15 insertions(+), 13 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 35530479..33f1677d 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -118,6 +118,9 @@ endif()
 # Include macros
 include(${PROJECT_SOURCE_DIR}/cmake/Macros.cmake)
 
+# AOSC: prepare for lua and sqlite
+find_package(PkgConfig REQUIRED)
+
 # Sub-Project directories
 add_subdirectory(third_party)
 add_subdirectory(Shared)
diff --git a/GUI/CMakeLists.txt b/GUI/CMakeLists.txt
index eefc4c33..4a319aa1 100644
--- a/GUI/CMakeLists.txt
+++ b/GUI/CMakeLists.txt
@@ -34,11 +34,10 @@ target_include_directories(GUI PRIVATE
 target_link_libraries(GUI Shared)
 target_link_libraries(GUI nanovg)
 target_link_libraries(GUI Graphics)
-target_link_libraries(GUI lua)
 
 target_link_libraries(GUI cc-common)
 
 # Enable multiprocess compiling
 if(MSVC)
     target_compile_options(GUI PRIVATE /MP)
-endif(MSVC)
\ No newline at end of file
+endif(MSVC)
diff --git a/Main/CMakeLists.txt b/Main/CMakeLists.txt
index a3a20923..15d3783e 100644
--- a/Main/CMakeLists.txt
+++ b/Main/CMakeLists.txt
@@ -94,7 +94,9 @@ target_link_libraries(usc-game Audio)
 target_link_libraries(usc-game GUI)
 target_link_libraries(usc-game Beatmap)
 target_link_libraries(usc-game nanovg)
-target_link_libraries(usc-game lua)
+pkg_check_modules(LUA REQUIRED lua5.3)
+target_link_libraries(usc-game ${LUA_LIBRARIES})
+target_include_directories(usc-game SYSTEM PRIVATE ${LUA_INCLUDE_DIRS})
 target_link_libraries(usc-game discord-rpc)
 target_link_libraries(usc-game cpr)
 target_link_libraries(usc-game nlohmann_json)
diff --git a/Shared/CMakeLists.txt b/Shared/CMakeLists.txt
index 9cacf761..6dcbd8db 100644
--- a/Shared/CMakeLists.txt
+++ b/Shared/CMakeLists.txt
@@ -44,7 +44,14 @@ target_include_directories(Shared PRIVATE
     ${PCHROOT}
 )
 
-target_link_libraries(Shared lua)
+# AOSC Shared libs
+pkg_check_modules(SQLITE3 REQUIRED sqlite3)
+target_link_libraries(Shared ${SQLITE3_LIBRARIES})
+target_include_directories(Shared SYSTEM PRIVATE ${SQLITE3_INCLUDE_DIRS})
+
+pkg_check_modules(LUA REQUIRED lua5.3)
+target_link_libraries(Shared ${LUA_LIBRARIES})
+target_include_directories(Shared SYSTEM PRIVATE ${LUA_INCLUDE_DIRS})
 
 target_link_libraries(Shared ${Iconv_LIBRARIES})
 target_include_directories(Shared SYSTEM PRIVATE ${Iconv_INCLUDE_DIRS})
diff --git a/third_party/CMakeLists.txt b/third_party/CMakeLists.txt
index 967a45d8..444dcedd 100644
--- a/third_party/CMakeLists.txt
+++ b/third_party/CMakeLists.txt
@@ -1,5 +1,4 @@
 # All third party libraries
-add_subdirectory(lua-5.3.5)
 
 #cpr test programs
 option(CPR_BUILD_TESTS "Set to ON to build cpr tests." OFF)
@@ -36,14 +35,6 @@ target_include_directories(miniaudio INTERFACE ${CMAKE_CURRENT_SOURCE_DIR}/minia
 add_library(nlohmann_json INTERFACE)
 target_include_directories(nlohmann_json INTERFACE ${CMAKE_CURRENT_SOURCE_DIR}/nlohmann_json)
 
-#sqlite
-add_library(sqlite3
-    sqlite3/sqlite3.c
-    sqlite3/sqlite3.h
-    sqlite3/sqlite3ext.h
-)
-target_include_directories(sqlite3 PUBLIC ${CMAKE_CURRENT_SOURCE_DIR}/sqlite3)
-
 #minimp3
 add_library(minimp3
     minimp3/minimp3.c
