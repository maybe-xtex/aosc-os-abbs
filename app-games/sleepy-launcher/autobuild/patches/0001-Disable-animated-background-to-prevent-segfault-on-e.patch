From db53799d7fce5c999e00f12fc9fc6b47ee478271 Mon Sep 17 00:00:00 2001
From: Mikura Kyouka <13207280@qq.com>
Date: Thu, 8 Jan 2026 12:34:45 +0800
Subject: [PATCH] Disable animated background to prevent segfault on exit

---
 src/ui/main/mod.rs                | 2 +-
 src/ui/preferences/general/mod.rs | 1 +
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/ui/main/mod.rs b/src/ui/main/mod.rs
index 92c1bef..5daf9f4 100644
--- a/src/ui/main/mod.rs
+++ b/src/ui/main/mod.rs
@@ -662,7 +662,7 @@ impl SimpleComponent for App {
 
             loading: Some(None),
             style: CONFIG.launcher.style,
-            use_video_background: CONFIG.launcher.video_background,
+            use_video_background: false,
             background_index: CONFIG.launcher.background_index,
             state: None,
 
diff --git a/src/ui/preferences/general/mod.rs b/src/ui/preferences/general/mod.rs
index 29e2589..f50a1ce 100644
--- a/src/ui/preferences/general/mod.rs
+++ b/src/ui/preferences/general/mod.rs
@@ -159,6 +159,7 @@ impl SimpleAsyncComponent for GeneralApp {
                 adw::ActionRow {
                     set_title: &tr!("video-background"),
                     set_subtitle: &tr!("video-background-description"),
+                    set_visible: false,
 
                     add_suffix = &gtk::Switch {
                         set_valign: gtk::Align::Center,
