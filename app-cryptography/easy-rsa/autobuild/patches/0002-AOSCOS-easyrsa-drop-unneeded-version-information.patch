From 6b4aca6201d211e7e9a51a2a542a05942780eafd Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Fri, 17 Oct 2025 18:55:07 +0800
Subject: [PATCH 2/2] AOSCOS: easyrsa: drop unneeded version information

Build date and Git commit is irrelevant.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 easyrsa3/easyrsa | 2 --
 1 file changed, 2 deletions(-)

diff --git a/easyrsa3/easyrsa b/easyrsa3/easyrsa
index 5fb4518..3a67c16 100755
--- a/easyrsa3/easyrsa
+++ b/easyrsa3/easyrsa
@@ -6615,9 +6615,7 @@ print_version() {
 		cat << VERSION_TEXT
 EasyRSA Version Information
 Version:     $EASYRSA_version
-Generated:   ~DATE~
 SSL Lib:     ${ssl_version:-undefined}
-Git Commit:  ~GITHEAD~
 Source Repo: https://github.com/OpenVPN/easy-rsa
 VERSION_TEXT
 } # => print_version()
-- 
2.51.0

