From d764846d1544ed00eb444a582656f17d970e892b Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Fri, 17 Oct 2025 18:09:12 +0800
Subject: [PATCH 1/2] AOSCOS: easyrsa: make the package suitable for packaging

- Set package-prefixed variables.
- Remove `./' prefix from help messages.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 easyrsa3/easyrsa | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/easyrsa3/easyrsa b/easyrsa3/easyrsa
index 3968897..5fb4518 100755
--- a/easyrsa3/easyrsa
+++ b/easyrsa3/easyrsa
@@ -10,6 +10,11 @@
 # and the Licensing/ directory of this project for full licensing
 # details.
 
+# Package-defined variables
+EASYRSA=/etc/easy-rsa
+EASYRSA_PKI=/etc/easy-rsa/pki
+EASYRSA_SSL_CONF=/etc/easy-rsa/openssl-easyrsa.cnf
+
 # Help/usage output to stdout
 usage() {
 	# command help:
@@ -652,10 +657,10 @@ default_overview() {
 Easy-RSA 3 Overview:
 
 To get a list of available options and commands, use:
-  ./easyrsa help
+  easyrsa help
 
 To get detailed usage and help for commands, use:
-  ./easyrsa help <COMMAND>"
+  easyrsa help <COMMAND>"
 
 	# collect/show dir status:
 	text_only=1
-- 
2.51.0

