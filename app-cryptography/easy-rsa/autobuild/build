abinfo "Installing easyrsa ..."
install -Dvm755 "$SRCDIR"/easyrsa3/easyrsa \
    "$PKGDIR"/usr/bin/easyrsa

abinfo "Installing configuration files ..."
install -Dvm644 "$SRCDIR"/easyrsa3/openssl-easyrsa.cnf \
    "$PKGDIR"/etc/easy-rsa/openssl-easyrsa.cnf
install -Dvm644 "$SRCDIR"/easyrsa3/vars.example \
    "$PKGDIR"/etc/easy-rsa/vars
install -Dvm644 "$SRCDIR"/easyrsa3/x509-types/* \
    -t "$PKGDIR"/etc/easy-rsa/x509-types/

abinfo "Initialising PKI store ..."
cd "$PKGDIR"/etc/easy-rsa
"$PKGDIR"/usr/bin/easyrsa init-pki
cp -av /etc/easy-rsa/pki \
    "$PKGDIR"/etc/easy-rsa/
