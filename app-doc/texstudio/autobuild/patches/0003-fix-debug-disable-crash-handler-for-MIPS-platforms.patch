From 78d4a73d8bfaefd3cad88083ae37582badce976c Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sat, 12 Apr 2025 12:00:29 +0800
Subject: [PATCH 3/3] fix(debug): disable crash handler for MIPS platforms
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Disable backtrace as it does not build on MIPS any more:

.../src/debug/debughelper.cpp: In function ‘QString print_backtrace(const SimulatedCPU&, const QString&)’:
.../src/debug/debughelper.cpp:470:35: error: expected ‘,’ or ‘;’ before ‘if’
  470 |                                   if (useNativeBacktrace) size = backtrace(trace, 48);
      |                                   ^~

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 src/debug/debughelper.cpp | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/debug/debughelper.cpp b/src/debug/debughelper.cpp
index f8a03b3a2..5aa7d06a7 100644
--- a/src/debug/debughelper.cpp
+++ b/src/debug/debughelper.cpp
@@ -9,10 +9,10 @@
 #define NO_CRASH_HANDLER
 #endif
 
-// disable backtrace on ARM as the code does not compile
+// disable backtrace on ARM, LoongArch, and MIPS as the code does not compile
 // disable backtrace on RISC-V. RISC-V does not support stack unwinding using frame pointer.
 // Recommended approach for RISC-V is dwarf cfi info.
-#if (defined(arm) || defined(__arm__) || defined(__riscv) || defined(__loongarch64))
+#if (defined(arm) || defined(__arm__) || defined(__riscv) || defined(__loongarch64)) || defined(mips) || defined(__mips__) || defined(mipsel) || defined(__mipsel__)
 #define NO_CRASH_HANDLER
 #endif
 
-- 
2.49.0

