PKGNAME=texstudio
PKGSEC=tex
PKGDEP="poppler qt-5 hunspell quazip qtsingleapplication qtermwidget zlib"
BUILDDEP="gettext"
PKGDES="Integrated writing environment for creating LaTeX documents"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DQT_VERSION_MAJOR=5'
    '-DTEXSTUDIO_BUILD_ADWAITA=ON'
    '-DTEXSTUDIO_ENABLE_MEDIAPLAYER=ON'
    '-DTEXSTUDIO_ENABLE_DEBUG_LOGGER=OFF'
)
