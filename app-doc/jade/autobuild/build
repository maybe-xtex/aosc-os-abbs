# Note: Homebrew configure script.
abinfo "Configuring jade ..."
"$SRCDIR"/configure \
    "${AUTOTOOLS_DEF[@]}" \
    --enable-splibdir=/usr/lib \
    --datadir=/usr/share/sgml/openjade-$PKGVER \
    --enable-html \
    --enable-http \
    --enable-mif

abinfo "Building jade ..."
make

abinfo "Installing jade ..."
make install \
    DESTDIR="$PKGDIR"
