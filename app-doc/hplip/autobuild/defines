PKGNAME=hplip
PKGSEC=doc
PKGDEP="ghostscript foomatic net-snmp wget cups dbus-python \
        pillow reportlab pygobject-3 libusb pyqt5 distro sane-backends"
PKGDES="Drivers for HP DeskJet, OfficeJet, Photosmart, and LaserJet printers"

# FIXME: platform.h: No such file or directory
ABSHADOW=0

ABTYPE=autotools
AUTOTOOLS_AFTER=(
    '--prefix=/usr'
    '--enable-scan-build'
    '--enable-gui-build'
    '--enable-fax-build'
    '--disable-foomatic-rip-hplip-install'
    '--enable-pp-build'
    '--disable-qt4'
    '--enable-qt5'
    '--enable-hpcups-install'
    '--enable-cups-drv-install'
    '--enable-foomatic-drv-install'
    '--enable-hpijs-install'
    '--enable-policykit'
    '--with-mimedir=/usr/share/cups/mime'
    '--disable-imageProcessor-build'
)

PKGEPOCH=2
