PKGNAME=gutenprint
PKGSEC=graphics
PKGDES="Print plugins and ghostscript drivers for various printers"
PKGDEP="cups ghostscript libusb ijs"
BUILDDEP="docbook-utils"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
	'--disable-samples'
	'--enable-escputil'
	'--enable-cups-1_2-enhancements'
	'--disable-cups-ppds'
	'--enable-simplified-cups-ppds'
)

PKGEPOCH=1
PKGBREAK="cinepaint<=1.0.4-9 gimp<=2.10.12-1"
