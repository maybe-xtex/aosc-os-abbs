PKGNAME=graphviz
PKGSEC=graphics
PKGDES="Graph visualization software"
PKGDEP="libgd libtool x11-lib ghostscript pango gts libnsl2"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
	'LIBPOSTFIX=""'
	'--disable-ocaml'
	'--without-rsvg'
	'--disable-php'
	'--disable-man-pdfs'
)
# FIXME: Configurations are passed into libltdl
AUTOTOOLS_STRICT=0

# Required for loadable plugins
NOLIBTOOL=0
