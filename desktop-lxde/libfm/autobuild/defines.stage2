PKGNAME=libfm
PKGSEC=x11
PKGDEP="desktop-file-utils libexif dbus-glib gtk-3"
BUILDDEP="intltool gtk-doc"
PKGDES="Library for file management (LXDE)"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
    '--with-gtk=3'
    '--with-extra-only'
    '--disable-old-actions'
)

# FIXME: fatal error: fm-marshal.h: No such file or directory
ABSHADOW=0
