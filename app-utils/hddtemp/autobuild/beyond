abinfo "Installing PAM configuration ..."
install -Dvm644 "$SRCDIR"/system/hddtemp.pam \
    "$PKGDIR"/etc/pam.d/hddtemp

abinfo "Installing main configuration ..."
install -Dvm644 "$SRCDIR"/system/hddtemp.sysconfig \
    "$PKGDIR"/etc/sysconfig/hddtemp

abinfo "Installing systemd unit ..."
install -Dvm644 "$SRCDIR"/system/hddtemp.service \
    "$PKGDIR"/usr/lib/systemd/system/hddtemp.service

abinfo "Installing hddtemp.db ..."
install -Dvm644 "$SRCDIR"/data/hddtemp.db \
    "$PKGDIR"/usr/share/hddtemp/hddtemp.db
