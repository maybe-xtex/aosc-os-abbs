abinfo "Building and zxing-cpp ..."
export CMAKE_AFTER=""
build_cmakeninja_configure
build_cmakeninja_build
build_cmakeninja_install

abinfo "Building python package"
python3 \
	-m build \
	--no-isolation \
	--wheel \
	--outdir "${SRCDIR}/dist" \
	"${SRCDIR}/wrappers/python" \
    || abdie "Failed to build python package"

abinfo "Installing python package ..."
python3 \
	-m installer \
	--destdir="$PKGDIR" \
	"$SRCDIR"/dist/*.whl \
    || abdie "Failed to install python package"
