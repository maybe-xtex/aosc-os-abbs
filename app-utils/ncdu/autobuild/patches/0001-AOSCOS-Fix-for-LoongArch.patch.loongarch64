diff --git a/src/delete.zig b/src/delete.zig
index 5d4d4af093e0..71a00aac638d 100644
--- a/src/delete.zig
+++ b/src/delete.zig
@@ -10,7 +10,7 @@ const scan = @import("scan.zig");
