PKGNAME=kmscon
PKGSEC=utils
PKGDEP="libdrm libtsm mesa pango systemd unifont xkeyboard-config"
PKGDEP__RETRO="libdrm libtsm systemd unifont xkeyboard-config"
PKGDEP__ARMV4="${PKGDEP__RETRO}"
PKGDEP__ARMV6HF="${PKGDEP__RETRO}"
PKGDEP__ARMV7HF="${PKGDEP__RETRO}"
PKGDEP__I486="${PKGDEP__RETRO}"
PKGDEP__LOONGSON2F="${PKGDEP__RETRO}"
PKGDEP__M68K="${PKGDEP__RETRO}"
PKGDEP__POWERPC="${PKGDEP__RETRO}"
PKGDEP__PPC64="${PKGDEP__RETRO}"
PKGDES="Terminal emulator based on Kernel Mode Setting (KMS)"

MESON_AFTER=(
	'-Dextra_debug=false'
	'-Dtests=false'
	'-Ddocs=disabled'
	'-Dmulti_seat=enabled'
	'-Delogind=disabled'
	'-Dvideo_fbdev=enabled'
	'-Dvideo_drm2d=enabled'
	'-Dvideo_drm3d=enabled'
	'-Drenderer_gltex=enabled'
	'-Dfont_unifont=enabled'
	'-Dfont_pango=enabled'
)

MESON_AFTER__RETRO=(
	'-Dextra_debug=false'
	'-Dtests=false'
	'-Ddocs=disabled'
	'-Dmulti_seat=enabled'
	'-Delogind=disabled'
	'-Dvideo_fbdev=enabled'
	'-Dvideo_drm2d=enabled'
	'-Dvideo_drm3d=disabled'
	'-Drenderer_gltex=disabled'
	'-Dfont_unifont=enabled'
	'-Dfont_pango=disabled'
)

PKGREP="kmscon-enablement"
PKGBREAK="kmscon-enablement"
