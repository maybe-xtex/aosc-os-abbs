# Adapted from https://salsa.debian.org/debian/mmdebstrap/-/blob/master/debian/rules
abinfo "Installing mmdebstrap ..."
install -dvm755 "$PKGDIR"/usr/bin
install -Dvm755 "$SRCDIR"/mmdebstrap \
    -t "$PKGDIR"/usr/bin/
install -Dvm755 "$SRCDIR"/tarfilter \
    "$PKGDIR"/usr/bin/mmtarfilter
install -Dvm755 "$SRCDIR"/mmdebstrap-autopkgtest-build-qemu \
    -t "$PKGDIR"/usr/bin/

install -dvm755 "$PKGDIR"/usr/lib/apt/solvers
install -Dvm755 "$SRCDIR"/proxysolver \
    "$PKGDIR"/usr/lib/apt/solvers/mmdebstrap-dump-solution

install -dvm755 "$PKGDIR"/usr/share/mmdebstrap
cp -av "$SRCDIR"/hooks "$PKGDIR"/usr/share/mmdebstrap/

install -dvm755 "$PKGDIR"/usr/libexec/mmdebstrap
install -Dvm755 "$SRCDIR"/gpgvnoexpkeysig \
    -t "$PKGDIR"/usr/libexec/mmdebstrap/
install -Dvm755 "$SRCDIR"/ldconfig.fakechroot \
    -t "$PKGDIR"/usr/libexec/mmdebstrap/
