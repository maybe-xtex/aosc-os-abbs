PKGNAME=tilix
PKGSEC=utils
PKGDEP="gtkd vte dconf gsettings-desktop-schemas gettext liblphobos librsvg"
BUILDDEP="appstream ldc po4a"
PKGSUG="nautilus-python"
PKGDES="A tiling terminal emulator"

PKGBREAK="terminix<=1.5.0"
PKGREP="terminix<=1.5.0"

USECLANG=1
ABTYPE=meson

PKGEPOCH=1
# FIXME: LDC seem to have some issues with fp ABI selection on RISCV64
# when LTO is enabled
NOLTO__RISCV64=1
# FIXME: LDC does not build on these architectures.
FAIL_ARCH="(loongson3|ppc64el)"
