abinfo "Building and installing daemon ..."
(
    cd "$SRCDIR"/coolercontrold
    export SRCDIR="$SRCDIR"/coolercontrold
    build_rust_configure
    build_rust_build
    build_rust_install
);

abinfo "Building and installing Qt GUI ..."
(
    cd "$SRCDIR"/coolercontrol
    export SRCDIR="$SRCDIR"/coolercontrol
    export BLDDIR="$SRCDIR"/abbuild
    build_cmakeninja_configure
    build_cmakeninja_build
    build_cmakeninja_install
);
