abinfo "Installing systemd unit ..."
install -Dvm644 "$SRCDIR"/packaging/systemd/coolercontrold.service \
        -t "$PKGDIR"/usr/lib/systemd/system/

abinfo "Installing metainfo ..."
install -Dvm644 \
        "$SRCDIR"/packaging/metadata/org.coolercontrol.CoolerControl.metainfo.xml \
        -t "$PKGDIR"/usr/share/metainfo/

abinfo "Installing desktop entry ..."
install -Dvm644 \
        "$SRCDIR"/packaging/metadata/org.coolercontrol.CoolerControl.desktop \
        -t "$PKGDIR"/usr/share/applications/

abinfo "Installing icons ..."
install -Dvm644 \
        "$SRCDIR"/packaging/metadata/org.coolercontrol.CoolerControl.svg \
        -t "$PKGDIR"/usr/share/icons/hicolor/scalable/apps/
install -Dvm644 \
        "$SRCDIR"/packaging/metadata/org.coolercontrol.CoolerControl-symbolic.svg \
        -t "$PKGDIR"/usr/share/icons/hicolor/symbolic/apps/
