From ca7f28afe4de00d7ad55f04e17e2ecd8e029b52e Mon Sep 17 00:00:00 2001
From: SkyBird233 <52884766+SkyBird233@users.noreply.github.com>
Date: Tue, 21 Apr 2026 18:42:44 +0800
Subject: [PATCH 5/5] bitwarden: replace rust-lang/libc with patched version
 for loongarch64

---
 apps/desktop/desktop_native/Cargo.toml | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/bitwarden/apps/desktop/desktop_native/Cargo.toml b/bitwarden/apps/desktop/desktop_native/Cargo.toml
index 6aac4c5dd2..967dd44ba7 100644
--- a/bitwarden/apps/desktop/desktop_native/Cargo.toml
+++ b/bitwarden/apps/desktop/desktop_native/Cargo.toml
@@ -97,3 +97,6 @@ print_stdout = "deny"
 string_slice = "warn"
 unused_async = "deny"
 unwrap_used = "deny"
+
+[patch.crates-io]
+libc = { path = "../../../../rust-lang-libc" }
-- 
2.52.0

