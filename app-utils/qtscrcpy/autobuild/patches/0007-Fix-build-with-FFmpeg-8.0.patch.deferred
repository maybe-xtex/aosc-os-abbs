From 0d3959087692499634bdfead989cc6d884ed49a3 Mon Sep 17 00:00:00 2001
From: CAB233 <yidaduizuoye@outlook.com>
Date: Fri, 10 Apr 2026 21:01:36 +0800
Subject: [PATCH 7/7] Fix build with FFmpeg >= 8.0

---
 QtScrcpy/QtScrcpyCore/src/device/decoder/decoder.cpp | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/QtScrcpy/QtScrcpyCore/src/device/decoder/decoder.cpp b/QtScrcpy/QtScrcpyCore/src/device/decoder/decoder.cpp
index 79dec15..5f6979b 100644
--- a/QtScrcpy/QtScrcpyCore/src/device/decoder/decoder.cpp
+++ b/QtScrcpy/QtScrcpyCore/src/device/decoder/decoder.cpp
@@ -51,9 +51,6 @@ void Decoder::close()
     if (!m_codecCtx) {
         return;
     }
-    if (m_isCodecCtxOpen) {
-        avcodec_close(m_codecCtx);
-    }
     avcodec_free_context(&m_codecCtx);
 }
 
