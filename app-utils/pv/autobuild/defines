PKGNAME=pv
PKGSEC=utils
PKGDEP="glibc"
PKGDES="Command-line tool for monitoring the progress of data through a pipeline"

AUTOTOOLS_AFTER=(
    '--disable-debugging'
    '--disable-profiling'
    '--enable-lfs'
    '--disable-static-nls'
    '--enable-nls'
    '--enable-splice'
    '--enable-ipc'
)
