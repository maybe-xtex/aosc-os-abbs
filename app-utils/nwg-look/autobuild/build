abinfo "Building nwg-look ..."
go build -v -o "$SRCDIR"/bin/nwg-look

# Note: Follow the Makefile
abinfo "Installing nwg-look ..."
install -Dvm755 "$SRCDIR"/bin/nwg-look  "$PKGDIR"/usr/bin/nwg-look
install -Dvm644 -t "$PKGDIR"/usr/share/nwg-look/langs "$SRCDIR"/langs/*
install -Dvm644 "$SRCDIR"/stuff/main.glade  "$PKGDIR"/usr/share/nwg-look/main.glade
install -Dvm644 "$SRCDIR"/stuff/nwg-look.desktop  "$PKGDIR"/usr/share/applications/nwg-look.desktop
install -Dvm644 "$SRCDIR"/stuff/nwg-look.svg  "$PKGDIR"/usr/share/pixmaps/nwg-look.svg
