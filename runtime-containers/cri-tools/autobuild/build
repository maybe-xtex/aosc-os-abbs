cd "$SRCDIR"

abinfo "Building cri-tools..."
make -j
cd build
mv ./bin/linux/*/* ./bin/
mkdir -pv completions
./bin/crictl completion bash > completions/crictl
./bin/crictl completion zsh > completions/_crictl

abinfo "Installing cri-tools..."
install -Dvm755 bin/{crictl,critest} -t "$PKGDIR"/usr/bin
install -Dvm644 completions/crictl -t "$PKGDIR"/usr/share/bash-completion/completions/
install -Dvm644 completions/_crictl -t "$PKGDIR"/usr/share/zsh/site-functions/
install -Dvm644 ../{{docs/{crictl,benchmark,validation},CHANGELOG,CONTRIBUTING,README,code-of-conduct}.md,SECURITY_CONTACTS} -t "$PKGDIR"/usr/share/doc/cri-tools/
