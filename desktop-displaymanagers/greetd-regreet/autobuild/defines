PKGNAME=greetd-regreet
PKGSEC=x11
PKGDEP="gcc-runtime glib glibc greetd gtk-4 pango"
BUILDDEP="rustc llvm"
# Regreet is meant to be run under a Wayland compositor
# You need to config /etc/greetd/config.toml and /etc/greetd/regreet.toml
PKGSUG="sway niri"
PKGDES="A GTK 4 based greeter for greetd"
ABTYPE=rust
CARGO_AFTER="--all-features"

# FIXME: ld.lld is not yet available for loongson3.
# ld.lld: error: relocation R_MIPS_64 cannot be used against local symbol; 
# recompile with -fPIC
NOLTO__LOONGSON3=1
