       .map_err(AuthHeaderForNpmRegistryError::Base64)?;
     let bearer = BASE64_STANDARD.encode(format!(
       "{}:{}",
-      username.unwrap(),
+      username,
       String::from_utf8_lossy(&pw_base64)
     ));
 
