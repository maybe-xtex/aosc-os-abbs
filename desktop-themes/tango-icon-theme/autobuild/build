abinfo "Creating directory ..."
mkdir -pv "$PKGDIR"/usr/share/icons/Tango

abinfo "Installing tango-icon-theme ...."
cp -rv "$SRCDIR"/16*16 "$PKGDIR"/usr/share/icons/Tango
cp -rv "$SRCDIR"/22*22 "$PKGDIR"/usr/share/icons/Tango
cp -rv "$SRCDIR"/32*32 "$PKGDIR"/usr/share/icons/Tango
cp -rv "$SRCDIR"/scalable "$PKGDIR"/usr/share/icons/Tango
