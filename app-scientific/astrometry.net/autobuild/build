abinfo "Building astrometry.net ..."
make all py extra \
    SYSTEM_GSL=yes \
    PYTHON=/usr/bin/python3

abinfo "Install astrometry.net ..."
make install \
    INSTALL_DIR="$PKGDIR/usr" \
    ETC_INSTALL_DIR="$PKGDIR/etc" \
    DOC_INSTALL_DIR="$PKGDIR/usr/share/doc/astrometry" \
    EXAMPLE_INSTALL_DIR="$PKGDIR/usr/share/astrometry/examples" \
    DATA_INSTALL_DIR="$PKGDIR/usr/share/astrometry/data" \
    PY_BASE_INSTALL_DIR="$PKGDIR/usr/lib/python${ABPY3VER}/site-packages/astrometry" \
    PY_BASE_LINK_DIR="../lib/python${ABPY3VER}/site-packages/astrometry" \
    DATA_FINAL_DIR=/usr/share/astrometry/data
