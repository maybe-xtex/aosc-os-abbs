From 0a2045292b5602bd1f5350af1b3c73715870faaf Mon Sep 17 00:00:00 2001
From: pch666777 <1005100717@qq.com>
Date: Sat, 29 Nov 2025 13:58:31 +0800
Subject: [PATCH] tachyon support loongarch64, mips64el and riscv64

---
 ...upport-loongarch64-arm-mips64-risv64.patch | 50 +++++++++++++++++++
 build/pkgs/tachyon/patches/Make-arch.patch    | 30 -----------
 build/pkgs/tachyon/spkg-install.in            |  3 ++
 3 files changed, 53 insertions(+), 30 deletions(-)
 create mode 100644 build/pkgs/tachyon/patches/0001-Make-arch-support-loongarch64-arm-mips64-risv64.patch
 delete mode 100644 build/pkgs/tachyon/patches/Make-arch.patch

diff --git a/build/pkgs/tachyon/patches/0001-Make-arch-support-loongarch64-arm-mips64-risv64.patch b/build/pkgs/tachyon/patches/0001-Make-arch-support-loongarch64-arm-mips64-risv64.patch
new file mode 100644
index 00000000000..5f7a79a902a
--- /dev/null
+++ b/build/pkgs/tachyon/patches/0001-Make-arch-support-loongarch64-arm-mips64-risv64.patch
@@ -0,0 +1,50 @@
+From 08bb29a209574d166b059a969bb8e62395466415 Mon Sep 17 00:00:00 2001
+From: pch666777 <1005100717@qq.com>
+Date: Sat, 29 Nov 2025 13:52:57 +0800
+Subject: [PATCH] Make-arch support loongarch64, arm, mips64, risv64
+
+---
+ unix/Make-arch | 27 +++++++++++++++++++++++++++
+ 1 file changed, 27 insertions(+)
+
+diff --git a/unix/Make-arch b/unix/Make-arch
+index 6779f26..38b27be 100644
+--- a/unix/Make-arch
++++ b/unix/Make-arch
+@@ -1929,6 +1929,33 @@ linux-arm64-thr-optix:
+ 	"RANLIB = ranlib" \
+ 	"LIBS = -L. -ltachyonoptix $(MISCLIB) $(CUDALIB) -ldl -lrt -lm -lpthread"
+ 
++# Linux Arm using gcc
++linux-arm:
++	$(MAKE) all \
++	"ARCH = linux-arm" \
++	"CFLAGS = -Wall -O3 -fomit-frame-pointer -ffast-math -DLinux $(MISCFLAGS)" \
++	"ARFLAGS = r" \
++	"STRIP = strip" \
++	"RANLIB = ranlib" \
++	"LIBS = -L. -ltachyon $(MISCLIB) -lm -lpthread"
++
++# Linux Arm using gcc, with threads
++linux-arm-thr:
++	$(MAKE) all \
++	"ARCH = linux-arm-thr" \
++	"CFLAGS = -Wall -O3 -fomit-frame-pointer -ffast-math -DLinux -DTHR -D_REENTRANT $(MISCFLAGS)" \
++	"ARFLAGS = r" \
++	"STRIP = strip" \
++	"LIBS = -L. -ltachyon $(MISCLIB) -lm -lpthread"
++
++# Linux Generic using gcc, with threads
++linux-generic-thr:
++	$(MAKE) all \
++	"ARCH = linux-generic-thr" \
++	"CFLAGS = -Wall -O3 -fomit-frame-pointer -ffast-math -DLinux -DTHR -D_REENTRANT $(MISCFLAGS)" \
++	"ARFLAGS = r" \
++	"STRIP = strip" \
++	"LIBS = -L. -ltachyon $(MISCLIB) -lm -lpthread"
+ 
+ # Linux on AMD64/EM64T, using 'cc', 'c++', and 'nvcc'
+ linux-64-thr-optix:
+-- 
+2.52.0
+
diff --git a/build/pkgs/tachyon/patches/Make-arch.patch b/build/pkgs/tachyon/patches/Make-arch.patch
deleted file mode 100644
index 81d53dda551..00000000000
--- a/build/pkgs/tachyon/patches/Make-arch.patch
+++ /dev/null
@@ -1,30 +0,0 @@
-diff --git a/unix/Make-arch b/unix/Make-arch
-index 08afb85..dbeb691 100644
---- a/unix/Make-arch
-+++ b/unix/Make-arch
-@@ -1471,6 +1471,25 @@
- 	"RANLIB = ranlib" \
- 	"LIBS = -L. -ltachyon $(MISCLIB) -lm -lpthread"
-
-+# Linux Arm using gcc
-+linux-arm:
-+	$(MAKE) all \
-+	"ARCH = linux-arm" \
-+	"CFLAGS = -Wall -O3 -fomit-frame-pointer -ffast-math -DLinux $(MISCFLAGS)" \
-+	"ARFLAGS = r" \
-+	"STRIP = strip" \
-+	"RANLIB = ranlib" \
-+	"LIBS = -L. -ltachyon $(MISCLIB) -lm -lpthread"
-+
-+# Linux Arm using gcc, with threads
-+linux-arm-thr:
-+	$(MAKE) all \
-+	"ARCH = linux-arm-thr" \
-+	"CFLAGS = -Wall -O3 -fomit-frame-pointer -ffast-math -DLinux -DTHR -D_REENTRANT $(MISCFLAGS)" \
-+	"ARFLAGS = r" \
-+	"STRIP = strip" \
-+	"LIBS = -L. -ltachyon $(MISCLIB) -lm -lpthread"
-+
- # Linux x86 using gcc, threads, and OpenGL
- linux-thr-ogl:
- 	$(MAKE) all \
diff --git a/build/pkgs/tachyon/spkg-install.in b/build/pkgs/tachyon/spkg-install.in
index 6a68d95688c..388da68eb59 100644
--- a/build/pkgs/tachyon/spkg-install.in
+++ b/build/pkgs/tachyon/spkg-install.in
@@ -30,6 +30,9 @@ case "$UNAME" in
     armv6l*|armv7l*|aarch64*)
         TARGET=linux-arm-thr
         ;;
+    loongarch64*|mips64el*|riscv64*)
+        TARGET=linux-generic-thr
+        ;;
     esac
     ;;
 "SunOS")
-- 
2.52.0

