abinfo "Building Dart SDK ..."
python3 ./tools/build.py \
    --no-clang \
    --arch="$DART_ARCH" \
    --mode=release \
    --no-verify-sdk-hash \
    --gn-args='dart_embed_icu_data=false dart_snapshot_kind="app-jit" dart_sysroot=""' \
    create_sdk runtime

abinfo "Packaging Dart SDK ..."
install -dvm755 "$PKGDIR"/usr/bin
install -dvm755 "$PKGDIR"/usr/lib
install -dvm755 "$PKGDIR"/usr/include/dart-sdk
cp -av "$DART_OUT"/dart-sdk "$PKGDIR"/usr/lib
ln -sv ../lib/dart-sdk/include "$PKGDIR"/usr/include/dart-sdk

abinfo "Splitting out dartaotruntime files ..."
install -dvm755 "$SRCDIR"/fakeroot/usr/lib/dart-sdk/bin
mv -v "$PKGDIR"/usr/lib/dart-sdk/bin/dartaotruntime \
    "$SRCDIR"/fakeroot/usr/lib/dart-sdk/bin
