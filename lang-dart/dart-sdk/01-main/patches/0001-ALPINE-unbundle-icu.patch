From 64611786ffa61aedbcbed22cd2cbb79529ff7249 Mon Sep 17 00:00:00 2001
From: pugaizai <i@pugai.life>
Date: Fri, 21 Nov 2025 07:40:06 +0800
Subject: [PATCH] build: option to not embed icu data

---
 runtime/bin/BUILD.gn     | 12 ++++++++----
 runtime/runtime_args.gni |  3 +++
 2 files changed, 11 insertions(+), 4 deletions(-)

diff --git a/runtime/bin/BUILD.gn b/runtime/bin/BUILD.gn
index b3b71b39c..973b50cc3 100644
--- a/runtime/bin/BUILD.gn
+++ b/runtime/bin/BUILD.gn
@@ -891,7 +891,6 @@ template("dart_executable") {
     }
     deps = [
       ":crashpad",
-      ":icudtl_cc",
       "//third_party/boringssl",
       "//third_party/icu:icui18n",
       "//third_party/icu:icuuc",
@@ -900,7 +899,11 @@ template("dart_executable") {
     if (is_fuchsia) {
       deps += [ "$fuchsia_sdk/pkg/fdio" ]
     }
-    defines = [ "DART_EMBED_ICU_DATA" ] + extra_defines
+    defines = extra_defines
+    if (dart_embed_icu_data) {
+      defines += [ "DART_EMBED_ICU_DATA" ]
+      deps += [ ":icudtl_cc" ]
+    }
     if (exclude_kernel_service) {
       defines += [ "EXCLUDE_CFE_AND_KERNEL_PLATFORM" ]
     }
@@ -1000,7 +1003,6 @@ dart_executable("dartaotruntime") {
     "..:add_empty_macho_section_config",
   ]
   extra_deps = [
-    ":icudtl_cc",
     "..:libdart_aotruntime",
     "../platform:libdart_platform_aotruntime",
   ]
@@ -1017,7 +1019,9 @@ dart_executable("dartaotruntime") {
     "main_options.h",
     "snapshot_empty.cc",
   ]
-
+  if (dart_embed_icu_data) {
+    extra_deps += [ ":icudtl_cc" ]
+  }
   if (dart_runtime_mode == "release") {
     extra_deps += [
       ":native_assets_api_product",
diff --git a/runtime/runtime_args.gni b/runtime/runtime_args.gni
index 3d72df96a..9b45c33bb 100644
--- a/runtime/runtime_args.gni
+++ b/runtime/runtime_args.gni
@@ -86,6 +86,9 @@ declare_args() {
 
   # Whether to support dynamic loading and interpretation of Dart bytecode.
   dart_dynamic_modules = false
+
+  # Whether to embed ICU data inside the runtime binary.
+  dart_embed_icu_data = true
 }
 
 declare_args() {
-- 
2.52.0
