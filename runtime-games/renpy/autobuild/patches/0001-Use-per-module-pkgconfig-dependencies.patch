+    cython("renpy.uguu.uguu", packages="sdl2")
 
     # renpy.gl2
     cython("renpy.gl2.gl2mesh")
@@ -134,46 +103,44 @@ def main():
     if cubism:
         cython("renpy.gl2.live2dmodel", [ "src/live2dcsm.c" ],)
 
