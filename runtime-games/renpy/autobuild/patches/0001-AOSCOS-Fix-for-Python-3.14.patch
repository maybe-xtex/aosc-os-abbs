Subject: [PATCH 1/3] AOSCOS: Fix for Python 3.14

---
 renpy/gl/glenviron_shader.pyx | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/renpy/gl/glenviron_shader.pyx b/renpy/gl/glenviron_shader.pyx
index 252b26753f12..f47affaf9de8 100644
--- a/renpy/gl/glenviron_shader.pyx
+++ b/renpy/gl/glenviron_shader.pyx
@@ -278,14 +278,14 @@ def check_status(shader, handle, type):
     else:
         glGetProgramiv(handle, GL_INFO_LOG_LENGTH, &log_length)
 
-    log = ' ' * log_length
+    cdef char error[1024]
 
     if shader:
-        glGetShaderInfoLog(handle, log_length, &log_length, <char *> log)
+        glGetShaderInfoLog(handle, log_length, &log_length, error)
     else:
-        glGetProgramInfoLog(handle, log_length, &log_length, <char *> log)
+        glGetProgramInfoLog(handle, log_length, &log_length, error)
 
-    raise Exception("Shader error: %s" % log)
+    raise Exception("Shader error: %s" % ((<object> error).decode("latin-1")))
 
 
 def compile_shader(kind, source):

