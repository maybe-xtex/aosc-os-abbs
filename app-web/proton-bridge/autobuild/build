abinfo "Building proton-bridge ..."
make "cmd/Desktop-Bridge/deploy/linux/bridge"

abinfo "Building launcher ..."
make build-launcher

abinfo "Installing bridge ..."
install -Dvm755 "$SRCDIR/cmd/Desktop-Bridge/deploy/linux/bridge" \
	"$PKGDIR/usr/lib/protonmail/bridge/bridge"

abinfo "Installing bridge-gui ..."
install -Dvm755 "$SRCDIR/cmd/Desktop-Bridge/deploy/linux/bridge-gui" \
	"$PKGDIR/usr/lib/protonmail/bridge/bridge-gui"

abinfo "Installing proton-bridge ..."
install -Dvm755 "$SRCDIR/proton-bridge" \
	"$PKGDIR/usr/lib/protonmail/bridge/proton-bridge"

abinfo "Creating symlink for launcher ..."
mkdir -pv "$PKGDIR/usr/bin"
ln -svf "/usr/lib/protonmail/bridge/proton-bridge" \
	"$PKGDIR/usr/bin/protonmail-bridge"
