From 896256db2f3f4a88cc96863e7bde10cc8a47116b Mon Sep 17 00:00:00 2001
From: "Lain \"Fearyncess\" Yang" <fsf@live.com>
Date: Wed, 16 Apr 2025 17:26:25 +0800
Subject: [PATCH 2/2] BACKPORT: Bug 1958004 - Don't clear CSD margin on
 sizemode changes. r=stransky

This would prevent some resizes in the case we go back from maximized to
a normal window or so, but can cause correctness issues (see bug 1956046
comment 18), so remove the special-case.

I'll try to remove further special cases in separate patches.

Differential Revision: https://phabricator.services.mozilla.com/D244196
---
 widget/gtk/nsWindow.cpp | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/widget/gtk/nsWindow.cpp b/widget/gtk/nsWindow.cpp
index 4fdba10ea9..da65c1977e 100644
--- a/widget/gtk/nsWindow.cpp
+++ b/widget/gtk/nsWindow.cpp
@@ -5406,9 +5406,6 @@ void nsWindow::OnWindowStateEvent(GtkWidget* aWidget,
     return result;
   }();
 
-  if (mSizeMode != oldSizeMode) {
-    mCsdMargin = kCsdMarginUnknown;
-  }
   if (mSizeMode != oldSizeMode || mIsTiled != oldIsTiled) {
     RecomputeBounds(MayChangeCsdMargin::No);
   }
