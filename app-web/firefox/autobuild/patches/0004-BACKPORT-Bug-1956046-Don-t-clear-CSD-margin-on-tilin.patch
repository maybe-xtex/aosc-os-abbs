From 8ea4b466e9fa130d656d57329ae5ecded8812538 Mon Sep 17 00:00:00 2001
From: "Lain \"Fearyncess\" Yang" <fsf@live.com>
Date: Wed, 16 Apr 2025 17:20:06 +0800
Subject: [PATCH 4/5] BACKPORT: Bug 1956046 - Don't clear CSD margin on tiling
 changes. r=stransky

This is meant to prevent spurious resize events when tiling / untiling
(because we still don't know the inner size allocate).

But if the conditions are just right, we might get stuck on an 'unknown'
margin:

 * The X server resizes us first, then changes the tiling state.
 * The GTK theme has the same decorations for tiled and untiled windows.

In that case, we don't get a configure, nor a container size-allocate
event, so the margin remains "unknown". Stick with the old margin.

Differential Revision: https://phabricator.services.mozilla.com/D243470
---
 widget/gtk/nsWindow.cpp | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/widget/gtk/nsWindow.cpp b/widget/gtk/nsWindow.cpp
index 5ffe31f1c3..dd9126d721 100644
--- a/widget/gtk/nsWindow.cpp
+++ b/widget/gtk/nsWindow.cpp
@@ -5382,8 +5382,10 @@ void nsWindow::OnWindowStateEvent(GtkWidget* aWidget,
     return result;
   }();
 
-  if (mSizeMode != oldSizeMode || mIsTiled != oldIsTiled) {
+  if (mSizeMode != oldSizeMode) {
     mCsdMargin = kCsdMarginUnknown;
+  }
+  if (mSizeMode != oldSizeMode || mIsTiled != oldIsTiled) {
     RecomputeBounds(MayChangeCsdMargin::No);
   }
   if (mSizeMode != oldSizeMode && mWidgetListener) {
