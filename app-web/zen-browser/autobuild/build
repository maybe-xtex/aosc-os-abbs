abinfo "Building zen-browser ..."
export SURFER_PLATFORM="linux"
export ZEN_RELEASE=1
export ZEN_RELEASE_BRANCH="release"
npm run build

abinfo "Building multi-locale package ..."
ALL_LOCALES=""
for LANG_CODE in $(cat "${SRCDIR}/lang-codes"); do
	ALL_LOCALES="$ALL_LOCALES ${LANG_CODE}"
done
./engine/mach package-multi-locale --locales $ALL_LOCALES
DIST_DIR="$(realpath "${SRCDIR}"/engine/obj-*/dist)"
PKG="${DIST_DIR}/$(cat "${DIST_DIR}/package_name.txt")"

abinfo "Unpacking multi-locale package..."
mkdir -pv "$PKGDIR/usr/lib"
tar xvf "${PKG}" -C "$PKGDIR/usr/lib"
