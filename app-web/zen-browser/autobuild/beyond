abinfo "Installing icons ..."
for i in 16 22 24 32 48 64 128 256 512 1024; do
	install -Dvm644 "$SRCDIR"/configs/branding/release/logo$i.png \
		"$PKGDIR"/usr/share/icons/hicolor/${i}x${i}/apps/zen-browser.png
done

abinfo "Symlinking dictionaries for spellchecking ..."
rm -rfv "$PKGDIR"/usr/lib/zen-browser/{dictionaries,hyphenation}
ln -sv /usr/share/hunspell \
	"$PKGDIR"/usr/lib/zen-browser/dictionaries
ln -sv /usr/share/hyphen \
	"$PKGDIR"/usr/lib/zen-browser/hyphenation
