abinfo "Installing manpages ..."
"$PKGDIR"/usr/bin/caddy manpage \
    --directory "$PKGDIR"/usr/share/man/man8

abinfo "Installing completions ..."
"$PKGDIR"/usr/bin/caddy completion bash | install -Dvm644 /dev/stdin \
    "$PKGDIR"/usr/share/bash-completion/completions/caddy
"$PKGDIR"/usr/bin/caddy completion zsh | install -Dvm644 /dev/stdin \
    "$PKGDIR"/usr/share/zsh/site-functions/_caddy
"$PKGDIR"/usr/bin/caddy completion fish | install -Dvm644 /dev/stdin \
    "$PKGDIR"/usr/share/fish/vendor_completions.d/caddy.fish

abinfo "Installing example config ..."
install -Dvm644 "$SRCDIR"/dist/config/Caddyfile \
    "$PKGDIR"/etc/caddy/Caddyfile
install -Dvm644 "$SRCDIR"/dist/welcome/index.html \
    "$PKGDIR"/usr/share/caddy/index.html

abinfo "Installing systemd config ..."
install -Dvm644 "$SRCDIR"/dist/init/caddy-api.service \
    "$PKGDIR"/usr/lib/systemd/system/caddy-api.service
install -Dvm644 "$SRCDIR"/dist/init/caddy.service \
    "$PKGDIR"/usr/lib/systemd/system/caddy.service
install -Dvm644 "$SRCDIR"/dist/init/caddy.sysusers \
    "$PKGDIR"/usr/lib/sysusers.d/caddy.conf
