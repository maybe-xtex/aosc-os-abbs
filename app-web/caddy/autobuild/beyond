abinfo "Installing manpages ..."
"$PKGDIR"/usr/bin/caddy manpage \
    --directory "$PKGDIR"/usr/share/man/man8

abinfo "Installing completions ..."
install -dvm755 "$PKGDIR"/usr/share/bash-completion/completions
"$PKGDIR"/usr/bin/caddy completion bash \
    > "$PKGDIR"/usr/share/bash-completion/completions/caddy
install -dvm755 "$PKGDIR"/usr/share/zsh/site-functions
"$PKGDIR"/usr/bin/caddy completion zsh \
    > "$PKGDIR"/usr/share/zsh/site-functions/_caddy
install -dvm755 "$PKGDIR"/usr/share/fish/vendor_completions.d
"$PKGDIR"/usr/bin/caddy completion fish \
    > "$PKGDIR"/usr/share/fish/vendor_completions.d/caddy.fish
