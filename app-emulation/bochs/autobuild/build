abinfo "Configuring Bochs ..."
CONFIGURE_ARGS="${AUTOTOOLS_AFTER[*]} ${AUTOTOOLS_DEF[*]}" sh "$SRCDIR"/.conf.linux

abinfo "Tweaking config.h (disable BX_NETMOD_FBSD) to fix build ..."
sed -e 's/BX_NETMOD_FBSD\ 1/BX_NETMOD_FBSD\ 0/g' \
    -i "$SRCDIR"/config.h

abinfo "Building Bochs ..."
make V=1

abinfo "Installing Bochs ..."
make install \
    DESTDIR="$PKGDIR"
