PKGNAME=86box
PKGSEC=utils
PKGDEP="gcc-runtime fluidsynth glib jack libevdev libpng libserialport \
        libslirp libsndfile libxcb openal-soft qt-5 rtmidi sdl2 wayland \
        x11-lib zlib"
PKGRECOM="86box-roms"
PKGDES="Emulator for x86-based machines"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DUSE_QT6=OFF'
    '-DSTATIC_BUILD=OFF'
    '-DRELEASE=ON'
    '-DDYNAREC=OFF'
    '-DOPENAL=ON'
    '-DRTMIDI=ON'
    '-DFLUIDSYNTH=ON'
    '-DMUNT=OFF'
    '-DVNC=OFF'
    '-DMINITRACE=OFF'
    '-DGDBSTUB=OFF'
    '-DDEV_BRANCH=OFF'
    '-DDISCORD=ON'
    '-DDEBUGREGS486=OFF'
    '-DLIBASAN=OFF'
)
CMAKE_AFTER__AMD64=(
    "${CMAKE_AFTER[@]}"
    '-DDYNAREC=ON'
)
# Upstream advised to use "new" dynamic recompiler for arm64.
CMAKE_AFTER__ARM64=(
    "${CMAKE_AFTER[@]}"
    '-DDYNAREC=ON'
    '-DNEW_DYNAREC=ON'
)
