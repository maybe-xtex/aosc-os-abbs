index 5e7c64b2a..f4fa64689 100755
--- a/debian/postinst
+++ b/debian/postinst
@@ -59,9 +59,9 @@ if [ "$1" = "configure" ]; then
 
   # create users groups (disable with INSTALL_NO_GROUP=1 in /etc/default/virtualbox)
