PKGNAME=libde265
PKGDES="An H.265 video codec implementation"
PKGDEP="gcc-runtime"
BUILDDEP="gdk-pixbuf qt-5"
BUILDDEP__RETRO="gdk-pixbuf"
PKGSEC=libs

ABTYPE=cmakeninja
# encoder is disabled by default from 1.0.10. Enabling it here.
CMAKE_AFTER=(
    '-DENABLE_ENCODER=ON'
    '-DENABLE_SHERLOCK265=ON'
)
# NOTE: For Afterglow:
# - Disable encoder (we use x265 for that part).
# - Disable sherlock265, H.265 video player for Qt.
CMAKE_AFTER=(
    '-DENABLE_ENCODER=OFF'
    '-DENABLE_SHERLOCK265=OFF'
)
