From 108fa7108a12b5ff83d4a14bcace038cec0324de Mon Sep 17 00:00:00 2001
From: Ruikai Liu <rickliu2000@outlook.com>
Date: Tue, 11 Nov 2025 16:11:59 +0800
Subject: [PATCH 4/4] UPSTREAM: gstplugin: convert plugin loading mutex to
 recursive mutex

Link: https://gitlab.freedesktop.org/gstreamer/gstreamer/-/commit/61721e8abdcf07d6ea7a2787bf079d263a36b717
---
 subprojects/gstreamer/gst/gstplugin.c | 14 +++++++-------
 1 file changed, 7 insertions(+), 7 deletions(-)

diff --git a/subprojects/gstreamer/gst/gstplugin.c b/subprojects/gstreamer/gst/gstplugin.c
index 10ad0b0132..21757b6764 100644
--- a/subprojects/gstreamer/gst/gstplugin.c
+++ b/subprojects/gstreamer/gst/gstplugin.c
@@ -674,7 +674,7 @@ check_release_datetime (const gchar * date_time)
   return (*date_time == '\0');
 }
 
-static GMutex gst_plugin_loading_mutex;
+static GRecMutex gst_plugin_loading_mutex;
 
 #define CHECK_PLUGIN_DESC_FIELD(desc,field,fn)                               \
   if (G_UNLIKELY ((desc)->field == NULL || *(desc)->field == '\0')) {        \
@@ -826,13 +826,13 @@ _priv_gst_plugin_load_file_for_registry (const gchar * filename,
   if (registry == NULL)
     registry = gst_registry_get ();
 
-  g_mutex_lock (&gst_plugin_loading_mutex);
+  g_rec_mutex_lock (&gst_plugin_loading_mutex);
 
   plugin = gst_registry_lookup (registry, filename);
   if (plugin) {
     if (plugin->module) {
       /* already loaded */
-      g_mutex_unlock (&gst_plugin_loading_mutex);
+      g_rec_mutex_unlock (&gst_plugin_loading_mutex);
       return plugin;
     } else if (g_strcmp0 (plugin->filename, filename) == 0) {
       /* load plugin and update fields */
@@ -1003,14 +1003,14 @@ _priv_gst_plugin_load_file_for_registry (const gchar * filename,
     gst_registry_add_plugin (registry, plugin);
   }
 
-  g_mutex_unlock (&gst_plugin_loading_mutex);
+  g_rec_mutex_unlock (&gst_plugin_loading_mutex);
   return plugin;
 
 return_error:
   {
     if (plugin)
       gst_object_unref (plugin);
-    g_mutex_unlock (&gst_plugin_loading_mutex);
+    g_rec_mutex_unlock (&gst_plugin_loading_mutex);
     return NULL;
   }
 }
@@ -1200,9 +1200,9 @@ gst_plugin_is_loaded (GstPlugin * plugin)
   if (plugin->filename == NULL)
     return TRUE;                /* Static plugin */
 
-  g_mutex_lock (&gst_plugin_loading_mutex);
+  g_rec_mutex_lock (&gst_plugin_loading_mutex);
   ret = (plugin->module != NULL);
-  g_mutex_unlock (&gst_plugin_loading_mutex);
+  g_rec_mutex_unlock (&gst_plugin_loading_mutex);
 
   return ret;
 }
