scons ${MAKEFLAGS} \
      CUSTOM_ENV=True \
      DEBUG=False \
      PREFIX=/usr \
      LIBDIR=/usr/lib \
      MANDIR=/usr/share/man \
      UDEVDIR=/usr/lib/udev/rules.d \
      PYTHON_INTERPRETER="/usr/bin/python3" \
      PYPKGDIR="/usr/lib/python${ABPY3VER}/site-packages" \
      BUILD_DOC=none \
      BUILD_TESTS=False

scons install DESTDIR="$PKGDIR" \
      WILL_DEAL_WITH_XDG_MYSELF="True"
