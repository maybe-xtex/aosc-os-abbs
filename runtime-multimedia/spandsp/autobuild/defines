PKGNAME=spandsp
PKGSEC=libs
PKGDEP="glibc libjpeg-turbo libtiff libwebp xz zstd"
BUILDDEP="docbook-xsl libxslt"
PKGDES="A low-level signal processing library that modulates and demodulates signals commonly used in telephony"

ABSHADOW=0

AUTOTOOLS_AFTER=(
    "--disable-builtin-tiff"
    "--disable-doc"
    "--disable-fixed-point"  # NOTE: if hardware have FPU, disable it.
)
AUTOTOOLS_AFTER__AMD64=(
    "${AUTOTOOLS_AFTER}"
    "--enable-mmx"
    "--enable-sse"
    "--enable-sse2"
    "--disable-sse3"
    "--disable-ssse3"
    "--disable-sse4-1"
    "--disable-sse4-2"
    "--disable-avx"
)
