PKGNAME=mbedtls+32
PKGSEC=libs
PKGDEP="aosc-aaa+32 glibc+32"
BUILDDEP="devel-base+32"
PKGDES="Portable cryptographic and SSL/TLS library (32-bit x86 runtime)"

ABHOST=optenv32
ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DDISABLE_PACKAGE_CONFIG_AND_INS=OFF'
    '-DENABLE_PROGRAMS=ON'
    '-DENABLE_TESTING=OFF'
    '-DGEN_FILES=OFF'
    '-DINSTALL_MBEDTLS_HEADERS=ON'
    '-DLINK_WITH_PTHREAD=OFF'
    '-DLINK_WITH_TRUSTED_STORAGE=OFF'
    '-DUSE_SHARED_MBEDTLS_LIBRARY=ON'
    '-DUSE_STATIC_MBEDTLS_LIBRARY=ON'
)

NOSTATIC=0
