for abiver in 5 6; do
    for widechar in disable enable; do
        abinfo "Configuring ncurses (ABI version: ${abiver}, wide character: ${widechar}d) ..."
        "$SRCDIR"/configure \
            ${AUTOTOOLS_DEF[@]} ${AUTOTOOLS_AFTER[@]} \
            --${widechar}-widec --with-abi-version=${abiver}

        abinfo "Building ncurses (ABI version: ${abiver}, wide character: ${widechar}d) ..."
        make

        abinfo "Installing ncurses (ABI version: ${abiver}, wide character: ${widechar}d) ..."
        make install \
            DESTDIR="$PKGDIR"

        abinfo "Cleaning up ... (ABI version: ${abiver}, wide character: ${widechar}d) ..."
        make distclean
    done
done

for i in tinfo tic; do
    abinfo "Creating compatibility symlinks for lib${i} ..."
    ln -sv libncursesw.so.${PKGVER} \
        "$PKGDIR"/opt/32/lib/lib${i}.so.${PKGVER%%.*}
    ln -sv lib${i}.so.${PKGVER%%.*} \
        "$PKGDIR"/opt/32/lib/lib${i}.so
done

for i in tinfo tic; do
    abinfo "Creating pkg-config symlinks for lib${i} ..."
    ln -sv ncursesw.pc \
        "$PKGDIR"/opt/32/lib/pkgconfig/${i}.pc
done
