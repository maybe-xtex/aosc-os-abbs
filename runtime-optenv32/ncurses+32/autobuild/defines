PKGNAME=ncurses+32
PKGSEC=libs
PKGDEP="aosc-aaa+32 glibc+32"
BUILDDEP="devel-base+32"
PKGDES="Library to create terminal user interfaces (32-bit x86 runtime)"

ABTYPE=self
AUTOTOOLS_AFTER=(
    '--with-pkg-config-libdir=/opt/32/lib/pkgconfig'
    '--with-shared'
    # Note: Disable static libraries.
    '--without-normal'
    '--without-debug'
    '--without-ada'
    '--enable-pc-files'
    '--with-cxx-binding'
    '--with-cxx-shared'
    '--without-gpm'
    '--enable-ext-colors'
    '--with-versioned-syms'
    # FIXME: Broken with ABI version 5.
    '--without-tests'
)

ABHOST=optenv32
