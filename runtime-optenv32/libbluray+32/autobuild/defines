PKGNAME=libbluray+32
PKGSEC=libs
PKGDEP="aosc-aaa+32 libxml2+32 fontconfig+32 freetype+32"
BUILDDEP="devel-base+32"
PKGDES="Library to access Blu-Ray disks for video playback (32-bit x86 runtime)"

ABTYPE=meson
MESON_AFTER=(
    '-Denable_docs=false'
    '-Denable_tools=true'
    '-Denable_devtools=true'
    '-Denable_examples=false'
    '-Dbdj_jar=disabled'
    '-Dfontconfig=enabled'
    '-Dfreetype=enabled'
    '-Dlibxml2=enabled'
)

ABHOST=optenv32

PKGBREAK="ffmpeg<=7.1"
