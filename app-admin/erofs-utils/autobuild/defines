PKGNAME=erofs-utils
PKGSEC=admin
PKGDES="Userspace tools for EROFS"
PKGDEP="fuse-3 zlib libdeflate zstd xxhash lz4 util-linux-runtime glibc"

AUTOTOOLS_AFTER=(
    "--enable-multithreading"
    "--enable-fuse"
    "--enable-lz4"
    "--enable-lzma"
    "--with-libzstd"
    "--with-libdeflate"
    "--with-xxhash"
    "--with-zlib"
    "--with-uuid"
)
