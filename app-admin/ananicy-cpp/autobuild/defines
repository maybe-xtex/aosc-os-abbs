PKGNAME=ananicy-cpp
PKGSEC=admin
BUILDDEP="cmake ninja nlohmann-json llvm"
PKGDEP="fmt spdlog elfutils pcre2 zlib libbpf systemd ananicy-rules"
PKGDES="Shell daemon to manage processes' IO and CPU priorities"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCMAKE_BUILD_TYPE=Release'
    '-DUSE_EXTERNAL_JSON=ON'
    '-DUSE_EXTERNAL_SPDLOG=ON'
    '-DUSE_EXTERNAL_FMTLIB=ON'
    '-DENABLE_SYSTEMD=ON'
    '-DUSE_BPF_PROC_IMPL=ON'
    '-DBPF_BUILD_LIBBPF=OFF'
)

CMAKE_AFTER__PPC64EL=(
    "${CMAKE_AFTER[@]}"
    # FIXME: No kernel BPF support.
    '-DUSE_BPF_PROC_IMPL=OFF'
)

CMAKE_AFTER__LOONGSON3=(
    "${CMAKE_AFTER[@]}"
    # FIXME: No kernel BPF support.
    '-DUSE_BPF_PROC_IMPL=OFF'
)
