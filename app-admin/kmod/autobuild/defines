PKGNAME=kmod
PKGSEC=admin
PKGDEP="glibc openssl xz zlib zstd"
# Note: scdoc for building manpages.
BUILDDEP="scdoc gtk-doc"
BUILDDEP__RETRO="scdoc"
PKGDES="Tools for managing kernel modules"

ABTYPE=meson
MESON_AFTER=(
    '-Dtools=true'
    '-Dmanpages=true'
    '-Dlogging=true'
    '-Ddebug=false'
    '-Dzstd=enabled'
    '-Dxz=enabled'
    '-Dzlib=enabled'
    '-Dopenssl=enabled'
    '-Ddocs=true'
)
MESON_AFTER__RETRO=(
    "${MESON_AFTER[@]}"
    '-Ddocs=false'
)

PKGESS=1

PKGBREAK="bash-completion<=1:2.14.0"
