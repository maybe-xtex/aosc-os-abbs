From 0b60cb227772272dea952e54fcd1c9bb014e839b Mon Sep 17 00:00:00 2001
From: liushuyu <liushuyu011@gmail.com>
Date: Thu, 15 Jul 2021 03:28:21 -0600
Subject: [PATCH 1/3] apt: allow disable gst matcher

---
 backends/apt/apt-job.cpp |  2 ++
 backends/apt/meson.build | 51 +++++++++++++++++++++++++++-------------
 2 files changed, 37 insertions(+), 16 deletions(-)

diff --git a/backends/apt/apt-job.cpp b/backends/apt/apt-job.cpp
index 0217eb854..c6fd64c84 100644
--- a/backends/apt/apt-job.cpp
+++ b/backends/apt/apt-job.cpp
@@ -593,6 +593,7 @@ void AptJob::emitUpdates(PkgList &output, PkBitfield filters)
 // search packages which provide a codec (specified in "values")
 void AptJob::providesCodec(PkgList &output, gchar **values)
 {
+#ifdef HAVE_GST_DEPS
     string arch;
     GstMatcher matcher(values);
     if (!matcher.hasMatches()) {
@@ -636,6 +637,7 @@ void AptJob::providesCodec(PkgList &output, gchar **values)
             output.append(ver);
         }
     }
+#endif
 }
 
 // search packages which provide the libraries specified in "values"
diff --git a/backends/apt/meson.build b/backends/apt/meson.build
index ef6f9ae2e..3eccfb31a 100644
--- a/backends/apt/meson.build
+++ b/backends/apt/meson.build
@@ -2,9 +2,11 @@ add_languages('cpp', native: false)
 
 cpp_compiler = meson.get_compiler('cpp')
 
-gstreamer_dep = dependency('gstreamer-1.0')
-gstreamer_base_dep = dependency('gstreamer-base-1.0')
-gstreamer_plugins_base_dep = dependency('gstreamer-plugins-base-1.0')
+if get_option('gstreamer_plugin')
+  gstreamer_dep = dependency('gstreamer-1.0')
+  gstreamer_base_dep = dependency('gstreamer-base-1.0')
+  gstreamer_plugins_base_dep = dependency('gstreamer-plugins-base-1.0')
+endif
 appstream_dep = dependency('appstream', version: '>=0.16.0')
 apt_pkg_dep = dependency('apt-pkg', version: '>=1.9.2')
 
@@ -25,13 +27,12 @@ if cpp_compiler.compiles(
   ddtp_flag = ['-DHAVE_DDTP']
 endif
 
+aptcc_args = []
 c_args = ['-DG_LOG_DOMAIN="PackageKit-APT"',
           '-DDATADIR="@0@"'.format(join_paths(get_option('prefix'), get_option('datadir'))),
 ]
 
-# Required to be used by the test suite
-packagekit_backend_apt_lib = static_library(
-  'pk_backend_apt_lib',
+aptcc_sources = [
   'acqpkitstatus.cpp',
   'acqpkitstatus.h',
   'apt-cache-file.cpp',
@@ -48,23 +49,40 @@ packagekit_backend_apt_lib = static_library(
   'deb822.h',
   'deb-file.cpp',
   'deb-file.h',
-  'gst-matcher.cpp',
-  'gst-matcher.h',
   'pkg-list.cpp',
   'pkg-list.h',
-  include_directories: packagekit_src_include,
-  dependencies: [
-    packagekit_glib2_dep,
-    apt_pkg_dep,
-    appstream_dep,
+]
+
+aptcc_deps = [
+  packagekit_glib2_dep,
+  apt_pkg_dep,
+  appstream_dep,
+]
+
+if get_option('gstreamer_plugin')
+  aptcc_sources += [
+    'gst-matcher.cpp',
+    'gst-matcher.h',
+  ]
+  aptcc_deps += [
     gstreamer_dep,
     gstreamer_base_dep,
     gstreamer_plugins_base_dep,
-  ],
+  ]
+  aptcc_args = ['-DHAVE_GST_DEPS']
+endif
+
+# Required to be used by the test suite
+packagekit_backend_apt_lib = static_library(
+  'pk_backend_apt_lib',
+  aptcc_sources,
+  include_directories: packagekit_src_include,
+  dependencies: aptcc_deps,
   c_args: c_args,
   cpp_args: [
     c_args,
     ddtp_flag,
+    aptcc_args,
   ],
   link_args: [
     '-lutil',
@@ -99,6 +117,7 @@ packagekit_backend_apt_module = shared_module(
   cpp_args: [
     c_args,
     ddtp_flag,
+    aptcc_args,
   ],
   override_options: [
     'b_lundef=false',
@@ -149,5 +168,3 @@ if get_option('systemd')
     install_dir: systemd_user_unit_dir,
   )
 endif
-
-subdir('tests')
