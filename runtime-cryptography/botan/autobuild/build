abinfo "Configuring botan ..."
"$SRCDIR"/configure.py --prefix=/usr \
               --with-bzip \
               --with-lzma \
               --with-zlib \
               --with-tpm \
               --with-os-feature=getrandom \
               --with-debug-info \
               --with-rst2man

abinfo "Building botan ..."
make

abinfo "Installing botan ..."
make install DESTDIR="$PKGDIR"
