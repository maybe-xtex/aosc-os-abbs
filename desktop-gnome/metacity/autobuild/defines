PKGNAME=metacity
PKGSEC=gnome
PKGDEP="dconf gtk-3 gsettings-desktop-schemas libcanberra libgtop \
        startup-notification vulkan zenity"
PKGDES="Window manager for GNOME Flashback"

AUTOTOOLS_AFTER=(
    '--enable-nls'
    '--disable-rpath'
    '--disable-schemas-compile'
    '--enable-canberra'
    '--enable-sm'
    '--enable-render'
    '--enable-xinerama'
    '--enable-vulkan'
    '--with-x'
)
