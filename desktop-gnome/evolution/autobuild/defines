    '-DENABLE_SMIME=ON'
    '-DENABLE_TEXT_HIGHLIGHT=ON'
    '-DENABLE_WEATHER=ON'
    '-DENABLE_YTNEF=ON'
    '-DWITH_BOGOFILTER=ON'
    '-DWITH_ENCHANT_VERSION=2'
    '-DWITH_GLADE_CATALOG=OFF'
