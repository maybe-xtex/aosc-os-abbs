PKGNAME=feedbackd
PKGSEC=admin
PKGDEP="systemd glib gsound json-glib libgudev gmobile umockdev"
BUILDDEP="gobject-introspection vala jinja2 typogrify tomli docutils"
PKGDES="Daemon to provide haptic, LED, and audio feedback triggered by application events"

ABTYPE=meson
MESON_AFTER=("-Dintrospection=enabled"
             "-Dvapi=true"
             "-Ddaemon=true"
             "-Dman=true"
             "-Dtests=false")

PKGEPOCH=1
