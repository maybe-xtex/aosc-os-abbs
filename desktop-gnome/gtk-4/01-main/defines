PKGNAME=gtk-4
PKGSEC=x11
PKGDES="GIMP toolkit version 4"
PKGDEP="cairo colord cups dconf desktop-file-utils fontconfig fribidi \
        gdk-pixbuf glib graphene gstreamer libpng libxkbcommon harfbuzz \
        iso-codes libcloudproviders libepoxy libtiff libjpeg-turbo \
        pango shared-mime-info tinysparql vulkan-loader wayland x11-lib"
BUILDDEP="docutils gobject-introspection shaderc wayland-protocols vulkan"
PKGDEP__RETRO="${PKGDEP/libcloudproviders/}"
BUILDDEP__RETRO="wayland-protocols vulkan shaderc"

MESON_AFTER=(
    '-Dx11-backend=true'
    '-Dwayland-backend=true'
    '-Dbroadway-backend=true'
    '-Dmedia-gstreamer=enabled'
    '-Dprint-cups=enabled'
    '-Dvulkan=enabled'
    '-Dcloudproviders=enabled'
    '-Dsysprof=disabled'
    '-Dtracker=enabled'
    '-Dcolord=enabled'
    '-Df16c=enabled'
    '-Ddocumentation=false'
    '-Dman-pages=true'
    '-Dintrospection=enabled'
    '-Dbuild-demos=true'
    '-Dbuild-examples=true'
    '-Dbuild-testsuite=false'
    '-Dbuild-tests=false'
)

MESON_AFTER__RETRO=(
    "${MESON_AFTER[@]}"
    '-Dbroadway-backend=false'
    '-Dcloudproviders=disabled'
    '-Dman-pages=false'
    '-Dintrospection=disaabled'
    '-Dbuild-demos=false'
    '-Dbuild-examples=false'
    '-Dbuild-testsuite=false'
    '-Dbuild-tests=false'
)

PKGBREAK="gtk-2<=2.24.32-3 gtk-3<=3.24.24-1"
PKGREP="gtk-2<=2.24.32-3 gtk-3<=3.24.24-1"

PKGEPOCH=1
