PKGNAME=gnome-control-center
PKGSEC=gnome
PKGDEP="accountsservice colord-gtk gnome-bluetooth gnome-desktop \
        gnome-online-accounts gnome-settings-daemon libadwaita libgtop \
        libibus libnma libsoup-3 libwacom malcontent tecla udisks-2"
BUILDDEP="blueprint-compiler"
PKGDES="Control center for GNOME"

ABTYPE=meson
MESON_AFTER=(
    '-Ddeprecated-declarations=disabled'
    '-Ddocumentation=false'
    '-Dlocation-services=enabled'
    '-Dibus=true'
    '-Dprivileged_group=wheel'
    '-Dsnap=true'
    '-Dtests=false'
    '-Dx11=true'
    '-Dprofile=default'
    '-Dmalcontent=true'
    '-Ddistributor_logo=/usr/share/pixmaps/aosc-os-gnome.svg'
    '-Ddark_mode_distributor_logo=/usr/share/pixmaps/aosc-os-gnome-dark.svg'
)
