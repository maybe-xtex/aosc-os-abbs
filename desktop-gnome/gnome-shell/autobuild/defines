PKGNAME=gnome-shell
PKGSEC=gnome
PKGDEP="evolution-data-server gcr-4 gjs gnome-autoar gnome-control-center \
        gnome-desktop gsettings-desktop-schemas libsecret mutter \
        networkmanager pipewire systemd"
BUILDDEP="docutils gobject-introspection"
PKGDES="Default desktop interface for GNOME"

ABTYPE=meson
MESON_AFTER=(
    '-Dcamera_monitor=true'
    '-Dextensions_tool=true'
    '-Dextensions_app=true'
    '-Dgtk_doc=false'
    '-Dman=true'
    '-Dtests=false'
    '-Dnetworkmanager=true'
    '-Dportal_helper=true'
    '-Dsystemd=true'
)
