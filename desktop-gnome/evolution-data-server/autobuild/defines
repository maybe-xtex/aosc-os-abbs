PKGNAME=evolution-data-server
PKGSEC=gnome
PKGDEP="gnome-online-accounts nss krb5 libgweather libical db \
        libgdata libphonenumber webkit2gtk icu libcanberra"
BUILDDEP="gobject-introspection gperf vala"
PKGDES="Unified backend for programs that work with contacts, tasks, and calendar information"

CMAKE_AFTER=(
    '-DENABLE_CODE_COVERAGE=OFF'
    '-DENABLE_SCHEMAS_COMPILE=OFF'
    '-DENABLE_INTROSPECTION=ON'
    '-DENABLE_GTK_DOC=OFF'
    '-DENABLE_INSTALLED_TESTS=OFF'
    '-DWITH_KRB5=ON'
    '-DWITH_OPENLDAP=ON'
    '-DWITH_SUNLDAP=OFF'
    '-DWITH_STATIC_LDAP=OFF'
    '-DWITH_PHONENUMBER=ON'
    '-DWITH_SMIME=ON'
    '-DENABLE_MAINTAINER_MODE=OFF'
    '-DWITH_PRIVATE_DOCS=ON'
    '-DENABLE_GTK=ON'
    '-DENABLE_OAUTH2=ON'
    '-DENABLE_EXAMPLES=ON'
    '-DENABLE_GOA=ON'
    '-DENABLE_BACKEND_PER_PROCESS=OFF'
    '-DWITH_LIBDB=ON'
    '-DWITH_BACKTRACES=OFF'
    '-DENABLE_IPV6=ON'
    '-DENABLE_WEATHER=ON'
    '-DWITH_GWEATHER4=ON'
    '-DENABLE_CANBERRA=ON'
    '-DENABLE_DOT_LOCKING=ON'
    '-DENABLE_BROKEN_SPOOL=OFF'
    '-DENABLE_GOOGLE=ON'
    '-DENABLE_LARGEFILE=ON'
    '-DENABLE_VALA_BINDINGS=ON'
    '-DLIB_INSTALL_DIR=/usr/lib'
    '-DCMAKE_SKIP_RPATH=OFF'
    '-DCMAKE_SKIP_INSTALL_RPATH=OFF'
)

PKGREP="evolution<=3.28.5-1"
PKGBREAK="""
bijiben<=40.1-4 calls<=46.0-1 endeavour<=42.0-1 evolution-ews<=3.42.0-1
evolution<=3.44.4-7 folks<=0.15.5 gnome-calendar<=42.2-1 gnome-contacts<=42.0-1
