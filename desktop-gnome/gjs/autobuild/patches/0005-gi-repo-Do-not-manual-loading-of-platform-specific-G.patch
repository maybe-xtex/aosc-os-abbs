From ab3833762b2371d92ae3d8b422c5a68b53b39096 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Marco=20Trevisan=20=28Trevi=C3=B1o=29?= <mail@3v1n0.net>
Date: Fri, 29 Aug 2025 15:40:43 +0200
Subject: [PATCH 5/5] gi/repo: Do not manual loading of platform-specific Gio
 namespace

This will be handled by GLib upstream now.

See: https://gitlab.gnome.org/GNOME/glib/-/merge_requests/4761
---
 gi/repo.cpp | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/gi/repo.cpp b/gi/repo.cpp
index a6746e40..25fd28bc 100644
--- a/gi/repo.cpp
+++ b/gi/repo.cpp
@@ -584,7 +584,11 @@ Maybe<GI::AutoRegisteredTypeInfo> gjs_lookup_gtype(const GI::Repository& repo,
     if (!retval)
         return {};
 
-#if GLIB_CHECK_VERSION(2, 79, 2) && (defined(G_OS_UNIX) || defined(G_OS_WIN32))
+#if GLIB_CHECK_VERSION(2, 85, 5)
+    return retval;
+#endif  // GLib >= 2.85.5
+
+#if (defined(G_OS_UNIX) || defined(G_OS_WIN32))
 #    ifdef G_OS_UNIX
     static const char* c_prefix = "GUnix";
     static const char* new_ns = "GioUnix";
-- 
