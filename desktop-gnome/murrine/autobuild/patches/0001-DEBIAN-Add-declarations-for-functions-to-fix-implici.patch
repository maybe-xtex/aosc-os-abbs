From: Peter Michael Green <plugwash@debian.org>
Date: Sun, 14 Sep 2025 00:36:03 +0800
Subject: [PATCH 1/2] DEBIAN: Add declarations for functions to fix implicit
 function declaration errors

Signed-off-by: Peter Michael Green <plugwash@debian.org>
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 src/murrine_rc_style.h | 2 ++
 src/murrine_style.h    | 1 +
 src/support.h          | 3 +++
 3 files changed, 6 insertions(+)

diff --git a/src/murrine_rc_style.h b/src/murrine_rc_style.h
index 97ca50c..c851a46 100644
--- a/src/murrine_rc_style.h
+++ b/src/murrine_rc_style.h
@@ -153,4 +153,6 @@ struct _MurrineRcStyleClass
 
 GType murrine_rc_style_get_type	(void);
 
+void murrine_rc_style_register_types (GTypeModule *module);
+
 #endif /* MURRINE_RC_STYLE_H */
diff --git a/src/murrine_style.h b/src/murrine_style.h
index 439ce6c..997a684 100644
--- a/src/murrine_style.h
+++ b/src/murrine_style.h
@@ -100,5 +100,6 @@ struct _MurrineStyleClass
 };
 
 GType murrine_style_get_type (void);
+void murrine_style_register_types (GTypeModule *module);
 
 #endif /* MURRINE_STYLE_H */
diff --git a/src/support.h b/src/support.h
index b5d0285..3b0292a 100644
--- a/src/support.h
+++ b/src/support.h
@@ -147,4 +147,7 @@ G_GNUC_INTERNAL void murrine_get_notebook_tab_position (GtkWidget *widget,
                                                         gboolean  *start,
                                                         gboolean  *end);
 
+gboolean murrine_object_is_a (const GObject * object, const gchar * type_name);
+gboolean murrine_widget_is_ltr (GtkWidget *widget);
+
 #endif /* SUPPORT_H */
