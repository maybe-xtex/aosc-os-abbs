PKGNAME=mutter
PKGSEC=gnome
PKGDEP="dconf egl-wayland gnome-settings-daemon graphene \
        gsettings-desktop-schemas gtk-4 libadwaita libdisplay-info libei \
        libinput libwacom pipewire startup-notification"
BUILDDEP="argcomplete docutils gobject-introspection"
PKGDES="Window manager for GNOME"

ABTYPE=meson
MESON_AFTER=(
    '-Dopengl=true'
    '-Dgles2=true'
    '-Degl=true'
    '-Dxwayland=true'
    '-Dlogind=true'
    '-Dnative_backend=true'
    '-Dremote_desktop=true'
    '-Dlibgnome_desktop=true'
    '-Degl_device=true'
    '-Dwayland_eglstream=true'
    '-Dudev=true'
    '-Dlibwacom=true'
    '-Dsound_player=true'
    '-Dstartup_notification=true'
    '-Dintrospection=true'
    '-Ddocs=false'
    '-Dcogl_tests=false'
    '-Dclutter_tests=false'
    '-Dmutter_tests=false'
    '-Dtests=disabled'
    '-Dkvm_tests=false'
    '-Dtty_tests=false'
    '-Dprofiler=false'
    '-Dinstalled_tests=false'
    '-Dverbose=true'
    '-Dxwayland_initfd=enabled'
    '-Dcatch=false'
    '-Dfonts=true'
    '-Dbash_completion=true'
    '-Ddevkit=disabled'
)
