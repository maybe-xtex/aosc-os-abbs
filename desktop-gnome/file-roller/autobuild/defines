PKGNAME=file-roller
PKGSEC=gnome
PKGDEP="gtk-4 libadwaita libarchive libportal"
BUILDDEP="gobject-introspection itstool nautilus"
PKGDES="Archive manager for GNOME"

MESON_AFTER=(
    '-Dwarn-deprecated=false'
    '-Drun-in-place=false'
    '-Dnautilus-actions=enabled'
    '-Dnotification=enabled'
    '-Duse_native_appchooser=true'
    '-Dpackagekit=false'
    '-Dlibarchive=enabled'
    '-Dintrospection=enabled'
    '-Dapi_docs=disabled'
)
