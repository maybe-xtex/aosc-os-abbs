PKGNAME=rocm-hipfort
PKGDES="Fortran interfaces for ROCm libraries"
PKGSEC=devel
PKGDEP="rocm-llvm rocm-clr rocm-cmake gcc"
BUILDDEP="cmake"

# FIXME: gfortran does not support ld.lld
#
# unrecognized command-line option ‘-fld-lld’
NOLTO=1

# Note: Control Flow Protection is not supported by GPU targets.
#
# https://github.com/llvm/llvm-project/issues/86450
AB_FLAGS_CFP=0

# Note: No ELF files.
ABSPLITDBG=0

USECLANG=1
ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DCMAKE_INSTALL_PREFIX=/usr/lib/rocm'
    '-DCMAKE_C_COMPILER=/usr/lib/rocm/lib/llvm/bin/clang'
    '-DCMAKE_CXX_COMPILER=/usr/lib/rocm/lib/llvm/bin/clang++'
    '-DHIPFORT_AR=/usr/lib/rocm/lib/llvm/bin/llvm-ar'
    '-DHIPFORT_RANLIB=/usr/lib/rocm/lib/llvm/bin/llvm-ranlib'
    '-DCMAKE_SKIP_INSTALL_RPATH=OFF'
    '-DCMAKE_PREFIX_PATH=/usr/lib/rocm'
    '-DLLVM_DIR=/usr/lib/rocm/lib/llvm/lib/cmake/llvm/'
    '-DClang_DIR=/usr/lib/rocm/lib/llvm/lib/cmake/clang/'
)

FAIL_ARCH="!(amd64|arm64|loongarch64)"
