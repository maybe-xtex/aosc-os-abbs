 system/i2c_x86.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/system/i2c_x86.c b/system/i2c_x86.c
index 4ef4a0b..166aa12 100644
--- a/system/i2c_x86.c
+++ b/system/i2c_x86.c
@@ -297,7 +297,7 @@ static bool find_smb_controller(uint16_t vid, uint16_t did)
                 case 0x3177: // 8235
                 case 0x3227: // 8237
                 // case 0x3337: // 8237A
-                // case 0x3372: // 8237S
+                case 0x3372: // 8237S
                 // case 0x3287: // 8251
                 // case 0x8324: // CX700
                 // case 0x8353: // VX800
