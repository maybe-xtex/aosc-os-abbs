# Ref: https://gitlab.archlinux.org/archlinux/packaging/packages/mono-msbuild
abinfo "Building MSBuild ..."
"$SRCDIR"/eng/cibuild_bootstrapped_msbuild.sh \
    --host_type mono \
    --configuration Release \
    --skip_tests /p:DisableNerdbankVersioning=true

abinfo "Installing MSbuild ..."
"$SRCDIR"/stage1/mono-msbuild/msbuild mono/build/install.proj \
    /p:MonoInstallPrefix="$PKGDIR"/usr \
    /p:Configuration=Release-MONO \
    /p:IgnoreDiffFailure=true
sed -e "s@$PKGDIR@@g" \
    -i "$PKGDIR"/usr/bin/msbuild
