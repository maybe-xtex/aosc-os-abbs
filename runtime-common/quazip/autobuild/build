for qtver in 5 6; do
    abinfo "Setting CMake build options (Qt ${qtver}) ..."
    export CMAKE_AFTER=(
        "-DQUAZIP_QT_MAJOR_VERSION=${qtver}"
    )

    abinfo "Configuring QuaZIP (Qt ${qtver}) ..."
    build_cmakeninja_configure

    abinfo "Building QuaZIP (Qt ${qtver}) ..."
    build_cmakeninja_build

    abinfo "Installing QuaZIP (Qt ${qtver}) ..."
    build_cmakeninja_install

    abinfo "Removing build directory for next round of building ..."
    rm -rv "$BLDDIR"
done
