From 0f0d612b2ba82dba5883cc099e410bd5c36ab503 Mon Sep 17 00:00:00 2001
From: xtex <xtexchooser@duck.com>
Date: Sun, 19 Jan 2025 22:27:51 +0800
Subject: [PATCH 1/3] AOSCOS: Fix libtoolize linking

Signed-off-by: xtex <xtexchooser@duck.com>
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 autogen.sh | 1 +
 1 file changed, 1 insertion(+)

diff --git a/autogen.sh b/autogen.sh
index 8bc5cffd5b..2c15e8debd 100755
--- a/autogen.sh
+++ b/autogen.sh
@@ -76,6 +76,7 @@ fi
 
 # Much like APR except we do not prefer libtool 1 over libtool 2.
 libtoolize="`./build/PrintPath glibtoolize libtoolize glibtoolize1 libtoolize15 libtoolize14`"
+libtoolize="$(readlink -f ${libtoolize})"
 lt_major_version=`$libtoolize --version 2>/dev/null | sed -e 's/^[^0-9]*//' -e 's/\..*//' -e '/^$/d' -e 1q`
 
 if [ "x$libtoolize" = "x" ]; then
