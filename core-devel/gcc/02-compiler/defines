PKGNAME=gcc
PKGSEC=devel
PKGDEP="gcc-runtime gcc-15"
PKGDES="GNU Compiler Collection (compilers and development data, metapackage)"

# Note: Architecture specific without ELF.
ABSPILTDBG=0
ABSTRIP=0

# Note: Debian's GCC is currently at 1:.
PKGEPOCH_SPIRAL=1

# Note: certain static libraries are required for development.
NOSTATIC=0

# NOTE: libgccjit is moved to gcc-runtime.
# NOTE: Modula-2 runtimes are moved to gcc-runtime.
PKGBREAK="gcc-runtime<=1:15.2.0 gcc<=15.2.0"
PKGREP="gcc-runtime<=1:15.2.0 gcc<=1:15.2.0"

# Note: Extra Provides for Spiral. Check defines from default GCC version
# for a list of available languages.
PKGPROV__GO=" \
         cpp_spiral g++_spiral gcc_spiral gccgo_spiral gdc_spiral \
         gfortran_spiral gm2_spiral gnat_spiral gobjc_spiral \
         gobjc++_spiral libgphobos-dev_spiral"
PKGPROV__NOGO=" \
         cpp_spiral g++_spiral gcc_spiral gdc_spiral gfortran_spiral \
         gm2_spiral gnat_spiral gobjc_spiral gobjc++_spiral \
         libgphobos-dev_spiral"
PKGPROV__RETRO=" \
         cpp_spiral g++_spiral gcc_spiral gfortran_spiral gobjc_spiral \
         gobjc++_spiral"
PKGPROV__ALPHA="${PKGPROV__RETRO}"
PKGPROV__AMD64="${PKGPROV__GO}"
PKGPROV__ARM64="${PKGPROV__GO}"
PKGPROV__ARMV4="${PKGPROV__RETRO}"
PKGPROV__ARMV6HF="${PKGPROV__RETRO}"
PKGPROV__ARMV7HF="${PKGPROV__RETRO}"
PKGPROV__I486="${PKGPROV__RETRO}"
PKGPROV__LOONGARCH64_NOSIMD="${PKGPROV__NOGO/ gnat_spiral/}"
PKGPROV__LOONGARCH64="${PKGPROV__NOGO/ gnat_spiral/}"
PKGPROV__LOONGSON2F="${PKGPROV__RETRO}"
PKGPROV__LOONGSON3="${PKGPROV__NOGO/ gnat_spiral/}"
PKGPROV__POWERPC="${PKGPROV__RETRO}"
PKGPROV__PPC64EL="${PKGPROV__GO}"
PKGPROV__PPC64="${PKGPROV__RETRO}"
PKGPROV__RISCV64="${PKGPROV__GO}"
PKGPROV__SPARC64="${PKGPROV__RETRO}"
