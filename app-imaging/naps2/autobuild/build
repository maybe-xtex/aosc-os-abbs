abinfo "Preparing PKGDIR..."
mkdir -pv "${PKGDIR}"/usr/bin
mkdir -pv "${PKGDIR}"/usr/lib/naps2

abinfo "Building NAPS2.Gtk.App..."
PROTOBUF_TOOLS_OS=linux \
  PROTOBUF_PROTOC=/usr/bin/protoc \
  GRPC_PROTOC_PLUGIN=/usr/bin/grpc_csharp_plugin \
  dotnet publish "${SRCDIR}"/NAPS2.App.Gtk \
    -v diag -c Release -r $(dotnet --info | grep RID | tr -d ' ' | cut -d \: -f 2) \
    -o "${PKGDIR}"/usr/lib/naps2

abinfo "Copying NAPS2 assets..."
install -Dvm644 "${SRCDIR}"/NAPS2.Lib/Icons/scanner-128.png \
  "${PKGDIR}"/usr/share/icons/hicolor/128x128/apps/com.naps2.Naps2.png
install -Dvm644 "${SRCDIR}"/NAPS2.Setup/config/linux/com.naps2.Naps2.desktop \
  -t "${PKGDIR}"/usr/share/applications/
install -Dvm644 "${SRCDIR}"/NAPS2.Setup/config/linux/com.naps2.Naps2.metainfo.xml \
  -t "${PKGDIR}"/usr/share/metainfo/

abinfo "Creating binary symlink..."
ln -sv ../lib/naps2/naps2 "${PKGDIR}"/usr/bin/naps2

abinfo "Manually processing PDB debug symbol..."
ABSPLITDBG=1
filter_pdb
ABSPLITDBG=0
