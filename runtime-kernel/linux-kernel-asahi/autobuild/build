abinfo "Obtaining rustup ..."
abinfo "Downloading rustup and toolchain ${RUSTC_VERSION}..."
curl https://sh.rustup.rs -sSf | sh -s -- \
    -y \
    --no-modify-path \
    --default-toolchain 1.86.0 \
    --component rust-src
export PATH="$HOME/.cargo/bin:$PATH"

abinfo "Overriding Rust version to fix build ..."
rustup install 1.86.0 --component rust-src
rustup override set 1.86.0

source "/usr/bin/kernel-ab4-enter"
