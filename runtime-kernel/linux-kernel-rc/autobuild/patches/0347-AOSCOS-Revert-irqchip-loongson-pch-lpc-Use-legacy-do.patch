From 7352e7205f80cf139c5bd6c1d7d394acfd9cc53c Mon Sep 17 00:00:00 2001
From: Xi Ruoyao <xry111@xry111.site>
Date: Wed, 12 Nov 2025 16:14:30 +0800
Subject: [PATCH 347/348] AOSCOS: Revert "irqchip/loongson-pch-lpc: Use legacy
 domain for PCH-LPC IRQ controller"

This reverts commit c33c43f71bda362b292a6e57ac41b64342dc87b3.

That commit may be the trigger of the "irq 14: nobody cared" error.

Signed-off-by: Xi Ruoyao <xry111@xry111.site>
---
 drivers/irqchip/irq-loongson-pch-lpc.c | 9 ++-------
 1 file changed, 2 insertions(+), 7 deletions(-)

diff --git a/drivers/irqchip/irq-loongson-pch-lpc.c b/drivers/irqchip/irq-loongson-pch-lpc.c
index 912bf50a5c7c..2d4c3ec128b8 100644
--- a/drivers/irqchip/irq-loongson-pch-lpc.c
+++ b/drivers/irqchip/irq-loongson-pch-lpc.c
@@ -200,13 +200,8 @@ int __init pch_lpc_acpi_init(struct irq_domain *parent,
 		goto iounmap_base;
 	}
 
-	/*
-	 * The LPC interrupt controller is a legacy i8259-compatible device,
-	 * which requires a static 1:1 mapping for IRQs 0-15.
-	 * Use irq_domain_create_legacy to establish this static mapping early.
-	 */
-	priv->lpc_domain = irq_domain_create_legacy(irq_handle, LPC_COUNT, 0, 0,
-						    &pch_lpc_domain_ops, priv);
+	priv->lpc_domain = irq_domain_create_linear(irq_handle, LPC_COUNT,
+					&pch_lpc_domain_ops, priv);
 	if (!priv->lpc_domain) {
 		pr_err("Failed to create IRQ domain\n");
 		goto free_irq_handle;
-- 
2.51.2

