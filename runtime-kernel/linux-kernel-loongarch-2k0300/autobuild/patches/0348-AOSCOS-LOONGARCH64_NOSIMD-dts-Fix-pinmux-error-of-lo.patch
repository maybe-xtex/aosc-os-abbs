From 2c15eb5425fed5165b6045459782f1c04389fdb1 Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Mon, 12 May 2025 00:05:32 +0800
Subject: [PATCH 348/376] AOSCOS: LOONGARCH64_NOSIMD: dts: Fix pinmux error of
 loongson_2k300_alientek

Signed-off-by: Ilikara <3435193369@qq.com>
---
 arch/loongarch/boot/dts/loongson-2k0300.dtsi  | 66 +++++++++++--------
 arch/loongarch/boot/dts/ls2k300_alientek.dts  |  7 +-
 .../dts/ls2k300_gongkong_g2k03z2_core.dtsi    |  4 +-
 3 files changed, 47 insertions(+), 30 deletions(-)

diff --git a/arch/loongarch/boot/dts/loongson-2k0300.dtsi b/arch/loongarch/boot/dts/loongson-2k0300.dtsi
index fd7e3db36999..df2f7d2b2dba 100644
--- a/arch/loongarch/boot/dts/loongson-2k0300.dtsi
+++ b/arch/loongarch/boot/dts/loongson-2k0300.dtsi
@@ -182,32 +182,44 @@ gmac1_pins: pinmux_G44_G55_as_gmac1 {
 			pinctrl-single,bits = <0x8 0x55000000 0xff000000
 						0xc 0x00005555 0x0000ffff>;
 		};
-		i2c0_pins: pinmux_G48_G49_as_i2c0 {
-			pinctrl-single,bits = <0xc 0x0000000f 0x0000000f>;
-		};
-
-		i2c1_pins: pinmux_G50_G51_as_i2c1 {
-			pinctrl-single,bits = <0xc 0x000000f0 0x000000f0>;
-		};
-
-		i2c1_as_gpio: pinmux_G50_G51_as_gpio {
-			pinctrl-single,bits = <0xc 0x00000000 0x000000f0>;
-		};
-
-		i2c2_pins: pinmux_G52_G53_as_i2c2 {
-			pinctrl-single,bits = <0xc 0x00000f00 0x00000f00>;
+		
+		i2c0_pins: i2c0-pins {
+			i2c0_mux_m0: pinmux_G48_G49_as_i2c0 {
+				pinctrl-single,bits = <0xc 0x0000000f 0x0000000f>;
+			};
+			i2c0_mux_m1: pinmux_G60_G61_as_i2c0 {
+				pinctrl-single,bits = <0xc 0x05000000 0x0f000000>;
+			};
 		};
-
-		i2c2_G82_G83_pins: pinmux_G82_G83_as_i2c2 {
-			pinctrl-single,bits = <0x14 0x000000a0 0x000000f0>;
+		
+		i2c1_pins: i2c1-pins {
+			i2c1_mux_m0: pinmux_G50_G51_as_i2c1 {
+				pinctrl-single,bits = <0xc 0x000000f0 0x000000f0>;
+			};
+			i2c1_mux_m0_as_gpio: pinmux_G50_G51_as_gpio {
+				pinctrl-single,bits = <0xc 0x00000000 0x000000f0>;
+			};
+			i2c1_mux_m1: pinmux_G62_G63_as_i2c0 {
+				pinctrl-single,bits = <0xc 0x50000000 0xf0000000>;
+			};
 		};
 
-		i2c3_pins: pinmux_G54_G55_as_i2c3 {
-			pinctrl-single,bits = <0xc 0x0000f000 0x0000f000>;
+		i2c2_pins: i2c2-pins {
+			i2c2_mux_m0: pinmux_G52_G53_as_i2c2 {
+				pinctrl-single,bits = <0xc 0x00000f00 0x00000f00>;
+			};
+			i2c2_mux_m1: pinmux_G82_G83_as_i2c2 {
+				pinctrl-single,bits = <0x14 0x000000a0 0x000000f0>;
+			};
 		};
 
-		i2c3_G84_G85_pins: pinmux_G84_G85_as_i2c3 {
-			pinctrl-single,bits = <0x14 0x00000a00 0x000000f00>;
+		i2c3_pins: i2c3-pins {
+			i2c3_mux_m0: pinmux_G54_G55_as_i2c3 {
+				pinctrl-single,bits = <0xc 0x0000f000 0x0000f000>;
+			};
+			i2c3_mux_m1: pinmux_G84_G85_as_i2c3 {
+				pinctrl-single,bits = <0x14 0x00000a00 0x000000f00>;
+			};
 		};
 
 		spi0_pins: pinmux_G56_G59_as_spi0 {
@@ -224,7 +236,7 @@ spi0_cs1: pinmux_G68_as_spi0_cs {
 		};
 
 		spi1_pins: pinmux_G60_G63_as_spi1 {
-				pinctrl-single,bits = <0xc 0xff000000 0xff000000>;
+			pinctrl-single,bits = <0xc 0xff000000 0xff000000>;
 		};
 
 		spi1_cs_as_gpio: pinmux_G60_G62_as_spi1 {
@@ -398,7 +410,7 @@ pwm1_mux_m2: pinmux_G103_as_pwm1 {
 				pinctrl-single,bits = <0x18 0x0000c000 0x0000c000>;
 			};
 		};
-		
+
 		pwm2_pins: pwm2-pins {
 			pwm2_mux_m0: pinmux_G66_as_pwm2 {
 				pinctrl-single,bits = <0x10 0x00000010 0x00000030>;
@@ -838,7 +850,7 @@ i2c0: i2c0@0x16108000 {
 			#size-cells = <0>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <4 IRQ_TYPE_LEVEL_HIGH>;
-			pinctrl-0 = <&i2c0_pins>;
+			pinctrl-0 = <&i2c0_mux_m0>;
 			pinctrl-names = "default";
 			clock-frequency = <200000000>;
 			status = "disabled";
@@ -851,7 +863,7 @@ i2c1: i2c1@0x16109000 {
 			#size-cells = <0>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <4 IRQ_TYPE_LEVEL_HIGH>;
-			pinctrl-0 = <&i2c1_pins>;
+			pinctrl-0 = <&i2c1_mux_m0>;
 			pinctrl-names = "default";
 			clock-frequency = <200000000>;
 			status = "disabled";
@@ -864,7 +876,7 @@ i2c2: i2c2@0x1610a000 {
 			#size-cells = <0>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <5 IRQ_TYPE_LEVEL_HIGH>;
-			pinctrl-0 = <&i2c2_pins>;
+			pinctrl-0 = <&i2c2_mux_m0>;
 			pinctrl-names = "default";
 			clock-frequency = <200000000>;
 			status = "disabled";
@@ -877,7 +889,7 @@ i2c3: i2c3@0x1610b000 {
 			#size-cells = <0>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <5 IRQ_TYPE_LEVEL_HIGH>;
-			pinctrl-0 = <&i2c3_pins>;
+			pinctrl-0 = <&i2c3_mux_m0>;
 			pinctrl-names = "default";
 			clock-frequency = <200000000>;
 			status = "disabled";
diff --git a/arch/loongarch/boot/dts/ls2k300_alientek.dts b/arch/loongarch/boot/dts/ls2k300_alientek.dts
index 470896166f9a..89f2055930ae 100644
--- a/arch/loongarch/boot/dts/ls2k300_alientek.dts
+++ b/arch/loongarch/boot/dts/ls2k300_alientek.dts
@@ -169,6 +169,8 @@ yt8511h1: ethernet-phy@1 {
 
 &i2c2 {
 	status = "ok";
+	pinctrl-0 = <&i2c2_mux_m1>;
+	pinctrl-names = "default";
 
 	touchpad: gt911@14 {
         compatible = "goodix,gt911";
@@ -184,6 +186,8 @@ touchpad: gt911@14 {
 
 &i2c3 {
 	status = "ok";
+	pinctrl-0 = <&i2c3_mux_m1>;
+	pinctrl-names = "default";
     //8388音频芯片
 	codec: es8388@11{
 		compatible = "everest,es8388";
@@ -217,7 +221,6 @@ &can0 {
     //status = "disabled";
 };
 
-
 &adc {
 	status = "okay";
 };
@@ -242,6 +245,8 @@ &i2s {
 
 &audio {
 	status = "okay";
+	dmas = <&dma 6 0xaf
+			&dma 7 0xbf>;
 };
 
 &sound {
diff --git a/arch/loongarch/boot/dts/ls2k300_gongkong_g2k03z2_core.dtsi b/arch/loongarch/boot/dts/ls2k300_gongkong_g2k03z2_core.dtsi
index df1873de0245..21351a72a2a0 100644
--- a/arch/loongarch/boot/dts/ls2k300_gongkong_g2k03z2_core.dtsi
+++ b/arch/loongarch/boot/dts/ls2k300_gongkong_g2k03z2_core.dtsi
@@ -44,10 +44,10 @@ spi-flash@0 {
 
 &i2c2 {
 	status = "okay";
-	pinctrl-0 = <&i2c2_G82_G83_pins>;
+	pinctrl-0 = <&i2c2_mux_m1>;
 };
 
 &i2c3 {
 	status = "okay";
-	pinctrl-0 = <&i2c3_G84_G85_pins>;
+	pinctrl-0 = <&i2c3_mux_m1>;
 };
-- 
2.50.0

