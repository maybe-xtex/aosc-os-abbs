From dff2fbf8f5f713f67ab0e7d65c5b7a6a28978976 Mon Sep 17 00:00:00 2001
From: maoxiaochuan <maoxiaochuan@loongson.cn>
Date: Fri, 11 Apr 2025 17:09:05 +0800
Subject: [PATCH 333/376] FROMEXT: LOONGARCH64_NOSIMD: update to e7567cc18

1.Fix the issue of the SD card crashing due to repeated plugging and unplugging.
2.add init-polarity to support setup init pwm status
3.loongson2_thermal: update temperature formula
4.Fix alert/critical temperature to 75/105
5.Add alientek-2k300 support

Signed-off-by: maoxiaochuan <maoxiaochuan@loongson.cn>

Link: https://gitee.com/open-loongarch/linux-6.12/commit/881dbd52e06b7b9ca3f19dccb07cec409a086e24
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 arch/loongarch/boot/dts/Makefile              |   3 +-
 arch/loongarch/boot/dts/loongson-2k0300.dtsi  |   4 +-
 arch/loongarch/boot/dts/ls2k300_alientek.dts  | 267 ++++++++++++++++++
 .../configs/loongson_2k300_defconfig          |   1 +
 .../configs/loongson_2k300_rt_defconfig       |   1 +
 arch/loongarch/include/asm/mach/boot_param.h  |   1 +
 arch/loongarch/kernel/setup.c                 |   2 +
 drivers/pwm/pwm-loongson.c                    |   9 +
 drivers/thermal/loongson2_thermal.c           |  36 ++-
 9 files changed, 317 insertions(+), 7 deletions(-)
 create mode 100644 arch/loongarch/boot/dts/ls2k300_alientek.dts

diff --git a/arch/loongarch/boot/dts/Makefile b/arch/loongarch/boot/dts/Makefile
index 9483324b0510..09e1b775bdde 100644
--- a/arch/loongarch/boot/dts/Makefile
+++ b/arch/loongarch/boot/dts/Makefile
@@ -3,7 +3,8 @@
 # dtb-y = loongson-2k0500-ref.dtb loongson-2k1000-ref.dtb loongson-2k2000-ref.dtb
 
 ifdef CONFIG_DTB_MATCH_BY_BOARD_NAME
-dtb-$(CONFIG_LOONGSON_2K300) += ls2k300_mini_dp.dtb ls2k300_vanguard_pi.dtb ls2k300_gongkong_gbkpgk0.dtb
+dtb-$(CONFIG_LOONGSON_2K300) += ls2k300_mini_dp.dtb ls2k300_vanguard_pi.dtb ls2k300_gongkong_gbkpgk0.dtb \
+				ls2k300_alientek.dtb
 dtb-$(CONFIG_LOONGSON_2K1000) += ls2k1000_dp.dtb
 
