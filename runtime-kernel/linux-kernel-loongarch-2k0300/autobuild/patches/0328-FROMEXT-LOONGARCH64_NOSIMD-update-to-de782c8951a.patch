From c4ad39aee4b3b62869a5bcfe1aed5673f042f7ed Mon Sep 17 00:00:00 2001
From: maoxiaochuan <maoxiaochuan@loongson.cn>
Date: Thu, 6 Mar 2025 11:01:10 +0800
Subject: [PATCH 328/376] FROMEXT: LOONGARCH64_NOSIMD: update to de782c8951a

ls2k300_mini_dp:enhance otg compatibility

Signed-off-by: maoxiaochuan <maoxiaochuan@loongson.cn>

Link: https://gitee.com/open-loongarch/linux-6.12/commit/f544a6456158b48128fd634271bcab6b07f2ed6c
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 arch/loongarch/boot/dts/loongson2k300.dtsi              | 5 +++++
 arch/loongarch/boot/dts/ls2k300_gongkong_gbkpgk0.dts    | 5 -----
 arch/loongarch/boot/dts/ls2k300_mini_dp.dts             | 9 ++++-----
 arch/loongarch/boot/dts/ls2k300_vanguard_pi_common.dtsi | 5 -----
 arch/loongarch/configs/loongson_2k300_defconfig         | 1 +
 5 files changed, 10 insertions(+), 15 deletions(-)

diff --git a/arch/loongarch/boot/dts/loongson2k300.dtsi b/arch/loongarch/boot/dts/loongson2k300.dtsi
index b9994c170240..bdf731fa7236 100644
--- a/arch/loongarch/boot/dts/loongson2k300.dtsi
+++ b/arch/loongarch/boot/dts/loongson2k300.dtsi
@@ -859,6 +859,11 @@ sdio1: sdio@0x16148000 {
 			interrupt-names = "ls2k_mci_irq";
 			dma-mask = <0xffffffff 0xffffffff>;
 			clock-frequency = <0 200000000>;
+			pinctrl-0 = <&sdio1_pins>;
+			pinctrl-names = "default";
+			cap-sd-highspeed;
+			cap-mmc-highspeed;
+			bus-width = <4>;
 			status = "disabled";
 		};
 
diff --git a/arch/loongarch/boot/dts/ls2k300_gongkong_gbkpgk0.dts b/arch/loongarch/boot/dts/ls2k300_gongkong_gbkpgk0.dts
index 13ebe1585291..7d5d8d455386 100644
--- a/arch/loongarch/boot/dts/ls2k300_gongkong_gbkpgk0.dts
+++ b/arch/loongarch/boot/dts/ls2k300_gongkong_gbkpgk0.dts
@@ -319,11 +319,6 @@ &adc {
 };
 
 &sdio1 {
-	pinctrl-0 = <&sdio1_pins>;
-	pinctrl-names = "default";
-	cap-sd-highspeed;
-	cap-mmc-highspeed;
-	bus-width = <4>;
 	//cd-gpios = <&io_expander_a 4 GPIO_ACTIVE_LOW>;
 	status = "okay";
 };
diff --git a/arch/loongarch/boot/dts/ls2k300_mini_dp.dts b/arch/loongarch/boot/dts/ls2k300_mini_dp.dts
index 41894b1d767e..f37e8a5df850 100644
--- a/arch/loongarch/boot/dts/ls2k300_mini_dp.dts
+++ b/arch/loongarch/boot/dts/ls2k300_mini_dp.dts
@@ -216,11 +216,10 @@ &rtc0 {
 };
 
 &sdio1 {
-	pinctrl-0 = <&sdio1_pins>;
-	pinctrl-names = "default";
-	cap-sd-highspeed;
-	cap-mmc-highspeed;
-	bus-width = <4>;
 	cd-gpios = <&gpio 81 GPIO_ACTIVE_LOW>;
 	status = "okay";
 };
+
+&otg {
+	loongson,dwc2-fix = <DWC2_LOONGSON_FIX_DMA>;
+};
diff --git a/arch/loongarch/boot/dts/ls2k300_vanguard_pi_common.dtsi b/arch/loongarch/boot/dts/ls2k300_vanguard_pi_common.dtsi
index dbf0906f79f1..6ceeafaf470c 100644
--- a/arch/loongarch/boot/dts/ls2k300_vanguard_pi_common.dtsi
+++ b/arch/loongarch/boot/dts/ls2k300_vanguard_pi_common.dtsi
@@ -218,11 +218,6 @@ &rtc0 {
 };
 
 &sdio1 {
-	pinctrl-0 = <&sdio1_pins>;
-	pinctrl-names = "default";
-	cap-sd-highspeed;
-	cap-mmc-highspeed;
-	bus-width = <4>;
 	cd-gpios = <&gpio 82 GPIO_ACTIVE_LOW>;
 	status = "okay";
 };
diff --git a/arch/loongarch/configs/loongson_2k300_defconfig b/arch/loongarch/configs/loongson_2k300_defconfig
index ac0738bad8de..01c18b68f390 100644
--- a/arch/loongarch/configs/loongson_2k300_defconfig
+++ b/arch/loongarch/configs/loongson_2k300_defconfig
@@ -1,3 +1,4 @@
+CONFIG_LOCALVERSION=".lsgd"
 # CONFIG_LOCALVERSION_AUTO is not set
 CONFIG_SYSVIPC=y
 CONFIG_POSIX_MQUEUE=y
-- 
