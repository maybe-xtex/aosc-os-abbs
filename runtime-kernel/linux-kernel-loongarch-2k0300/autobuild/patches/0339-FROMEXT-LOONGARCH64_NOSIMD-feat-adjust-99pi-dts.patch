From eb7b6e670abbcc81177758876a20856462ad3112 Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Wed, 30 Apr 2025 23:29:30 +0800
Subject: [PATCH 339/376] FROMEXT: LOONGARCH64_NOSIMD: feat: adjust 99pi dts

Signed-off-by: Ilikara <3435193369@qq.com>

Link: https://gitee.com/open-loongarch/linux-6.12/commit/f4a44bbe6f2986528fe7c7dc7c02ee93ffc00907
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts | 29 +++++++++----------
 1 file changed, 13 insertions(+), 16 deletions(-)

diff --git a/arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts b/arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts
index 41fae3281ca2..e9676dc1b18f 100644
--- a/arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts
+++ b/arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts
@@ -1,7 +1,9 @@
-#include <dt-bindings/gpio/gpio.h>
-#include <dt-bindings/pwm/pwm.h>
-#include <dt-bindings/input/linux-event-codes.h>
-#include <dt-bindings/interrupt-controller/irq.h>
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Copyright (C) 2025 Loongson Technology Corporation Limited
+ */
+
+/dts-v1/;
 
 #include "loongson-2k0300.dtsi"
 #include "loongson_panel_param.dtsi"
@@ -104,7 +106,7 @@ spidev0@0 {
 };
 
 &spi2 {
-	status = "disabled"; // 与 PWM0-3 的 MUX0 冲突
+	status = "okay"; // 与 PWM0-3 的 MUX0 冲突
 
 	spidev1@0 {
 		compatible = "rohm,dh2228fv";
@@ -114,10 +116,10 @@ spidev1@0 {
 };
 
 &timers1 {
-	status = "disabled";
+	status = "okay";
 	/delete-property/ dmas;
 	/delete-property/ dma-names;
-	pinctrl-0 = <&atim3_pin_m1>, <&atim3n_pin_m1>;  // 在 LCD 排线处和 S_LED
+	pinctrl-0 = <&atim3n_pin_m1>; // LCD PWM 背光，备用
 	pinctrl-names = "default";
 
 	pwm {
@@ -142,25 +144,25 @@ pwm {
 };
 
 &pwm0 {
-	status = "okay";
+	status = "disabled";
 	pinctrl-0 = <&pwm0_mux_m0>;
 	pinctrl-names = "default";
 };
 
 &pwm1 {
-	status = "okay";
+	status = "disabled";
 	pinctrl-0 = <&pwm1_mux_m0>;
 	pinctrl-names = "default";
 };
 
 &pwm2 {
-	status = "okay";
+	status = "disabled";
 	pinctrl-0 = <&pwm2_mux_m0>;
 	pinctrl-names = "default";
 };
 
 &pwm3 {
-	status = "okay";
+	status = "disabled";
 	pinctrl-0 = <&pwm3_mux_m0>;
 	pinctrl-names = "default";
 };
@@ -182,11 +184,6 @@ &rtc0 {
 };
 
 &sdio1 {
-	pinctrl-0 = <&sdio1_pins>;
-	pinctrl-names = "default";
-	cap-sd-highspeed;
-	cap-mmc-highspeed;
-	bus-width = <4>;
 	cd-gpios = <&gpio 82 GPIO_ACTIVE_LOW>;
 	status = "okay";
 };
-- 
2.50.0

