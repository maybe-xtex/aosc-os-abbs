+	pinmux: pinmux@16000490 {
+		compatible = "pinctrl-single";
+		reg = <0 0x16000490 0 0x20>;
+		#address-cells = <1>;
+		#size-cells = <0>;
+		#pinctrl-cells = <2>;
+		pinctrl-single,bit-per-mux;
+		pinctrl-single,register-width = <32>;
