+	pinctrl-names = "default";
+	cap-sd-highspeed;
+	cap-mmc-highspeed;
+	bus-width = <4>;
+	cd-gpios = <&gpio 81 GPIO_ACTIVE_LOW>;
+	status = "okay";
+};
