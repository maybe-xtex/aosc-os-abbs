diff --git a/drivers/mmc/host/ls2kmci.c b/drivers/mmc/host/ls2kmci.c
new file mode 100644
index 000000000000..fc4dd5e16704
--- /dev/null
+++ b/drivers/mmc/host/ls2kmci.c
@@ -0,0 +1,1177 @@
+/*
+ *  linux/drivers/mmc/ls2k_mci.h - Loongson ls2k MCI driver
+ *
