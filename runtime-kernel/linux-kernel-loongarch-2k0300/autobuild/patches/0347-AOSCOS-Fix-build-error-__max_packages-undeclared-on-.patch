From d66453a36fdcdfd4a1b09929f7d1f1dfea0142e3 Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Sun, 11 May 2025 19:39:41 +0800
Subject: [PATCH 347/376] AOSCOS: Fix build error '__max_packages' undeclared
 on non-SMP platforms

The commit "BACKPORT: DEEPIN: LoongArch: Adjust the calculation of the
number of packages", introduced a build failure on non-SMP configurations
due to the unconditional use of '__max_packages', which is only defined
when CONFIG_SMP is enabled.

  arch/loongarch/kernel/setup.c: In function 'parse_cpu_table':
  arch/loongarch/kernel/setup.c:150:9: error: '__max_packages' undeclared (first use in this function)
    150 |         __max_packages++;
        |         ^~~~~~~~~~~~~~
  arch/loongarch/kernel/setup.c:150:9: note: each undeclared identifier is reported only once for each function it appears in

Fix this by guarding the '__max_packages' increment with CONFIG_SMP,
as the variable is only relevant for SMP systems.

Link: https://github.com/AOSC-Tracking/linux/commit/e48a6614dda6958e08efa37c35364ed2429c60d6

Signed-off-by: Ilikara <3435193369@qq.com>
---
 arch/loongarch/kernel/setup.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/arch/loongarch/kernel/setup.c b/arch/loongarch/kernel/setup.c
index 1a8e3fcf1cda..120e56f46ae4 100644
--- a/arch/loongarch/kernel/setup.c
+++ b/arch/loongarch/kernel/setup.c
@@ -147,7 +147,10 @@ static void __init parse_cpu_table(const struct dmi_header *dm)
 
 	loongson_sysconf.cpuname = (void *)dmi_string_parse(dm, dmi_data[16]);
 	loongson_sysconf.cores_per_package = *(dmi_data + SMBIOS_THREAD_PACKAGE_OFFSET);
+
+#ifdef CONFIG_SMP
 	__max_packages++;
+#endif
 
 	pr_info("CpuClock = %llu\n", cpu_clock_freq);
 }
