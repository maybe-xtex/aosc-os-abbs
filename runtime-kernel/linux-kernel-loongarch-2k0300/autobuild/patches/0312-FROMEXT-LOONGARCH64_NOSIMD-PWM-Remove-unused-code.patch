From 5e1142cdfac80626c1aefe0b12badb4852b3b6ba Mon Sep 17 00:00:00 2001
From: maoxiaochuan <maoxiaochuan@loongson.cn>
Date: Sun, 16 Feb 2025 17:03:01 +0800
Subject: [PATCH 312/376] FROMEXT: LOONGARCH64_NOSIMD: PWM:Remove unused code

Signed-off-by: maoxiaochuan <maoxiaochuan@loongson.cn>

Link: https://gitee.com/open-loongarch/linux-6.12/commit/d405f3e1c15854a2cd6875833203213bcdfd725b
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 drivers/pwm/Kconfig  | 9 ---------
 drivers/pwm/Makefile | 1 -
 2 files changed, 10 deletions(-)

diff --git a/drivers/pwm/Kconfig b/drivers/pwm/Kconfig
index 0238ab9b8796..ef02a44d83a7 100644
--- a/drivers/pwm/Kconfig
+++ b/drivers/pwm/Kconfig
@@ -757,13 +757,4 @@ config PWM_XILINX
 	  To compile this driver as a module, choose M here: the module
 	  will be called pwm-xilinx.
 
-config PWM_LS
-	tristate "Loongson PWM support"
-	depends on LOONGSON_2K500 || LOONGSON_2K1000 || LOONGSON_2K300 || LOONGSON_2P500
-	help
-	  Generic PWM framework driver for loongson3.
-
-	  To compile this driver as a module, choose M here: the module
-	  will be called pwm-ls.
-
 endif
diff --git a/drivers/pwm/Makefile b/drivers/pwm/Makefile
index feb1ab5930d1..7c18c9be419f 100644
--- a/drivers/pwm/Makefile
+++ b/drivers/pwm/Makefile
@@ -70,4 +70,3 @@ obj-$(CONFIG_PWM_TWL_LED)	+= pwm-twl-led.o
 obj-$(CONFIG_PWM_VISCONTI)	+= pwm-visconti.o
 obj-$(CONFIG_PWM_VT8500)	+= pwm-vt8500.o
 obj-$(CONFIG_PWM_XILINX)	+= pwm-xilinx.o
-obj-$(CONFIG_PWM_LS)		+= pwm-ls.o
-- 
