From e019e1b3ef306a65794e639cd7db1e6c94a1d658 Mon Sep 17 00:00:00 2001
From: jmjoy <jmjoy@apache.org>
Date: Fri, 25 Apr 2025 23:56:47 +0800
Subject: [PATCH 334/376] FROMEXT: LOONGARCH64_NOSIMD: Fix typo in
 LD_LIBRARY_PATH export for LoongArch environment setup

Signed-off-by: jmjoy <jmjoy@apache.org>

Link: https://gitee.com/open-loongarch/linux-6.12/commit/23c13cf7b46d5f236c2b59e5975d4a8927b4517b
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 set_env.sh | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/set_env.sh b/set_env.sh
index 6c520df070f3..acd5eeabe140 100644
--- a/set_env.sh
+++ b/set_env.sh
@@ -27,7 +27,7 @@ function setup_loongarch_env()
 	CC_PREFIX=/opt/loongarch64-linux-gnu-gcc13.3
 
 	export PATH=$PATH:$CC_PREFIX/bin
-	export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:CC_PREFIX/lib
+	export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$CC_PREFIX/lib
 	export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$CC_PREFIX/loongarch64-linux-gnu/lib64
 
 	export ARCH=loongarch
-- 
