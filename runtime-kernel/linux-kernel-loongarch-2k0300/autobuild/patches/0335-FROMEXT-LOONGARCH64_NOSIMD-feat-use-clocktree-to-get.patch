From 0b7f73c70d63ae28162f84a5b9e9a4f511c7b025 Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Tue, 29 Apr 2025 10:59:56 +0800
Subject: [PATCH 335/376] FROMEXT: LOONGARCH64_NOSIMD: feat: use clocktree to
 get uart clock

Signed-off-by: Ilikara <3435193369@qq.com>

Link: https://gitee.com/open-loongarch/linux-6.12/commit/2d8b839dd3256f075c6936d5ae5b60416aafd469
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 arch/loongarch/boot/dts/loongson-2k0300.dtsi | 22 +++++++++-----------
 1 file changed, 10 insertions(+), 12 deletions(-)

diff --git a/arch/loongarch/boot/dts/loongson-2k0300.dtsi b/arch/loongarch/boot/dts/loongson-2k0300.dtsi
index dabbc9255a93..9061a2ad3149 100644
--- a/arch/loongarch/boot/dts/loongson-2k0300.dtsi
+++ b/arch/loongarch/boot/dts/loongson-2k0300.dtsi
@@ -432,7 +432,7 @@ isa@16400000 {
 		uart0: serial@0x16100000 {
 			compatible = "ns16550a";
 			reg = <0 0x16100000 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <0 IRQ_TYPE_LEVEL_HIGH>;
 			no-loopback-test;
@@ -441,7 +441,7 @@ uart0: serial@0x16100000 {
 		uart1: serial@0x16100400 {
 			compatible = "ns16550a";
 			reg = <0 0x16100400 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <1 IRQ_TYPE_LEVEL_HIGH>;
 			no-loopback-test;
@@ -453,7 +453,7 @@ uart1: serial@0x16100400 {
 		uart2: serial@0x16100800 {
 			compatible = "ns16550a";
 			reg = <0 0x16100800 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <2 IRQ_TYPE_LEVEL_HIGH>;
 			no-loopback-test;
@@ -465,7 +465,7 @@ uart2: serial@0x16100800 {
 		uart3: serial@0x16100c00 {
 			compatible = "ns16550a";
 			reg = <0 0x16100c00 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <2 IRQ_TYPE_LEVEL_HIGH>;
 			no-loopback-test;
@@ -477,7 +477,7 @@ uart3: serial@0x16100c00 {
 		uart4: serial@0x16101000 {
 			compatible = "ns16550a";
 			reg = <0 0x16101000 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <2 IRQ_TYPE_LEVEL_HIGH>;
 			pinctrl-0 = <&uart4_pins>;
@@ -489,7 +489,7 @@ uart4: serial@0x16101000 {
 		uart5: serial@0x16101400 {
 			compatible = "ns16550a";
 			reg = <0 0x16101400 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <2 IRQ_TYPE_LEVEL_HIGH>;
 			no-loopback-test;
@@ -501,7 +501,7 @@ uart5: serial@0x16101400 {
 		uart6: serial@0x16101800 {
 			compatible = "ns16550a";
 			reg = <0 0x16101800 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <3 IRQ_TYPE_LEVEL_HIGH>;
 			no-loopback-test;
@@ -513,7 +513,7 @@ uart6: serial@0x16101800 {
 		uart7: serial@0x16101c00 {
 			compatible = "ns16550a";
 			reg = <0 0x16101c00 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <3 IRQ_TYPE_LEVEL_HIGH>;
 			no-loopback-test;
@@ -525,7 +525,7 @@ uart7: serial@0x16101c00 {
 		uart8: serial@0x16102000 {
 			compatible = "ns16550a";
 			reg = <0 0x16102000 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <3 IRQ_TYPE_LEVEL_HIGH>;
 			no-loopback-test;
@@ -537,7 +537,7 @@ uart8: serial@0x16102000 {
 		uart9: serial@0x16102400 {
 			compatible = "ns16550a";
 			reg = <0 0x16102400 0 0x10>;
-			clock-frequency = <200000000>;
+			clocks = <&clocks CLK_APB>;
 			interrupt-parent = <&liointc0>;
 			interrupts = <3 IRQ_TYPE_LEVEL_HIGH>;
 			no-loopback-test;
@@ -969,7 +969,6 @@ timers1: timer@16118000 {
 			dma-names = "ch1", "ch2", "ch3", "ch4", "com", "up", "trig";
 			pinctrl-0 = <&atim3_pin_m1>, <&atim3n_pin_m1>;
 			pinctrl-names = "default";
-			clock-frequency = <200000000>;
 			status = "disabled";
 
 			pwm {
@@ -997,7 +996,6 @@ timers2: timer@16119000 {
 			dma-names = "ch1", "ch2", "ch3", "ch4", "up", "trig";
 			pinctrl-0 = <&gtim2_pin_m1>, <&gtim3_pin_m1>;
 			pinctrl-names = "default";
-			clock-frequency = <200000000>;
 			status = "disabled";
 
 			pwm {
-- 
2.50.0

