+&spi0 {
+	status = "okay";
+
+	#address-cells = <1>;
+    	#size-cells = <0>;
+	spi-flash@0 {
+		compatible = "jedec,spi-nor";
+		spi-max-frequency = <30000000>;
+		reg = <0>; /* CS0 */
+
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 {
+				label = "u-boot";
+				reg = <0x0000000 0x100000>;
+				read-only;
+			};
+		};
+	};
