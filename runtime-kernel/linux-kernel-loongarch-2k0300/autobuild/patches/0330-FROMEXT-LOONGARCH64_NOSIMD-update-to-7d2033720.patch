+
+	// 7寸触屏芯片
+	touchpad: gt911@5d {
+		compatible = "goodix,gt911";
+		reg = <0x5d>;
+		interrupt-parent = <&liointc1>;
+		interrupts = <29 IRQ_TYPE_LEVEL_HIGH>;
+		irq-gpios = <&gpio0 0 GPIO_ACTIVE_LOW>;
+	};
+
+	// 4.3寸触屏芯片
+	touchpad_1: gt9147@14 {
+		compatible = "goodix,gt9147";
+		reg = <0x14>;
+		// 2K300 GPIO 支持中断控制
+		// GPIO 中断号为 vhwirq-base + pinnum (210 = 128 + 82)
+		interrupt-parent = <&liointc1>;
+		interrupts = <29 IRQ_TYPE_LEVEL_HIGH>;
+		irq-gpios = <&gpio0 0 GPIO_ACTIVE_LOW>;
+	};
+};
