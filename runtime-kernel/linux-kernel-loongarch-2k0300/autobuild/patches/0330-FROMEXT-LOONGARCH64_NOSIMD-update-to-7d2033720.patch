+			default-state = "off";
+		};
+	};
+
+	gpio-fan {
+		compatible = "gpio-fan";
+		gpios = <&gpio0 57 GPIO_ACTIVE_HIGH>;
+		gpio-fan,speed-map = <0    0>,
+					<3000 1>,
+					<6000 2>;
+		#cooling-cells = <2>; /* min followed by max */
+	};
+
+	gpio_keys {
+		compatible = "gpio-keys-polled";
+		#address-cells = <1>;
+		#size-cells = <0>;
+		poll-interval = <20>;
+
+		enter {
+			label = "enter";
