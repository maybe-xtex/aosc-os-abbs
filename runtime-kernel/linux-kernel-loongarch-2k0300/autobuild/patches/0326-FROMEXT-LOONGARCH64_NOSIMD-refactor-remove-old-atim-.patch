-		};
-
 		pwm0: pwm@0x1611b000 {
 			compatible = "loongson,ls2k-pwm";
 			reg = <0 0x1611b000 0 0xf>;
@@ -1008,6 +945,63 @@ rtc0: rtc@0x16128000{
 			status = "disabled";
 		};
 
+		timers1: timer@16118000 {
+			#address-cells = <1>;
+			#size-cells = <0>;
