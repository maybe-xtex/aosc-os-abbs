diff --git a/arch/loongarch/boot/dts/ls2k300_vanguard_pi_common.dtsi b/arch/loongarch/boot/dts/ls2k300_vanguard_pi_common.dtsi
index 229974c47c05..dbf0906f79f1 100644
--- a/arch/loongarch/boot/dts/ls2k300_vanguard_pi_common.dtsi
+++ b/arch/loongarch/boot/dts/ls2k300_vanguard_pi_common.dtsi
@@ -1,8 +1,3 @@
