 1ace04931c77df9

1. Add 2k300_gongkong board support

Signed-off-by: maoxiaochuan <maoxiaochuan@loongson.cn>

Link: https://gitee.com/open-loongarch/linux-6.12/commit/1c67e978cfbf9faee63bdffe02851cdf759a7698
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 arch/loongarch/boot/dts/Makefile              |   3 +-
 arch/loongarch/boot/dts/loongson2k300.dtsi    |  20 +-
 .../boot/dts/ls2k300_g2k03z0_core_v10.dtsi    |  11 +-
 .../dts/ls2k300_gongkong_g2k03z2_core.dtsi    |  53 +++
 .../boot/dts/ls2k300_gongkong_gbkpgk0.dts     | 345 ++++++++++++++++++
 arch/loongarch/boot/dts/ls2k300_mini_dp.dts   |   4 +-
 .../boot/dts/ls2k300_vanguard_pi.dts          |   7 +-
 .../boot/dts/ls2k300_vanguard_pi_common.dtsi  |   5 -
 .../boot/dts/ls2k300_vanguard_pi_func2.dts    |   7 +-
 .../boot/dts/ls2k300_vanguard_pi_pihat.dts    |   7 +-
 .../configs/loongson_2k300_defconfig          |   3 +
 arch/loongarch/include/asm/mach/boot_param.h  |   1 +
 arch/loongarch/kernel/setup.c                 |   2 +
 drivers/mmc/host/ls2kmci.c                    |   7 +
 14 files changed, 437 insertions(+), 38 deletions(-)
 create mode 100644 arch/loongarch/boot/dts/ls2k300_gongkong_g2k03z2_core.dtsi
 create mode 100644 arch/loongarch/boot/dts/ls2k300_gongkong_gbkpgk0.dts

diff --git a/arch/loongarch/boot/dts/Makefile b/arch/loongarch/boot/dts/Makefile
index 4a07360a17d6..d1363aa054a4 100644
--- a/arch/loongarch/boot/dts/Makefile
+++ b/arch/loongarch/boot/dts/Makefile
@@ -3,7 +3,8 @@
 # dtb-y = loongson-2k0500-ref.dtb loongson-2k1000-ref.dtb loongson-2k2000-ref.dtb
 
 ifdef CONFIG_DTB_MATCH_BY_BOARD_NAME
-dtb-$(CONFIG_LOONGSON_2K300) += ls2k300_mini_dp.dtb ls2k300_vanguard_pi.dtb
+dtb-$(CONFIG_LOONGSON_2K300) += ls2k300_mini_dp.dtb ls2k300_vanguard_pi.dtb ls2k300_gongkong_gbkpgk0.dtb
+
 obj-y += $(patsubst %.dtb, %.dtb.o, $(dtb-y))
 else
 obj-$(CONFIG_BUILTIN_DTB)	+= $(addsuffix .dtb.o, $(CONFIG_BUILTIN_DTB_NAME))
diff --git a/arch/loongarch/boot/dts/loongson2k300.dtsi b/arch/loongarch/boot/dts/loongson2k300.dtsi
index 62d4f1189a07..1a2ce983dabf 100644
--- a/arch/loongarch/boot/dts/loongson2k300.dtsi
+++ b/arch/loongarch/boot/dts/loongson2k300.dtsi
@@ -1,6 +1,10 @@
 /dts-v1/;
+#include <dt-bindings/interrupt-controller/irq.h>
 #include <dt-bindings/clock/loongson2k300-clock.h>
 #include <dt-bindings/usb/dwc2-loongson-fix.h>
+#include <dt-bindings/gpio/gpio.h>
+#include <dt-bindings/pwm/pwm.h>
+#include <dt-bindings/input/linux-event-codes.h>
 
 / {
 	model = "loongson,generic";
@@ -184,10 +188,18 @@ i2c2_pins: pinmux_G52_G53_as_i2c2 {
 			pinctrl-single,bits = <0xc 0x00000f00 0x00000f00>;
 		};
 
+		i2c2_G82_G83_pins: pinmux_G82_G83_as_i2c2 {
+			pinctrl-single,bits = <0x14 0x000000a0 0x000000f0>;
+		};
+
 		i2c3_pins: pinmux_G54_G55_as_i2c3 {
 			pinctrl-single,bits = <0xc 0x0000f000 0x0000f000>;
 		};
 
+		i2c3_G84_G85_pins: pinmux_G84_G85_as_i2c3 {
+			pinctrl-single,bits = <0x14 0x00000a00 0x000000f00>;
+		};
+
 		spi1_pins: pinmux_G60_G63_as_spi1 {
 			pinctrl-single,bits = <0xc 0xff000000 0xff000000>;
 		};
@@ -833,11 +845,9 @@ emmc: sdio@0x16140000 {
 			clock-frequency = <0 200000000>;
 			bus-width = <8>;
 			cap-mmc-highspeed;
-#if CONFIG_LOONGSON_MMC_HIGH_PERFORMANCE
-			mmc-hs200-1_8v;
-#endif
 			no-sd;
 			no-sdio;
+			non-removable;
 		};
 
 		sdio1: sdio@0x16148000 {
@@ -868,13 +878,13 @@ ehci@0x16080000 {
 			dma-mask = <0x0 0xffffffff>;
 		};
 
-		otg@0x16040000 {
+		otg: otg@0x16040000 {
 			compatible = "loongson,loongson2-dwc2";
 			reg = <0 0x16040000 0 0x40000>;
 			interrupt-parent = <&liointc1>;
 			interrupts = <16 IRQ_TYPE_LEVEL_HIGH>; // 48 - 32 = 16
 			dma-mask = <0x0 0xffffffff>;
-			loongson,dwc2-fix = <DWC2_LOONGSON_FIX_DELAY>;
+			loongson,dwc2-fix = <DWC2_LOONGSON_FIX_NONE>;
 			//dr_mode = "peripheral";
 			/* Optional for that dr_mode = "host" or dr_mode = "peripheral" */
 		};
diff --git a/arch/loongarch/boot/dts/ls2k300_g2k03z0_core_v10.dtsi b/arch/loongarch/boot/dts/ls2k300_g2k03z0_core_v10.dtsi
index f43bd695c70e..875511c33421 100644
