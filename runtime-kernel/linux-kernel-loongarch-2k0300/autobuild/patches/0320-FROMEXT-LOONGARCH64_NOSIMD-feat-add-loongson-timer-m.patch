+			       <&dma 3 0x400>,
+			       <&dma 4 0x400>,
+			       <&dma 5 0x400>,
+			       <&dma 6 0x400>;
+			dma-names = "ch1", "ch2", "ch3", "ch4", "com", "up", "trig";
+			status = "disabled";
+		};
+
