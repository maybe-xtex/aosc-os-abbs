 			compatible = "loongson,ls2k-pwm-atim";
 			reg = <0 0x16118000 0 0x1000>;
@@ -900,6 +920,25 @@ pwm_atim: pwm@16118000{
 			clock-frequency = <200000000>;
 			status = "disabled";
 		};
+
+		timers2: timer@16119000 {
+			#address-cells = <1>;
+			#size-cells = <0>;
+			compatible = "loongson,loongson-timers";
+			reg = <0 0x16119000 0 0x1000>;
+			interrupt-parent = <&liointc0>;
+			interrupts = <14 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&clocks CLK_APB>;
+			clock-names = "int";
+			dmas = <&dma 0 0x400>,
+			       <&dma 1 0x400>,
+			       <&dma 2 0x400>,
+			       <&dma 3 0x400>,
+			       <&dma 5 0x400>,
+			       <&dma 6 0x400>;
+			dma-names = "ch1", "ch2", "ch3", "ch4", "up", "trig";
+			status = "disabled";
+		};
 		
 		pwm_gtim: pwm@16119000{
 			compatible = "loongson,ls2k-pwm-gtim";
diff --git a/drivers/mfd/Kconfig b/drivers/mfd/Kconfig
index cc5a6f46408c..62840ef59a2e 100644
--- a/drivers/mfd/Kconfig
+++ b/drivers/mfd/Kconfig
@@ -2151,6 +2151,17 @@ config MFD_STM32_TIMERS
 	  for PWM and IIO Timer. This driver allow to share the
 	  registers between the others drivers.
 
+config MFD_LS_TIMERS
+	tristate "Support for LS Timers"
+	depends on (MACH_LOONGSON64 && OF) || COMPILE_TEST
+	select MFD_CORE
+	select REGMAP
+	select REGMAP_MMIO
