From 7b9e1ec567f4cc0d6c676c5acf5073adcccd17ee Mon Sep 17 00:00:00 2001
From: mainframe98 <k.s.werf@hotmail.com>
Date: Fri, 31 Oct 2025 17:28:51 +0100
Subject: [PATCH 03/50] Also extract trait usage in traits and in enums

Summary:
Traits can be used in classes, enums and other traits.
There's a helper that can be used for this.

Test Plan:
* Create a phutil library with a trait using another trait
* Look at the library map file

Reviewers: O1 Blessed Committers, avivey

Reviewed By: O1 Blessed Committers, avivey

Subscribers: tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Maniphest Tasks: T16289

Differential Revision: https://we.phorge.it/D26475
---
 .../api/PHPASTDeclarationVisitor.php          | 21 +++++++++----------
 1 file changed, 10 insertions(+), 11 deletions(-)

diff --git a/support/php-parser/api/PHPASTDeclarationVisitor.php b/support/php-parser/api/PHPASTDeclarationVisitor.php
index 0a3848d68013..e75f23c309b0 100644
--- a/support/php-parser/api/PHPASTDeclarationVisitor.php
+++ b/support/php-parser/api/PHPASTDeclarationVisitor.php
@@ -85,17 +85,6 @@ final class PHPASTDeclarationVisitor extends PhpParser\NodeVisitorAbstract {
           'symbol' => $interface_name,
         );
       }
-
-      $node_finder = new PhpParser\NodeFinder();
-      $trait_use = $node_finder->findInstanceOf(
-        $node->stmts,
-        PhpParser\Node\Stmt\TraitUse::class);
-
-      foreach ($trait_use as $traits) {
-        foreach ($traits->traits as $trait_name) {
-          $this->traits[$fqn][] = $trait_name->toCodeString();
-        }
-      }
     } else if ($node instanceof PhpParser\Node\Stmt\Interface_) {
       $type = 'interface';
       $fqn = $node->namespacedName->toCodeString();
@@ -128,6 +117,16 @@ final class PHPASTDeclarationVisitor extends PhpParser\NodeVisitorAbstract {
       return null;
     }
 
+    if ($node instanceof PhpParser\Node\Stmt\ClassLike) {
+      $fqn = $node->namespacedName->toCodeString();
+
+      foreach ($node->getTraitUses() as $traits) {
+        foreach ($traits->traits as $trait_name) {
+          $this->traits[$fqn][] = $trait_name->toCodeString();
+        }
+      }
+    }
+
     $this->declarations[] = array(
       'type' => $type,
       'name' => $node->namespacedName->toCodeString(),
-- 
