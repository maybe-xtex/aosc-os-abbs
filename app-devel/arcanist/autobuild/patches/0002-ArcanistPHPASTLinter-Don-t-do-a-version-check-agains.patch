From a5e981c8c7cb79f7ee5c8e25b4cf6e849ff5dee4 Mon Sep 17 00:00:00 2001
From: mainframe98 <k.s.werf@hotmail.com>
Date: Tue, 16 Dec 2025 17:02:22 +0100
Subject: [PATCH 02/50] ArcanistPHPASTLinter: Don't do a version check against
 null

Summary:
If the PHP-Parser library isn't available,
PhutilPHPParserLibrary::getVersion will return `null`.
The version check should instead compare the PHP version to predict
if the linter would be able to run if Arcanist were to download
PHP-Parser later on.

Closes T16397

Test Plan:
* Remove PHP-Parser
* Make a change and run `arc diff`

Reviewers: aklapper, O1 Blessed Committers

Reviewed By: aklapper, O1 Blessed Committers

Subscribers: tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Maniphest Tasks: T16397

Differential Revision: https://we.phorge.it/D26595
---
 src/lint/linter/ArcanistPHPASTLinter.php | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/src/lint/linter/ArcanistPHPASTLinter.php b/src/lint/linter/ArcanistPHPASTLinter.php
index 2d7c57ea38f5..52155c4c02c6 100644
--- a/src/lint/linter/ArcanistPHPASTLinter.php
+++ b/src/lint/linter/ArcanistPHPASTLinter.php
@@ -30,10 +30,19 @@ final class ArcanistPHPASTLinter extends ArcanistFutureLinter {
   }
 
   public function canRun() {
+    $library_version = PhutilPHPParserLibrary::getVersion();
+
     // Older versions of PHP-Parser do not provide easy access
     // to the token stream.
     // This means this linter is effectively PHP >= 7.4
-    return version_compare(PhutilPHPParserLibrary::getVersion(), '5.0.0', '>=');
+    if ($library_version) {
+      return version_compare($library_version, '5.0.0', '>=');
+    } else {
+      // If the library isn't available, we can predict which version will be
+      // downloaded.
+      // Only PHP 7.4 and newer download the new version of PHP-Parser.
+      return PHP_VERSION_ID >= 70400;
+    }
   }
 
   public function getCacheVersion() {
-- 
