+    'strptime' => false,
+    'sys_getloadavg' => false,
+    'checkdnsrr' => '5.3.0',
+    'dns_get_record' => '5.3.0',
+    'fnmatch' => '5.3.0',
+    'getmxrr' => '5.3.0',
+    'getopt' => '5.3.0',
+    'imagecolorclosesthwb' => '5.3.0',
+    'inet_ntop' => '5.3.0',
+    'inet_pton' => '5.3.0',
+    'link' => '5.3.0',
+    'linkinfo' => '5.3.0',
+    'readlink' => '5.3.0',
