+            $extension_name,
+            $method);
+        } else {
+          $symbol_information['methods'][$class][$name] = map_entry(
+            $extension_name,
+            $method);
+        }
+      }
+      break;
+    case 'interfaces.json':
+      $symbol_information['interfaces'] = map_entries(
+        $extension_name,
+        $entries);
+      break;
+    case 'traits.json':
+      $symbol_information['traits'] = map_entries($extension_name, $entries);
+      break;
+  }
