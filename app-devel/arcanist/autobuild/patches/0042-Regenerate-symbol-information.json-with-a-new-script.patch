+/** @var SplFileInfo $fileinfo */
+foreach (new RecursiveIteratorIterator($iterator) as $path => $fileinfo) {
+  if ($fileinfo->isDir()) {
+    continue;
+  }
+
+  $extension_name = basename(dirname($fileinfo->getPath()));
+  $entries = phutil_json_decode(Filesystem::readFile($path));
