+if ($args->getArg('show')) {
+  echo id(new PhutilJSON())->encodeFormatted($symbol_information);
+} else {
+  Filesystem::writeFile(
+    $root.'/resources/php/symbol-information.json',
+    id(new PhutilJSON())->encodeFormatted($symbol_information));
