From 791f9a5d6aff9165a36d3268994135bcdbb0d3aa Mon Sep 17 00:00:00 2001
From: mainframe98 <k.s.werf@hotmail.com>
Date: Fri, 6 Feb 2026 19:05:08 +0100
Subject: [PATCH 29/50] Linter: Fix fluent method calling edge case

Summary:
Fluent method calls with more than one argument resulted in a
false-positive for linter rule PHPAST140: Argument Alignment,
as it took the start of the method call chain as the starting line,
rather than the line the operator is placed on.

Ref D26725

Test Plan:
* Run the unit test containing a minimum reproduction
* (Optional) Run arc lint on D26725

Reviewers: O1 Blessed Committers, aklapper

Reviewed By: O1 Blessed Committers, aklapper

Subscribers: tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Differential Revision: https://we.phorge.it/D26727
---
 .../ArcanistArgumentAlignmentPHPASTLinterRule.php   | 13 +++++++++++--
 .../argument-alignment/argument-alignment.lint-test |  8 ++++++++
 2 files changed, 19 insertions(+), 2 deletions(-)

diff --git a/src/lint/linter/phpast/rules/ArcanistArgumentAlignmentPHPASTLinterRule.php b/src/lint/linter/phpast/rules/ArcanistArgumentAlignmentPHPASTLinterRule.php
index 35a048c78acc..cd2c79992b77 100644
--- a/src/lint/linter/phpast/rules/ArcanistArgumentAlignmentPHPASTLinterRule.php
+++ b/src/lint/linter/phpast/rules/ArcanistArgumentAlignmentPHPASTLinterRule.php
@@ -3,6 +3,7 @@
 /**
  * @phutil-external-symbol class PhpParser\Node
  * @phutil-external-symbol class PhpParser\Node\Expr\CallLike
+ * @phutil-external-symbol class PhpParser\Node\Expr\MethodCall
  */
 final class ArcanistArgumentAlignmentPHPASTLinterRule
   extends ArcanistPHPASTNodeLinterRule {
@@ -33,15 +34,23 @@ final class ArcanistArgumentAlignmentPHPASTLinterRule
     $first = head($arguments);
     $last = last($arguments);
 
+    if (
+      $node instanceof PhpParser\Node\Expr\MethodCall &&
+      $node->var instanceof PhpParser\Node\Expr\MethodCall) {
+      $start_line = $node->name->getStartLine();
+    } else {
+      $start_line = $node->getStartLine();
+    }
+
     if (
       $first->getStartLine() === $last->getStartLine() &&
-      $node->getStartLine() === $first->getStartLine()) {
+      $start_line === $first->getStartLine()) {
       return;
     }
 
     $indentation = $this->getIndentation($node, $token_stream).'  ';
 
-    $last_argument_line = $node->getStartLine();
+    $last_argument_line = $start_line;
     foreach ($arguments as $argument) {
       if ($last_argument_line === $argument->getStartLine()) {
         $before = $this->getNonsemanticTokensBeforeNode(
diff --git a/src/lint/linter/phpast/rules/__tests__/argument-alignment/argument-alignment.lint-test b/src/lint/linter/phpast/rules/__tests__/argument-alignment/argument-alignment.lint-test
index cddf853e5f1c..d82cf2b6a4b4 100644
--- a/src/lint/linter/phpast/rules/__tests__/argument-alignment/argument-alignment.lint-test
+++ b/src/lint/linter/phpast/rules/__tests__/argument-alignment/argument-alignment.lint-test
@@ -59,6 +59,10 @@ new class(
   $a, $b) {};
 new class($a,
   $b) {};
+
+$bar = id(new Foo())
+  ->setBaz($baz)
+  ->setFooBar($foo, $bar);
 ~~~~~~~~~~
 warning:9:6:PHPAST140:Argument Alignment
 warning:10:5:PHPAST140:Argument Alignment
@@ -146,3 +150,7 @@ new class(
 new class(
   $a,
   $b) {};
+
+$bar = id(new Foo())
+  ->setBaz($baz)
+  ->setFooBar($foo, $bar);
