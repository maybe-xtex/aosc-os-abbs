From 9e001c493d0e8051de511f5393318fd522d6841d Mon Sep 17 00:00:00 2001
From: Andre Klapper <a9016009@gmx.de>
Date: Sat, 14 Mar 2026 13:40:16 +0100
Subject: [PATCH 48/50] Remove obsolete phutil_is_hiphop_runtime()

Summary:
HipHop for PHP got superseded by HHVM in 2013; no need to check anymore.

Closes T16554

Test Plan: None.

Reviewers: O1 Blessed Committers, mainframe98

Reviewed By: O1 Blessed Committers, mainframe98

Subscribers: tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Maniphest Tasks: T16554

Differential Revision: https://we.phorge.it/D26843
---
 src/__phutil_library_map__.php                         | 1 -
 src/filesystem/__tests__/PhutilDeferredLogTestCase.php | 9 +--------
 src/utils/utils.php                                    | 4 ----
 3 files changed, 1 insertion(+), 13 deletions(-)

diff --git a/src/__phutil_library_map__.php b/src/__phutil_library_map__.php
index eee0d11fbc29..a26945754e54 100644
--- a/src/__phutil_library_map__.php
+++ b/src/__phutil_library_map__.php
@@ -1219,7 +1219,6 @@ phutil_register_library_map(array(
     'phutil_hashes_are_identical' => 'utils/utils.php',
     'phutil_http_parameter_pair' => 'utils/utils.php',
     'phutil_ini_decode' => 'utils/utils.php',
-    'phutil_is_hiphop_runtime' => 'utils/utils.php',
     'phutil_is_interactive' => 'utils/utils.php',
     'phutil_is_natural_list' => 'utils/utils.php',
     'phutil_is_noninteractive' => 'utils/utils.php',
diff --git a/src/filesystem/__tests__/PhutilDeferredLogTestCase.php b/src/filesystem/__tests__/PhutilDeferredLogTestCase.php
index 1d12987182b7..c365a34efc08 100644
--- a/src/filesystem/__tests__/PhutilDeferredLogTestCase.php
+++ b/src/filesystem/__tests__/PhutilDeferredLogTestCase.php
@@ -80,14 +80,7 @@ final class PhutilDeferredLogTestCase extends PhutilTestCase {
   public function testLogWriteFailure() {
     $caught = null;
     try {
-      if (phutil_is_hiphop_runtime()) {
-        // In HipHop exceptions thrown in destructors are not normally
-        // catchable, so call __destruct() explicitly.
-        $log = new PhutilDeferredLog('/derp/derp/derp/derp/derp', 'derp');
-        $log->__destruct();
-      } else {
-        new PhutilDeferredLog('/derp/derp/derp/derp/derp', 'derp');
-      }
+      new PhutilDeferredLog('/derp/derp/derp/derp/derp', 'derp');
     } catch (Exception $ex) {
       $caught = $ex;
     }
diff --git a/src/utils/utils.php b/src/utils/utils.php
index be4ca8ae1938..1e321527888b 100644
--- a/src/utils/utils.php
+++ b/src/utils/utils.php
@@ -1039,10 +1039,6 @@ function phutil_is_windows() {
   return (DIRECTORY_SEPARATOR != '/');
 }
 
-function phutil_is_hiphop_runtime() {
-  return (array_key_exists('HPHP', $_ENV) && $_ENV['HPHP'] === 1);
-}
-
 /**
  * Converts a string to a loggable one, with unprintables and newlines escaped.
  *
-- 
