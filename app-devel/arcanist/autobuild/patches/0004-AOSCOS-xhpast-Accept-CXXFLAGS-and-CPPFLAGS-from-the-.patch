 h=from:subject; bh=EF5LjvSWZW6tMzv9zcHxS8rOR4UMZMuWgl2TBMGvM5c=;
 b=owGbwMvMwCW2U4Ij7wZL9ETG02pJDBlOii5VXz9taSh+1jhrUsFDsdCKM60bPrzfzPFG5q/St
 Kuf37Au7ChlYRDjYpAVU2QpMmzwZtVJ5xddVi4LM4eVCWQIAxenAExE7Sgjw8+gJP81nIlfigTu
 bw09/4u52LEw8hNLoT3XKpnex8ePeTP8s98hz3ehw7T6uJd7Qfm9iqux27Yov2I3/3y7xfz0Q75
 yZgA=
X-Developer-Key: i=xtexchooser@duck.com; a=openpgp;
 fpr=7231804B052C670F15A6771DB918086ED8045B91

This allows users to pass customized flags to the compiler.

The motivation for this change is to include flags provided
by automatic packaging systems.
---
 support/xhpast/Makefile | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/support/xhpast/Makefile b/support/xhpast/Makefile
index 64a211745909..2e7272da5f63 100644
--- a/support/xhpast/Makefile
+++ b/support/xhpast/Makefile
@@ -1,5 +1,5 @@
 BISONFLAGS = --verbose --name-prefix xhpast
-CPPFLAGS   = -fPIC -Wall
+CPPFLAGS   += $(CXXFLAGS) -fPIC -Wall
 FLEXFLAGS  = -CFr
 XHPAST_VERSION := $(shell ./bin/xhpast-generate-version.php)
 
