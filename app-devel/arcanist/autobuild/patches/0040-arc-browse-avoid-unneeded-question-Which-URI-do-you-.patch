@@ -6,6 +6,9 @@ final class ArcanistBrowseRef
   const HARDPOINT_URIS = 'uris';
   const HARDPOINT_COMMITREFS = 'commitRefs';
 
+  /**
+   * @var string
+   */
   private $token;
   private $types = array();
 
@@ -36,11 +39,18 @@ final class ArcanistBrowseRef
     );
   }
 
+  /**
+   * @param string $token
+   * @return $this
