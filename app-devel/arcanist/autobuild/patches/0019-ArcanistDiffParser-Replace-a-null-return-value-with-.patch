From b71cacc50bf41bb19fb6f58d5c35741882798e78 Mon Sep 17 00:00:00 2001
From: Andre Klapper <a9016009@gmx.de>
Date: Sat, 10 Jan 2026 14:30:19 +0100
Subject: [PATCH 19/50] ArcanistDiffParser: Replace a null return value with
 void for consistency

Summary: This private function is not supposed to return anything as its return value is never read anyway, thus consistently return void instead of null (which makes no technical difference but is easier to read).

Test Plan: Look at the other return values in the same function, and the calls of the function.

Reviewers: O1 Blessed Committers, mainframe98

Reviewed By: O1 Blessed Committers, mainframe98

Subscribers: tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Differential Revision: https://we.phorge.it/D26667
---
 src/parser/ArcanistDiffParser.php | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/parser/ArcanistDiffParser.php b/src/parser/ArcanistDiffParser.php
index ba43e1214aaa..926cab1576cd 100644
--- a/src/parser/ArcanistDiffParser.php
+++ b/src/parser/ArcanistDiffParser.php
@@ -804,7 +804,7 @@ final class ArcanistDiffParser extends Phobject {
       // "git diff -b" ignores whitespace, but has an empty hunk target
       if (preg_match('@^diff --git .*$@', $line)) {
         $this->nextLine();
-        return null;
+        return;
       }
     }
 
