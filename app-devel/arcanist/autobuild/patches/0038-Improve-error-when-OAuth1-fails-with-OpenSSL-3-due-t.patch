From 64d64e1bc49c01c0887b186c36276df30b61c414 Mon Sep 17 00:00:00 2001
From: Andre Klapper <a9016009@gmx.de>
Date: Tue, 21 Oct 2025 10:35:30 +0200
Subject: [PATCH 38/50] Improve error when OAuth1 fails with OpenSSL 3 due to
 SHA1

Summary:
OAuth 1.0 mandates SHA1 per https://datatracker.ietf.org/doc/html/rfc5849#section-3.4.
SHA1 has been deprecated since OpenSSL 3.0 per https://docs.openssl.org/3.0/man3/SHA256_Init/ and https://openssl-library.org/news/openssl-3.0-notes/

Provide configuration hints instead of a generic `openssl_sign() failed` error message.

Closes T16315

Test Plan:
* Use a Fedora distribution released in the last five years per https://fedoraproject.org/wiki/Changes/StrongCryptoSettings2
* Use OpenSSL 3.x (the last 1.x release was two years ago according to https://openssl-library.org/source/old/)
* Run `./bin/arc unit src/future/oauth/__tests__/PhutilOAuth1FutureTestCase.php`
* Check error output before and after applying this patch
* After applying the patch, follow given instructions in output, see that afterwards this unit test passes

Reviewers: O1 Blessed Committers, mainframe98

Reviewed By: O1 Blessed Committers, mainframe98

Subscribers: mainframe98, tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Maniphest Tasks: T16315

Differential Revision: https://we.phorge.it/D26445
---
 src/future/oauth/PhutilOAuth1Future.php | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/src/future/oauth/PhutilOAuth1Future.php b/src/future/oauth/PhutilOAuth1Future.php
index 3cf6fabd8d08..014ef17536fb 100644
--- a/src/future/oauth/PhutilOAuth1Future.php
+++ b/src/future/oauth/PhutilOAuth1Future.php
@@ -269,6 +269,22 @@ final class PhutilOAuth1Future extends FutureProxy {
         $signature = null;
         $ok = openssl_sign($string, $signature, $pkey, OPENSSL_ALGO_SHA1);
         if (!$ok) {
+          $ex = openssl_error_string();
+          if (substr($ex, 0, 15) === 'error:03000098:') {
+            $explain = pht(
+              '%s requires the %s algorithm but %s disables %s by default. '.
+              'Consider setting %s or export %s.',
+              'OAuth1',
+              'SHA1',
+              'OpenSSL 3',
+              'SHA1',
+              '"update-crypto-policies --set LEGACY"',
+              '"OPENSSL_ENABLE_SHA1_SIGNATURES=1"');
+            throw new Exception(pht(
+              '%s failed: %s',
+              'openssl_sign()',
+              $explain));
+          }
           throw new Exception(pht('%s failed!', 'openssl_sign()'));
         }
 
