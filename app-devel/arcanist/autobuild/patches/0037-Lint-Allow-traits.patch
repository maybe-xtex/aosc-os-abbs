Subject: [PATCH 37/50] Lint: Allow traits

Summary: Ref T15751. These lints are wrong when it comes to Traits.

Test Plan: `arc lint` on D26768, and also on some positive examples.

Reviewers: O1 Blessed Committers, mainframe98

Reviewed By: O1 Blessed Committers, mainframe98

Subscribers: mainframe98, tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Maniphest Tasks: T15751

Differential Revision: https://we.phorge.it/D26769
---
 ...ClassMustBeDeclaredAbstractXHPASTLinterRule.php |  6 +++++-
 ...ArcanistRaggedClassTreeEdgeXHPASTLinterRule.php | 14 ++++++--------
 2 files changed, 11 insertions(+), 9 deletions(-)

diff --git a/src/lint/linter/xhpast/rules/ArcanistClassMustBeDeclaredAbstractXHPASTLinterRule.php b/src/lint/linter/xhpast/rules/ArcanistClassMustBeDeclaredAbstractXHPASTLinterRule.php
index 859dc3196ab0..ad81adc792e7 100644
--- a/src/lint/linter/xhpast/rules/ArcanistClassMustBeDeclaredAbstractXHPASTLinterRule.php
+++ b/src/lint/linter/xhpast/rules/ArcanistClassMustBeDeclaredAbstractXHPASTLinterRule.php
@@ -19,6 +19,10 @@ final class ArcanistClassMustBeDeclaredAbstractXHPASTLinterRule
     foreach ($classes as $class) {
       $class_modifiers = $this->getModifiers($class);
 
+      if (idx($class_modifiers, 'abstract') || idx($class_modifiers, 'trait')) {
+        continue;
+      }
+
       $abstract_methods = array();
       $methods = $class->selectDescendantsOfType('n_METHOD_DECLARATION');
 
@@ -30,7 +34,7 @@ final class ArcanistClassMustBeDeclaredAbstractXHPASTLinterRule
         }
       }
 
-      if (!idx($class_modifiers, 'abstract') && $abstract_methods) {
+      if ($abstract_methods) {
         $this->raiseLintAtNode(
           $class,
           pht(
diff --git a/src/lint/linter/xhpast/rules/ArcanistRaggedClassTreeEdgeXHPASTLinterRule.php b/src/lint/linter/xhpast/rules/ArcanistRaggedClassTreeEdgeXHPASTLinterRule.php
index 864d1f6e6cc9..55021aa846f2 100644
--- a/src/lint/linter/xhpast/rules/ArcanistRaggedClassTreeEdgeXHPASTLinterRule.php
+++ b/src/lint/linter/xhpast/rules/ArcanistRaggedClassTreeEdgeXHPASTLinterRule.php
@@ -22,14 +22,12 @@ final class ArcanistRaggedClassTreeEdgeXHPASTLinterRule
       $is_abstract = false;
       $is_concrete_extensible = false;
 
-      $attributes = $class->getChildOfType(0, 'n_CLASS_ATTRIBUTES');
-      foreach ($attributes->getChildren() as $child) {
-        if ($child->getConcreteString() == 'final') {
-          $is_final = true;
-        }
-        if ($child->getConcreteString() == 'abstract') {
-          $is_abstract = true;
-        }
+      $class_modifiers = $this->getModifiers($class);
+      if (idx($class_modifiers, 'final')) {
+        $is_final = true;
+      }
+      if (idx($class_modifiers, 'abstract') || idx($class_modifiers, 'trait')) {
+        $is_abstract = true;
       }
 
       $docblock = $class->getDocblockToken();
