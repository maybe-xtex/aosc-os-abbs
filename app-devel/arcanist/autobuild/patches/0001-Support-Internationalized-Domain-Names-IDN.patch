From 49f59ecb2441d88db896702e923284398babc465 Mon Sep 17 00:00:00 2001
From: Valerio Bozzolan <nsa+gitspam@succhia.cz>
Date: Tue, 16 Dec 2025 15:39:43 +0100
Subject: [PATCH 01/50] Support Internationalized Domain Names (IDN)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Summary:
The class PhutilURI, which is responsible for validating each URI,
now supports Internationalized Domain Names (IDN).
Further info about these domains:

https://en.wikipedia.org/wiki/Internationalized_domain_name

This means Phorge now supports these domains in multiple areas,
especially for Remarkup links.

This means URIs with domain names in Ukrainian, Arabic, Japanese, Chinese,
Greek, etc. are now supported. This catapults us forward 15 years of
technological innovation, preventing these white people from the USA
with their evil neolatin purposes from dominating computer science
through Phorge.

The domains were validated by a regex, changed in this way:

| Before   | After   | Notes                                 |
|----------|---------|---------------------------------------|
| `a-zA-Z` | `\p{L}` | from ASCII letters to unicode letters |
| `0-9`    | `\p{N}` | from ASCII numbers to unicode numbers |

To use this feature, we activated the 'u' regex modifier.

None of the mentioned unicode categories include separators or spaces,
so the relevant concern about these separators is still mitigated.

Support for Unicode domains does not yet include domains with emoji.
If your business requires emojis in domains, join the task https://we.phorge.it/T16391.

Closes T16326
Closes T15733
Ref T16391

Test Plan:
Run all the unit tests with:

    arc unit --everything

Run the specific unit test:

    arc unit src/parser/__tests__/PhutilURITestCase.php

Visit a Remarkup input box, and write this code:

    [[ https://후이즈검색.한국/ | Link name ]]

It's now recognized as a link. The link is not red anymore. Nothing else explodes.

Reviewers: revi, O1 Blessed Committers, mainframe98

Reviewed By: O1 Blessed Committers, mainframe98

Subscribers: mainframe98, tobiaswiese, Matthew, Cigaryno

Maniphest Tasks: T16326, T15733, T16391

Differential Revision: https://we.phorge.it/D26578
---
 src/parser/PhutilURI.php                   |  6 +++++-
 src/parser/__tests__/PhutilURITestCase.php | 18 ++++++++++++++++++
 2 files changed, 23 insertions(+), 1 deletion(-)

diff --git a/src/parser/PhutilURI.php b/src/parser/PhutilURI.php
index 494882e1ea9f..0552e0d9ce0a 100644
--- a/src/parser/PhutilURI.php
+++ b/src/parser/PhutilURI.php
@@ -103,10 +103,14 @@ final class PhutilURI extends Phobject {
     // the host looks like garbage. In particular, we do not allow hosts which
     // begin with "." or "-". See T12961 for a specific attack which relied on
     // hosts beginning with "-".
+    // Regex notes:
+    // The sequence '\p{L}' means any Unicode letter (Greek, Chinese, etc.)
+    // The sequence '\p{N}' means any Unicode number.
+    // The last letter 'u' is the modifier to support Unicode.
     if ($parts) {
       $host = idx($parts, 'host', '');
       if (strlen($host)) {
-        if (!preg_match('/^[a-zA-Z0-9]+[a-zA-Z0-9\\.\\-]*\z/', $host)) {
+        if (!preg_match('/^[\p{L}\p{N}]+[\p{L}\p{N}\\.\\-]*\z/u', $host)) {
           $parts = false;
         }
       }
diff --git a/src/parser/__tests__/PhutilURITestCase.php b/src/parser/__tests__/PhutilURITestCase.php
index c9c881ce9bf0..d691b7930b69 100644
--- a/src/parser/__tests__/PhutilURITestCase.php
+++ b/src/parser/__tests__/PhutilURITestCase.php
@@ -414,4 +414,22 @@ final class PhutilURITestCase extends PhutilTestCase {
       (string)$uri);
   }
 
+  public function testUnicodeDomains() {
+    // These domains are non-ascii, so, encoded with 'base64_encode()',
+    // just to make our linter happy.
+    $test_domains_in_base64 = [
+      '7ZuE7J207KaI6rKA7IOJLu2VnOq1rQ==', // Chinese, just letters
+      'zr/Phc+Ezr/PgM6vzrEuzrTPgM64Lmdy', // Greek
+    ];
+
+    foreach ($test_domains_in_base64 as $test_domain_in_base64) {
+      $test_domain = base64_decode($test_domain_in_base64);
+      $uri = new PhutilURI("http://$test_domain/path");
+      $this->assertEqual(
+        $test_domain,
+        $uri->getDomain(),
+        pht("Test non-ASCII domain '%s' (base64: %s)",
+        $test_domain, $test_domain_in_base64));
+    }
+  }
 }

