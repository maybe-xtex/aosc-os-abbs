From c313f2b3f2a36966fc53b2914aaf84ec8a1eb567 Mon Sep 17 00:00:00 2001
From: Pppery <mapreader@olum.org>
Date: Thu, 25 Dec 2025 22:02:15 -0500
Subject: [PATCH 09/50] Check for toolset config before complaining about
 invalid config

Summary:
Fixes T16411

This is kind of hacky, but T16412 won't be done any time soon and in the mean time it alleviates confusion

Test Plan:
- Run `arc set-config arc.land.strategy merge`
- See a warning without this patch and no warning with it
- Run `arc get-config arc.land.strategy --verbose`
- See a warning without this patch and no warning with it
- Run `arc get-config bogus --verbose`
- See a warning with and without this patch
- Run `arc set-config bogus bogus`
- See a warning with and without this patch

Reviewers: O1 Blessed Committers, aklapper

Reviewed By: O1 Blessed Committers, aklapper

Subscribers: aklapper, tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Maniphest Tasks: T16411

Differential Revision: https://we.phorge.it/D26620
---
 src/workflow/ArcanistGetConfigWorkflow.php | 11 ++++++++---
 src/workflow/ArcanistSetConfigWorkflow.php | 21 +++++++++++++--------
 2 files changed, 21 insertions(+), 11 deletions(-)

diff --git a/src/workflow/ArcanistGetConfigWorkflow.php b/src/workflow/ArcanistGetConfigWorkflow.php
index 0f2c34cae4b0..9cdd9b94079a 100644
--- a/src/workflow/ArcanistGetConfigWorkflow.php
+++ b/src/workflow/ArcanistGetConfigWorkflow.php
@@ -79,9 +79,14 @@ EOTEXT
       if ($verbose) {
         $help = $settings->getHelp($key);
         if (!$help) {
-          $help = pht(
-            '(This configuration value is not recognized by arc. It may '.
-            'be misspelled or out of date.)');
+          // It's not a legacy-workflow-recognized config setting; check if
+          // it's a toolset-recognized config setting before complaining
+          $map = id(new ArcanistConfigurationEngine())->newConfigOptionsMap();
+          if (!isset($map[$key])) {
+            $help = pht(
+              '(This configuration value is not recognized by arc. It may '.
+              'be misspelled or out of date.)');
+          }
         }
 
         $console->writeOut("%s\n\n", phutil_console_wrap($help, 4));
diff --git a/src/workflow/ArcanistSetConfigWorkflow.php b/src/workflow/ArcanistSetConfigWorkflow.php
index 75b4334f8bb9..6591bddda45d 100644
--- a/src/workflow/ArcanistSetConfigWorkflow.php
+++ b/src/workflow/ArcanistSetConfigWorkflow.php
@@ -72,14 +72,19 @@ EOTEXT
     $console = PhutilConsole::getConsole();
 
     if (!$settings->getHelp($key)) {
-      $warning = tsprintf(
-        "**%s:** %s\n",
-        pht('Warning'),
-        pht(
-          'The configuration key "%s" is not recognized by arc. It may '.
-          'be misspelled or out of date.',
-          $key));
-      $console->writeErr('%s', $warning);
+      // It's not a legacy-workflow-recognized config setting; check if
+      // it's a toolset-recognized config setting before complaining
+      $map = id(new ArcanistConfigurationEngine())->newConfigOptionsMap();
+      if (!isset($map[$key])) {
+        $warning = tsprintf(
+          "**%s:** %s\n",
+          pht('Warning'),
+          pht(
+            'The configuration key "%s" is not recognized by arc. It may '.
+            'be misspelled or out of date.',
+            $key));
+        $console->writeErr('%s', $warning);
+      }
     }
 
     $old = null;
-- 
