+(str_starts_with('a', 'b'));
+(1 + 0 === strpos('a', 'b'));
+
+(!strncasecmp('a', 'b', 1));
+(strncasecmp('a', 'b', 1));
+(!strncasecmp('a', 'b', 1));
+(1 + 0 === stripos('a', 'b'));
