From 6c25bc68359d6da3f87a94c9cb921e330287cbd2 Mon Sep 17 00:00:00 2001
From: Andre Klapper <a9016009@gmx.de>
Date: Sat, 14 Mar 2026 13:42:40 +0100
Subject: [PATCH 47/50] PhutilPHPParserLibrary: Replace a strpos call with
 strncmp

Summary: arc lint says `(PHPAST36) Slow Construct: Use "strncmp" for checking if the string starts with something` so just do that.

Test Plan: Compare the output of `arc lint src/parser/phpast/lib/PhutilPHPParserLibrary.php` before and after this patch.

Reviewers: O1 Blessed Committers, mainframe98

Reviewed By: O1 Blessed Committers, mainframe98

Subscribers: mainframe98, tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Differential Revision: https://we.phorge.it/D26845
---
 src/parser/phpast/lib/PhutilPHPParserLibrary.php | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/parser/phpast/lib/PhutilPHPParserLibrary.php b/src/parser/phpast/lib/PhutilPHPParserLibrary.php
index 1b5ab6c4c353..ea7ae5787c23 100644
--- a/src/parser/phpast/lib/PhutilPHPParserLibrary.php
+++ b/src/parser/phpast/lib/PhutilPHPParserLibrary.php
@@ -140,7 +140,7 @@ final class PhutilPHPParserLibrary extends Phobject {
   private static function phpParserAutoloader($classname) {
     $lib = self::getPath();
 
-    if (strpos($classname, 'PhpParser') !== 0) {
+    if (strncmp($classname, 'PhpParser', 9)) {
       return false;
     }
 
