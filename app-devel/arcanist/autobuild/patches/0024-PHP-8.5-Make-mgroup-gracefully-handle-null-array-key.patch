From 4933ff76516dd93c5d231c02e1525319358f8d2c Mon Sep 17 00:00:00 2001
From: Andre Klapper <a9016009@gmx.de>
Date: Wed, 7 Jan 2026 14:10:56 +0100
Subject: [PATCH 24/50] PHP 8.5: Make mgroup() gracefully handle null array
 keys

Summary:
Setting null as an array key is deprecated since PHP 8.5 per https://www.php.net/releases/8.5/en.php: "Using null as an array offset or when calling array_key_exists() is now deprecated. Use an empty string instead."

```
ERROR 8192: Using null as an array offset is deprecated, use an empty string instead at [/var/www/html/phorge/arcanist/src/utils/utils.php:338]
  #0 mgroup(array, string) called at [<phorge>/src/applications/maniphest/controller/ManiphestReportController.php:221]
```

Closes T16445

Test Plan: On PHP 8.5, make you sure you have at least one open unassigned task, go to http://phorge.localhost/maniphest/report/user/

Reviewers: O1 Blessed Committers, valerio.bozzolan

Reviewed By: O1 Blessed Committers, valerio.bozzolan

Subscribers: tobiaswiese, valerio.bozzolan, Matthew, Cigaryno

Maniphest Tasks: T16445

Differential Revision: https://we.phorge.it/D26664
---
 src/utils/utils.php | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/src/utils/utils.php b/src/utils/utils.php
index cd3b4e1b57b0..33a4feab6525 100644
--- a/src/utils/utils.php
+++ b/src/utils/utils.php
@@ -326,10 +326,12 @@ function mgroup(array $list, $by /* , ... */) {
   $groups = array();
   foreach ($map as $group) {
     // Can't array_fill_keys() here because 'false' gets encoded wrong.
+    $group = $group ?? '';
     $groups[$group] = array();
   }
 
   foreach ($map as $key => $group) {
+    $group = $group ?? '';
     $groups[$group][$key] = $list[$key];
   }
 
