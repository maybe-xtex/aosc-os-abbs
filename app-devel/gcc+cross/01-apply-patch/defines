# Apply the patch in a fake package: we cannot do this in 01-amd64 otherwise
# on amd64 no patches will be applied due to FAIL_ARCH.

PKGNAME=gcc+cross-apply-patch
PKGDES="An artifact of the internal build process; nobody should install it"
PKGSEC=devel
ABINSTALL=
ABARCHIVE=true # note that "true" is a command here, not a boolean value
ABHOST=noarch
ABTYPE=dummy
