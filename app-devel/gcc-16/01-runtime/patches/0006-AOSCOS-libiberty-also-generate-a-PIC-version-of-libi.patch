From efbae12e5b5ba7ebdc52a05ca058a41048ed9a95 Mon Sep 17 00:00:00 2001
From: Henry Chen <henry.chen@oss.cipunited.com>
Date: Mon, 25 Nov 2024 15:09:30 +0800
Subject: [PATCH 6/7] AOSCOS: libiberty: also generate a PIC version of
 libiberty.a

Signed-off-by: Xi Ruoyao <xry111@xry111.site>
---
 libiberty/configure | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/libiberty/configure b/libiberty/configure
index 359f19ac037..3eabfa2856a 100755
--- a/libiberty/configure
+++ b/libiberty/configure
@@ -5676,10 +5676,6 @@ if [ "${enable_host_shared}" = "yes" ] || [ "${enable_host_pie}" = "yes" ]; then
   shared=yes
 fi
 
-if [ "${shared}" != "yes" ]; then
-  PICFLAG=
-fi
-
 
 NOASANFLAG=
 case " ${CFLAGS} " in
-- 
