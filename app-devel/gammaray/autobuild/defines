PKGNAME=gammaray
PKGSEC=devel
PKGDEP="elfutils gcc-runtime kdsme qt-6 syntax-highlighting"
BUILDDEP="libdwarf llvm gdb glslang"
PKGDES="Qt graphical interface introspection utility"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DQT_VERSION_MAJOR=6'
    '-DGAMMARAY_PROBE_ONLY_BUILD=false'
    '-DGAMMARAY_CLIENT_ONLY_BUILD=false'
    '-DGAMMARAY_BUILD_UI=true'
    '-DGAMMARAY_INSTALL_QT_LAYOUT=true'
    '-DGAMMARAY_MULTI_BUILD=true'
    '-DGAMMARAY_BUILD_CLI_INJECTOR=false'
    '-DGAMMARAY_STATIC_PROBE=false'
    '-DGAMMARAY_CORE_ONLY_LAUNCHER=false'
    '-DGAMMARAY_DISABLE_FEEDBACK=true'
    '-DGAMMARAY_BUILD_DOCS=false'
    '-DGAMMARAY_ENFORCE_QT_ASSERTS=false'
    '-DGAMMARAY_USE_PCH=true'
    '-DGAMMARAY_WITH_KDSME=true'
    '-DENABLE_GOLD_LINKER=false'
    '-DWARNINGS_ARE_ERRORS=false'
    '-DECM_MKSPECS_INSTALL_DIR=/usr/lib/qt6/mkspecs/modules'
    '-DPLUGIN_INSTALL_DIR=/usr/lib/qt6/plugins/gammaray'
)
