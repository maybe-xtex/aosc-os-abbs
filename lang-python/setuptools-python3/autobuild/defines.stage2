PKGNAME=setuptools-python3
PKGSEC=python
PKGDES="Easily download, build, install, upgrade, and uninstall Python packages (Python 3)"
PKGREP="setuptools+rt3"
PKGPROV="setuptools+rt3"

PKGBREAK="setuptools<=44.1.0"
PKGREP="setuptools<=44.1.0"

# Incomplete installation if using setup.py.
ABTYPE=pep517
NOPYTHON2=1
ABHOST=noarch
