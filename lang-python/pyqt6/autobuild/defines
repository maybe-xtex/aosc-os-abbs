PKGNAME=pyqt6
PKGSEC=python
PKGDEP="qt-6 sip dbus-python pyopengl pyqt6-sip"
BUILDDEP="packaging pyqt-builder setuptools"
BUILDDEP__ARM64="${BUILDDEP} llvm"
BUILDDEP__LOONGARCH64="${BUILDDEP} llvm"
BUILDDEP__LOONGARCH64_NOSIMD="${BUILDDEP} llvm"
PKGDES="Python bindings for Qt 6"

NOPYTHON2=1
QT_SELECT=6

# qmake will use llvm for archs that build qt with llvm
USECLANG__ARM64=1
USECLANG__LOONGARCH64=1
USECLANG__LOONGARCH64_NOSIMD=1

# FIXME: LLVM builds will try to link LLVM IR bitcode
# with lto enabled. Turn off LTO as a workaround.
# Proper LTO flags shall be set to ensure correct behavior.
NOLTO__ARM64=1
NOLTO__LOONGARCH64=1
NOLTO__LOONGARCH64_NOSIMD=1

