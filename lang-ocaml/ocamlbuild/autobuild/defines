PKGNAME=ocamlbuild
PKGSEC=devel
PKGDEP="ocaml"
BUILDDEP="ocaml"
PKGDES="Generic build tool for OCaml"

MAKE_AFTER=(
    'OCAML_NATIVE=false'
    'OCAMLBUILD_PREFIX=/usr'
    'OCAMLBUILD_BINDIR=/usr/bin'
    'OCAMLBUILD_LIBDIR=/usr/lib/ocaml'
    'OCAMLBUILD_MANDIR=/usr/share/man'
)
MAKE_AFTER__OCAML_NATIVE=(
    'OCAML_NATIVE=true'
    'OCAMLBUILD_PREFIX=/usr'
    'OCAMLBUILD_BINDIR=/usr/bin'
    'OCAMLBUILD_LIBDIR=/usr/lib/ocaml'
    'OCAMLBUILD_MANDIR=/usr/share/man'
)

PKGBREAK="ocaml<=4.02.3"
PKGREP="ocaml<=4.02.3"

NOSTATIC=0
ABTYPE=self
ABSTRIP=0
ABSTRIP__OCAML_NATIVE=1
