From 7a3236ce9ccfd3057a3967d8587125244348a36b Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sun, 4 Jan 2026 16:12:25 +0800
Subject: [PATCH 1/2] AOSCOS: HACK: fix(pam): do not build tests
 unconditionally

Tests for the PAM module requires pam_wrapper, which we do not maintain.
It seems pointless since we don't even run unit tests.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 pam/meson.build | 26 --------------------------
 1 file changed, 26 deletions(-)

diff --git a/pam/meson.build b/pam/meson.build
index 8413b58..51657ff 100644
--- a/pam/meson.build
+++ b/pam/meson.build
@@ -17,29 +17,3 @@ pam_gnome_keyring = shared_library('pam_gnome_keyring',
   ],
   name_prefix: '',
 )
-
-# pam tests
-pam_wrapper = dependency('pam_wrapper', required: true)
-libpamtest = dependency('libpamtest', required: true)
-
-subdir('servicedir')
-
-test_bin = executable('pam_test',
-  sources: [
-    'test-pam.c',
-  ],
-  dependencies: [
-    libpamtest,
-    glib_deps,
-  ],
-)
-
-test('pam-test',
-  test_bin,
-  env: {
-    'LD_PRELOAD': 'libpam_wrapper.so',
-    'PAM_WRAPPER': '1',
-    'PAM_WRAPPER_DEBUGLEVEL': '5',
-    'PAM_WRAPPER_SERVICE_DIR': meson.current_build_dir() + '/servicedir',
-  },
-)
-- 
2.52.0

