PKGNAME=libei
PKGDES="Library for handling Emulated Input (EI)"
PKGSEC=libs
PKGDEP="gcc-runtime glibc libxkbcommon libevdev systemd"
BUILDDEP="attrs jinja2 meson ninja"

ABTYPE=meson
MESON_AFTER=(
    '-Ddocumentation=[]'
    '-Dsd-bus-provider=libsystemd'
    '-Dtests=disabled'
    '-Dliboeffis=enabled'
    '-Dlibeis=enabled'
    '-Dlibei=enabled'
)
