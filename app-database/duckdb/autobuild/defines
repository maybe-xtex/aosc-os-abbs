PKGNAME=duckdb
PKGDES="Analytical in-process SQL database management system"
PKGSEC=database
PKGDEP="glibc gcc-runtime"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DBUILD_UNITTESTS=OFF'
    '-DENABLE_UNITTEST_CPP_TESTS=OFF'
    '-DENABLE_SANITIZER=OFF'
    '-DENABLE_UBSAN=OFF'
)

# FIXME: ld.lld is not yet available for these architectures.
NOLTO__LOONGSON3=1
