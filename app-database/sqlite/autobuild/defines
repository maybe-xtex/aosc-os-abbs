PKGNAME=sqlite
PKGSEC=database
PKGDEP="libedit readline tcl"
PKGDES="A full-featured and self-contained SQL database engine" 

ABSHADOW=0
NOPARALLEL=1

AUTOTOOLS_AFTER="--soname=0 \
                 --prefix=/usr \
                 --enable-largefile \
                 --enable-threadsafe \
                 --enable-tcl \
                 --enable-editline \
                 --enable-readline \
                 --disable-amalgamation \
                 --enable-load-extension \
                 --enable-math \
                 --enable-json \
                 --enable-memsys5 \
                 --enable-memsys3 \
                 --enable-fts3 \
                 --enable-fts4 \
                 --enable-fts5 \
                 --enable-update-limit \
                 --enable-geopoly \
                 --enable-rtree \
                 --enable-session"
AUTOTOOLS_AFTER__RETRO=" \
                 ${AUTOTOOLS_AFTER} \
                 --disable-tcl"

NOLTO__M68K=1
