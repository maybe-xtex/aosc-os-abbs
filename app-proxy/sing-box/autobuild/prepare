abinfo "Setting build tags ..."
TAGS=(
    "with_quic"
    "with_grpc"
    "with_dhcp"
    "with_wireguard"
    "with_utls"
    "with_acme"
    "with_clash_api"
    "with_v2ray_api"
    "with_gvisor"
    "with_tailscale"
)
# FIXME: For `with_naive_outbound`, though it does not support ppc64el.
if ! ab_match_arch ppc64el; then
    export CGO_LDFLAGS="${LDFLAGS} -fuse-ld=lld"
    TAGS=(
        "${TAGS[@]}"
        "with_naive_outbound"
    )
fi
GO_BUILD_AFTER=(
    -tags "${TAGS[*]}"
)
