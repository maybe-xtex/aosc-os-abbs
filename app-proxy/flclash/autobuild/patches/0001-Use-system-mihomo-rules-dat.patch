From 9372c0bed291e95289f24997a1a577e8cb03c93b Mon Sep 17 00:00:00 2001
From: pugaizai <i@pugai.life>
Date: Tue, 30 Sep 2025 21:02:50 +0800
Subject: [PATCH 1/3] Use system mihomo rules dat

---
 lib/common/constant.dart | 8 ++++----
 lib/core/controller.dart | 7 ++++---
 pubspec.yaml             | 3 +--
 3 files changed, 9 insertions(+), 9 deletions(-)

diff --git a/lib/common/constant.dart b/lib/common/constant.dart
index b7320b0..7aac933 100644
--- a/lib/common/constant.dart
+++ b/lib/common/constant.dart
@@ -32,10 +32,10 @@ const animateDuration = Duration(milliseconds: 100);
 const midDuration = Duration(milliseconds: 200);
 const commonDuration = Duration(milliseconds: 300);
 const defaultUpdateDuration = Duration(days: 1);
-const MMDB = 'GEOIP.metadb';
-const ASN = 'ASN.mmdb';
-const GEOIP = 'GEOIP.dat';
-const GEOSITE = 'GEOSITE.dat';
+const MMDB = 'geoip.metadb';
+const ASN = 'GeoLite2-ASN.mmdb';
+const GEOIP = 'geoip.dat';
+const GEOSITE = 'geosite.dat';
 final double kHeaderHeight = system.isDesktop
     ? !system.isMacOS
           ? 40
diff --git a/lib/core/controller.dart b/lib/core/controller.dart
index a8cdaf5..392ddea 100644
--- a/lib/core/controller.dart
+++ b/lib/core/controller.dart
@@ -50,9 +50,10 @@ class CoreController {
         if (isExists) {
           continue;
         }
-        final data = await rootBundle.load('assets/data/$geoFileName');
-        List<int> bytes = data.buffer.asUint8List();
-        await geoFile.writeAsBytes(bytes, flush: true);
+        final data = await File(
+          '/usr/share/mihomo-rules-dat/$geoFileName',
+        ).readAsBytes();
+        await geoFile.writeAsBytes(data, flush: true);
       }
     } catch (e) {
       exit(0);
diff --git a/pubspec.yaml b/pubspec.yaml
index f5ce5c4..16f4205 100755
--- a/pubspec.yaml
+++ b/pubspec.yaml
@@ -75,7 +75,6 @@ dev_dependencies:
 flutter:
   uses-material-design: true
   assets:
-    - assets/data/
     - assets/fonts/
     - assets/images/
     - assets/images/avatars/
@@ -93,4 +92,4 @@ flutter_intl:
   enabled: true
   class_name: AppLocalizations
   arb_dir: arb
-  output_dir: lib/l10n
\ No newline at end of file
+  output_dir: lib/l10n
-- 
