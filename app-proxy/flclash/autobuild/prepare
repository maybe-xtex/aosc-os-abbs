abinfo "Mapping Flutter architecture ..."
if ab_match_arch amd64; then
    export FLUTTER_OUT="$SRCDIR/build/linux/x64/release/bundle"
elif ab_match_arch arm64; then
    export FLUTTER_OUT="$SRCDIR/build/linux/arm64/release/bundle"
fi

abinfo "Setting up flutter ..."
fvm install 3.35.7
fvm global 3.35.7
fvm flutter --disable-analytics

### FIXME: To lock pub deps version, remove it when next flclash version released.
fvm flutter pub upgrade
