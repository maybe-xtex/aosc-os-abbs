From cbabddaf1cae3a6cbda11244ffb68e73478748ee Mon Sep 17 00:00:00 2001
From: stydxm <stydxm@outlook.com>
Date: Sun, 9 Nov 2025 19:15:18 +0800
Subject: [PATCH 13/13] edit dependencies to support loongarch & ppc

Signed-off-by: stydxm <stydxm@outlook.com>
---
 Cargo.lock           | 11 -----------
 package.json         | 15 +++++----------
 scripts/prebuild.mjs |  6 ++++--
 src-tauri/Cargo.toml |  2 +-
 vite.config.mts      |  2 +-
 5 files changed, 11 insertions(+), 25 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index 7581e385..e9b8ab6f 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -783,7 +783,6 @@ dependencies = [
  "dashmap 6.1.0",
  "dynify",
  "fast-float2",
- "float16",
  "futures-channel",
  "futures-concurrency",
  "futures-lite 2.6.1",
@@ -2519,16 +2518,6 @@ dependencies = [
  "thiserror 2.0.17",
 ]
 
-[[package]]
-name = "float16"
-version = "0.1.5"
-source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "7bffafbd079d520191c7c2779ae9cf757601266cf4167d3f659ff09617ff8483"
-dependencies = [
- "cfg-if",
- "rustc_version 0.2.3",
-]
-
 [[package]]
 name = "fnv"
 version = "1.0.7"
diff --git a/package.json b/package.json
index 09318b7a..21000939 100644
--- a/package.json
+++ b/package.json
@@ -86,7 +86,7 @@
     "@types/react": "19.2.7",
     "@types/react-dom": "19.2.3",
     "@vitejs/plugin-legacy": "^7.2.1",
-    "@vitejs/plugin-react-swc": "^4.2.2",
+    "@vitejs/plugin-react": "^5.1.0",
     "adm-zip": "^0.5.16",
     "cli-color": "^2.0.4",
     "commander": "^14.0.2",
@@ -125,15 +125,10 @@
     ]
   },
   "type": "module",
-  "packageManager": "pnpm@10.26.1",
+  "packageManager": "pnpm@9.13.2",
   "pnpm": {
-    "onlyBuiltDependencies": [
-      "@parcel/watcher",
-      "@swc/core",
-      "core-js",
-      "es5-ext",
-      "esbuild",
-      "unrs-resolver"
-    ]
+    "overrides": {
+      "rollup": "npm:@rollup/wasm-node"
+    }
   }
 }
diff --git a/scripts/prebuild.mjs b/scripts/prebuild.mjs
index b0e945e4..e63da21a 100644
--- a/scripts/prebuild.mjs
+++ b/scripts/prebuild.mjs
@@ -186,7 +186,8 @@ const META_ALPHA_MAP = {
   "linux-arm64": "mihomo-linux-arm64",
   "linux-arm": "mihomo-linux-armv7",
   "linux-riscv64": "mihomo-linux-riscv64",
-  "linux-loong64": "mihomo-linux-loong64",
+  "linux-loong64": "mihomo-linux-loong64-abi2",
+  "linux-ppc64": "mihomo-linux-ppc64le",
 };
 
 const META_MAP = {
@@ -200,7 +201,8 @@ const META_MAP = {
   "linux-arm64": "mihomo-linux-arm64",
   "linux-arm": "mihomo-linux-armv7",
   "linux-riscv64": "mihomo-linux-riscv64",
-  "linux-loong64": "mihomo-linux-loong64",
+  "linux-loong64": "mihomo-linux-loong64-abi2",
+  "linux-ppc64": "mihomo-linux-ppc64le",
 };
 
 // =======================
diff --git a/src-tauri/Cargo.toml b/src-tauri/Cargo.toml
index f49420a4..00c1e573 100755
--- a/src-tauri/Cargo.toml
+++ b/src-tauri/Cargo.toml
@@ -59,7 +59,7 @@ open = "5.3.3"
 dunce = "1.0.5"
 nanoid = "0.4"
 chrono = "0.4.42"
-boa_engine = "0.21.0"
+boa_engine = { version = "0.21.0", features = ["xsum"], default-features = false }
