From 303363f8dd39f1658703964c4495708226a079c6 Mon Sep 17 00:00:00 2001
From: Henry Chen <henry.chen@oss.cipunited.com>
Date: Fri, 20 Mar 2026 16:22:26 +0800
Subject: [PATCH] Make header path detection relative

---
 CMakeLists.txt             | 6 +++---
 cmake/MvfstFunctions.cmake | 1 +
 2 files changed, 4 insertions(+), 3 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 5dcc25874..9fcaee720 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -151,9 +151,9 @@ include(MvfstCompatAliases)
 # =============================================================================
 
 # Collect all headers (.h and .hpp), excluding test/facebook/build directories
-file(GLOB_RECURSE MVFST_HEADERS
-  "${CMAKE_CURRENT_SOURCE_DIR}/quic/*.h"
-  "${CMAKE_CURRENT_SOURCE_DIR}/quic/*.hpp"
+file(GLOB_RECURSE MVFST_HEADERS RELATIVE "${CMAKE_CURRENT_SOURCE_DIR}/quic"
+  "*.h"
+  "*.hpp"
 )
 list(FILTER MVFST_HEADERS EXCLUDE REGEX "/test/")
 list(FILTER MVFST_HEADERS EXCLUDE REGEX "/facebook/")
diff --git a/cmake/MvfstFunctions.cmake b/cmake/MvfstFunctions.cmake
index 4f1430679..ab1d55f57 100644
--- a/cmake/MvfstFunctions.cmake
+++ b/cmake/MvfstFunctions.cmake
@@ -308,6 +308,7 @@ function(mvfst_install_headers rootName rootDir)
   file(TO_CMAKE_PATH "${rootDir}" rootDir)
   string(LENGTH "${rootDir}" rootDirLength)
   foreach(fil ${ARGN})
+    set(fil "${rootDir}/${fil}")
     file(TO_CMAKE_PATH "${fil}" filePath)
     string(FIND "${filePath}" "/" rIdx REVERSE)
     if(rIdx EQUAL -1)
-- 
