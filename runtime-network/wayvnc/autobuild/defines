PKGNAME=wayvnc
PKGSEC=net
PKGDEP="aml mesa libdrm libxkbcommon neatvnc linux-pam pixman jansson"
BUILDDEP="meson ninja scdoc"
PKGDES="VNC server for wlroots-based Wayland compositors"

ABTYPE=meson
MESON_AFTER=(
    '-Dscreencopy-dmabuf=enabled'
    '-Dpam=enabled'
    '-Dman-pages=enabled'
    '-Dsystemtap=false'
    '-Dtests=false'
)
