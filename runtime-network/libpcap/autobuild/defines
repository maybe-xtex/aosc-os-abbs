PKGNAME=libpcap
PKGSEC=utils
PKGDEP="libnl libusb bluez"
PKGDEP__RETRO="libnl libusb"
PKGDES="System-independent interface for user-level packet capture"

ABTYPE=autotools
AUTOTOOLS_AFTER=(
    '--enable-ipv6'
    '--with-libnl'
)
AUTOTOOLS_AFTER__RETRO=(
    "${AUTOTOLS_AFTER[@]}"
    '--disable-bluetooth'
)
