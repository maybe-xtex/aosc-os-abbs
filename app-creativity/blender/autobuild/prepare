abinfo "Fetching git-lfs resources"
git lfs install
git lfs pull

# FIXME: workaround incorrect vectorization on PPC64.
if ab_match_arch ppc64; then
    abinfo "Fixing build on ppc64 ..."
    export CFLAGS="${CFLAGS/-maltivec -maltivec=be -mabi=altivec/} -mno-altivec -fno-tree-vectorize"
    export CXXFLAGS="${CXXFLAGS/-maltivec -maltivec=be -mabi=altivec/} -mno-altivec -fno-tree-vectorize"
fi

if ab_match_arch ppc64el; then
    abinfo "Fixing build on ppcel64 ..."
    export CFLAGS="${CFLAGS} -D__LITTLE_ENDIAN=1 -DARCH_CPU_LITTLE_ENDIAN=1"
    export CXXFLAGS="${CXXFLAGS} -D__LITTLE_ENDIAN=1 -DARCH_CPU_LITTLE_ENDIAN=1"
fi

if ab_match_arch loongson3; then
    abinfo "Undefining mips to fix build ..."
    export CFLAGS="${CFLAGS} -Umips"
    export CXXFLAGS="${CXXFLAGS} -Umips"
fi

if ab_match_arch amd64 || ab_match_arch arm64; then
    abinfo "Setting CUDA environment ..."
    source /etc/profile.d/cuda.sh
fi

if ab_match_arch amd64 || ab_match_arch arm64 || \
   ab_match_arch loongarch64 || ab_match_arch riscv64; then
    abinfo "Setting HIP-RT environment ..."
    # Copy from /etc/profile.d/rocm.sh in `rocm-base`
    export ROCM_PATH="/usr/lib/rocm"
    export PATH="$PATH:/usr/lib/rocm/bin"
fi
