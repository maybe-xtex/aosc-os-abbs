PKGNAME=gimp
PKGSEC=graphics
PKGDEP="babl dbus-glib desktop-file-utils gegl-0.4 jasper lcms2 libexif \
        libmng librsvg libwmf openexr pygobject-3 alsa-lib curl \
        ghostscript gutenprint poppler libheif gvfs gexiv2 libmypaint \
        mypaint-brushes libwebp aalib libgudev gtk-3 json-glib \
        libarchive libunwind xz openjpeg libjxl cfitsio libiff libilbm"
BUILDDEP="appstream gjs vala"
PKGDES="GNU Image Manipulation Program"

ABTYPE=meson
MESON_AFTER=(
    # Note: Turn on strict ansi
    '-Dansi=false'
    '-Denable-console-bin=true'
    '-Denable-multiproc=true'
    '-Dprofiling=false'
    '-Drelocatable-bundle=no'
    '-Dcheck-update=no'
    '-Dbug-report-url=https://github.com/AOSC-Dev/aosc-os-abbs/issues'
    '-Dlibunwind=true'
    '-Dlibbacktrace=true'
    '-Denable-default-bin=enabled'
    '-Dbash-completion=enabled'
    '-Daa=enabled'
    '-Dalsa=enabled'
    '-Dappdata-test=disabled'
    '-Dcairo-pdf=enabled'
    '-Dfits=enabled'
    '-Dghostscript=enabled'
    '-Dgudev=enabled'
    '-Dheif=enabled'
    '-Dilbm=enabled'
    '-Djpeg2000=enabled'
    '-Djpeg-xl=enabled'
    '-Dmng=enabled'
    '-Dopenexr=enabled'
    '-Dopenmp=enabled'
    '-Dprint=true'
    '-Dwebkit-unmaintained=false'
    '-Dwebp=enabled'
    '-Dwmf=enabled'
    '-Dxcursor=enabled'
    '-Dxpm=enabled'
    '-Dheadless-tests=disabled'
    '-Dfile-plug-ins-test=false'
    '-Dgi-docgen=disabled'
    '-Dlinux-input=enabled'
    '-Dvector-icons=true'
    '-Dvala=enabled'
    '-Djavascript=enabled'
    # Note: Install Lua plug-ins (experimental)
    '-Dlua=false'
    '-Ddebug-self-in-build=false'
)
