abinfo "Generating C bindings ..."
tree-sitter init

abinfo "Building tree-sitter-vim ..."
make

abinfo "Installing tree-sitter-vim ..."
make install \
    DESTDIR="$PKGDIR" \
    PREFIX="/usr"

abinfo "Symlinking the library ..."
install -dv "$PKGDIR"/usr/lib/tree_sitter
ln -sv ../libtree-sitter-vim.so "$PKGDIR"/usr/lib/tree_sitter/vim.so
