From 8bda216b7d40e7ee0dfff9c50a42f478c7402f0a Mon Sep 17 00:00:00 2001
From: rvalue <i@rvalue.moe>
Date: Mon, 11 Oct 2021 03:19:00 +0800
Subject: [PATCH 1/2] SConstruct: fix riscv build

Define words endian for RISC-V architecture.
---
 SConstruct | 1 +
 1 file changed, 1 insertion(+)

diff --git a/SConstruct b/SConstruct
index e063c6d..f80044d 100644
--- a/SConstruct
+++ b/SConstruct
@@ -345,6 +345,7 @@ def AppendEndianCheck(conf):
   || defined(_M_ALPHA)  || defined(__amd64) \
   || defined(__amd64__) || defined(_M_AMD64) \
   || defined(__x86_64)  || defined(__x86_64__) \
+  || defined(__riscv__) || defined(__riscv) \
   || defined(_M_X64)    || defined(__bfin__) \
   || defined(__alpha__) || defined(__ARMEL__) \
   || defined(_MIPSEL)   || (defined(__sh__) && defined(__LITTLE_ENDIAN__)) \
