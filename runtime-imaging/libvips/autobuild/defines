PKGNAME=libvips
PKGSEC=libs
PKGDES="An image processing library"
PKGDEP="gcc-runtime glibc glib expat zlib libarchive fftw cfitsio cgif \
        libimagequant libexif libjpeg-turbo libpng libwebp pango fontconfig \
        libtiff librsvg cairo lcms2 openexr openjpeg highway nifti matio"
PKGRECOM="imagemagick openslide libheif libjxl poppler python-3"
BUILDDEP="imagemagick openslide libdicom libheif libjxl poppler vala gtk-doc \
	doxygen"

MESON_AFTER=(
    '-Dexamples=false'
    '-Ddoxygen=true'
    '-Dgtk_doc=true'
    '-Dvapi=true'
    '-Dnifti-prefix-dir=/usr'
    '-Dpdfium=disabled'
    '-Dquantizr=disabled'
    '-Dspng=disabled'
    '-Dcfitsio=enabled'
    '-Dcgif=enabled'
    '-Dexif=enabled'
    '-Dfftw=enabled'
    '-Dfontconfig=enabled'
    '-Darchive=enabled'
    '-Dheif=enabled'
    '-Dimagequant=enabled'
    '-Djpeg=enabled'
    '-Djpeg-xl=enabled'
    '-Dlcms=enabled'
    '-Dmagick=enabled'
    '-Dmatio=enabled'
    '-Dnifti=enabled'
    '-Dopenexr=enabled'
    '-Dopenjpeg=enabled'
    '-Dopenslide=enabled'
    '-Dhighway=enabled'
    '-Dorc=enabled'
    '-Dpangocairo=enabled'
    '-Dpng=enabled'
    '-Dpoppler=enabled'
    '-Drsvg=enabled'
    '-Dtiff=enabled'
    '-Dwebp=enabled'
    '-Dzlib=enabled'
)
