Description: Mark as hopeful tests that sometimes fail on GNU/Hurd.
Author: Yavor Doganov <yavor@gnu.org>
Forwarded: not-needed
Last-Update: 2024-06-27
---

--- gnustep-base.orig/Tests/base/NSURL/test00.m
+++ gnustep-base/Tests/base/NSURL/test00.m
@@ -70,6 +70,9 @@
   END_SET("-resourceDataUsingCache")
 
   START_SET("-sendSynchronousRequest:returningResponse:error:")
+#if defined(__GNU__)
+  testHopeful = YES;
+#endif
   NSURLRequest	*request;
   NSHTTPURLResponse	*response;
   NSError		*error;
@@ -115,6 +118,10 @@
 #if defined(_WIN64) && defined(_MSC_VER)
   SKIP("Known to crash on 64-bit Windows with Clang/MSVC.")
 #endif
+#if defined(__GNU__)
+  testHopeful = YES;
+#endif
+
 
   /* Ask the 'respond' helper to send back a response containing
    * 'hello' and to shrink the write buffer size it uses on each
@@ -195,6 +202,9 @@
 #if defined(_WIN64) && defined(_MSC_VER)
       SKIP("Known to crash on 64-bit Windows with Clang/MSVC.")
 #endif
+#if defined(__GNU__)
+      testHopeful = YES;
+#endif
 
       t = [NSTask launchedHelperWithLaunchPath: respond
          arguments: [NSArray arrayWithObjects:
@@ -231,7 +241,7 @@
     }
   LEAVE_POOL
 
-#if defined(_WIN32)
+#if defined(__GNU__) || defined(_WIN32)
   testHopeful = NO;
 #endif
 
--- gnustep-base.orig/Tests/base/NSURL/test02.m
+++ gnustep-base/Tests/base/NSURL/test02.m
@@ -42,6 +42,9 @@
   NSLog(@"Marking local web server tests as hopeful because GSInetServerStream is broken on Windows");
   testHopeful = YES;
 #endif
+#if defined(__GNU__)
+  testHopeful = YES;
+#endif
 
   m = [NSMutableString stringWithCapacity: 2048];
   for (i = 0; i < 128; i++)
@@ -138,7 +141,7 @@
 
   LEAVE_POOL
 
-#if defined(_WIN32)
+#if defined(__GNU__) || defined(_WIN32)
   testHopeful = NO;
 #endif
 
--- gnustep-base.orig/Tests/base/NSURLConnection/test02.m
