-        tmp=(
-          /System/Library/Frameworks/*/Headers/*.h(#q-.N:t)
-          /usr/local/include/**/*.h(#q-.N:t)
-          /usr/include/**/*.h(#q-.N:t)
-        )
-        _describe -t headers 'header file' tmp && ret=0
-      else
-        _webbrowser && ret=0
-      fi
-      ;;
-    sdks)
