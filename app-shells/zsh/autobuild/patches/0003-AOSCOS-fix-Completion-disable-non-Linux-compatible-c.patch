-#  relocate
-#    complete a `old=new' pair of paths
-#  setattrs
-#    complete for --setperms, --setugids, --setcaps and --restore
-#  public_keys
-#    complete for `rpmkeys --import'
-#  query_specs
-#    complete for `rpmspec --query'
