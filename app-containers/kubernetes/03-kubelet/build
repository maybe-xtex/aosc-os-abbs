abinfo "Building kubelet ..."
make kubelet

abinfo "Installing kubelet ..."
install -Dvm755 "$SRCDIR"/_output/bin/kubelet -t "$PKGDIR"/usr/bin

abinfo "Installing bash and zsh completions ..."
"$PKGDIR"/usr/bin/kubelet completion bash | \
install -Dvm644 /dev/stdin "$PKGDIR"/usr/share/bash-completion/completions/kubelet
"$PKGDIR"/usr/bin/kubelet completion zsh | \
install -Dvm644 /dev/stdin "$PKGDIR"/usr/share/zsh/site-functions/_kubelet
