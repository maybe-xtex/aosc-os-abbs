abinfo "edit files"
# See https://github.com/zabbly/incus/blob/2efccf9de6d2245b8c4f2b3203e94613b973cf24/.github/workflows/builds.yml#L366C11-L366C79
find -type f -name "*.ts" -o -name "*.tsx" -o -name "*.scss" | xargs sed -i \
    -e 's/devlxd/guestapi/g' \
    -e 's/dev\/lxd/dev\/incus/g' \
    -e 's/LXD/Incus/g' \
    -e 's/Lxd/Incus/g' \
    -e 's/lxd/incus/g'

abinfo "install build deps"
yarn install

abinfo "building incus-ui-canonical"
yarn build

abinfo "install incus-ui-canonical"
install -dvm755 "$PKGDIR"/usr/share/incus-ui-canonical
cp -dR --preserve=timestamps "$SRCDIR"/build/ui -T "$PKGDIR"/usr/share/incus-ui-canonical
