# Adapted from Arch Linux
abinfo "Renaming binary files ..."
for b in stdiscosrv strelaysrv strelaypoolsrv; do 
    mv -v "$PKGDIR"/usr/bin/"$b" \
        "$PKGDIR"/usr/bin/"syncthing-${b#st}"
done

abinfo "Installing sysctl configuration file ..."
install -Dvm644 "$SRCDIR"/etc/linux-sysctl/30-syncthing.conf \
    "$PKGDIR"/usr/lib/sysctl.d/30-syncthing.conf

abinfo "Installing ufw configuration file ..."
install -Dvm644 "$SRCDIR"/etc/firewall-ufw/syncthing \
    "$PKGDIR"/etc/ufw/applications.d/ufw-syncthing

abinfo "Installing man pages ..."
pushd "$SRCDIR"/man
for file in $(find . -name '*.1' -print); do
    install -Dvm644 $file "$PKGDIR"/usr/share/man/man1/$file
done
for file in $(find . -name '*.5' -print); do
    install -Dvm644 $file "$PKGDIR"/usr/share/man/man5/$file
done
for file in $(find . -name '*.7' -print); do
    install -Dvm644 $file "$PKGDIR"/usr/share/man/man7/$file
done
popd

abinfo "Installing systemd service unit files ..."
install -Dvm644 "$SRCDIR"/etc/linux-systemd/system/syncthing@.service \
    "$PKGDIR"/usr/lib/systemd/system/syncthing@.service
install -Dvm644 "$SRCDIR"/etc/linux-systemd/user/syncthing.service \
    "$PKGDIR"/usr/lib/systemd/user/syncthing.service

install -Dvm644 "$SRCDIR"/cmd/stdiscosrv/etc/linux-systemd/stdiscosrv.service \
    "$PKGDIR"/usr/lib/systemd/system/stdiscosrv.service
install -Dvm644 "$SRCDIR"/cmd/stdiscosrv/etc/linux-systemd/default \
    "$PKGDIR"/etc/default/syncthing-discosrv

install -Dvm644 "$SRCDIR"/cmd/strelaysrv/etc/linux-systemd/strelaysrv.service \
    "$PKGDIR"/usr/lib/systemd/system/strelaysrv.service
install -Dvm644 "$SRCDIR"/cmd/strelaysrv/etc/linux-systemd/default \
    "$PKGDIR"/etc/default/syncthing-relaysrv

abinfo "Installing desktop files and icons ..."
install -Dvm644 "$SRCDIR"/etc/linux-desktop/syncthing-ui.desktop \
    "$PKGDIR"/usr/share/applications/syncthing-ui.desktop
install -Dvm644 "$SRCDIR"/etc/linux-desktop/syncthing-start.desktop \
    "$PKGDIR"/usr/share/applications/syncthing-start.desktop
mkdir -pv "$PKGDIR"/usr/share/icons/hicolor/{32,64,128,256,512,scalable}/apps
for size in 32 64 128 256 512; do
    install -Dvm644 "$SRCDIR"/assets/logo-$size.png \
        "$PKGDIR"/usr/share/icons/hicolor/$size/apps/syncthing.png
done
install -Dvm644 "$SRCDIR"/assets/logo-only.svg \
    "$PKGDIR"/usr/share/icons/hicolor/scalable/apps/syncthing.svg
