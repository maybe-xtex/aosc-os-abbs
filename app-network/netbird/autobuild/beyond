abinfo "Installing netbird shell completions..."
"$PKGDIR"/usr/bin/netbird completion bash | \
	install -Dvm644 /dev/stdin \
	"$PKGDIR"/usr/share/bash-completion/completions/netbird
"$PKGDIR"/usr/bin/netbird completion zsh | \
	install -Dvm644 /dev/stdin \
	"$PKGDIR"/usr/share/zsh/site-functions/_netbird
"$PKGDIR"/usr/bin/netbird completion fish | \
	install -Dvm644 /dev/stdin \
	"$PKGDIR"/usr/share/fish/vendor_completions.d/netbird.fish
