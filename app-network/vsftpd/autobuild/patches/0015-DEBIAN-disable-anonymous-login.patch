From f94f29dcd1cbf945192ba2829a0659a5286b3b39 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sat, 4 Apr 2026 02:07:36 +0800
Subject: [PATCH 15/25] DEBIAN: disable anonymous login

Origin: http://bazaar.launchpad.net/~ubuntu-branches/ubuntu/utopic/vsftpd/utopic/view/head:/debian/patches/ubuntu-disable-anonymous.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 EXAMPLE/INTERNET_SITE/vsftpd.conf         | 2 +-
 EXAMPLE/INTERNET_SITE_NOINETD/vsftpd.conf | 2 +-
 vsftpd.conf                               | 6 +++---
 vsftpd.conf.5                             | 2 +-
 4 files changed, 6 insertions(+), 6 deletions(-)

diff --git a/EXAMPLE/INTERNET_SITE/vsftpd.conf b/EXAMPLE/INTERNET_SITE/vsftpd.conf
index ff874bd..364a869 100644
--- a/EXAMPLE/INTERNET_SITE/vsftpd.conf
+++ b/EXAMPLE/INTERNET_SITE/vsftpd.conf
@@ -1,5 +1,5 @@
 # Access rights
-anonymous_enable=YES
+anonymous_enable=NO
 local_enable=NO
 write_enable=NO
 anon_upload_enable=NO
diff --git a/EXAMPLE/INTERNET_SITE_NOINETD/vsftpd.conf b/EXAMPLE/INTERNET_SITE_NOINETD/vsftpd.conf
index 5470b6e..7b20a30 100644
--- a/EXAMPLE/INTERNET_SITE_NOINETD/vsftpd.conf
+++ b/EXAMPLE/INTERNET_SITE_NOINETD/vsftpd.conf
@@ -3,7 +3,7 @@ listen=YES
 max_clients=200
 max_per_ip=4
 # Access rights
-anonymous_enable=YES
+anonymous_enable=NO
 local_enable=NO
 write_enable=NO
 anon_upload_enable=NO
diff --git a/vsftpd.conf b/vsftpd.conf
index 392a100..f31df5b 100644
--- a/vsftpd.conf
+++ b/vsftpd.conf
@@ -21,11 +21,11 @@ listen=NO
 # files.
 listen_ipv6=YES
 #
-# Allow anonymous FTP? (Beware - allowed by default if you comment this out).
-anonymous_enable=YES
+# Allow anonymous FTP? (Disabled by default).
+anonymous_enable=NO
 #
 # Uncomment this to allow local users to log in.
-#local_enable=YES
+local_enable=YES
 #
 # Uncomment this to enable any form of FTP write command.
 #write_enable=YES
diff --git a/vsftpd.conf.5 b/vsftpd.conf.5
index 32223a3..08ca417 100644
--- a/vsftpd.conf.5
+++ b/vsftpd.conf.5
@@ -84,7 +84,7 @@ and
 .BR anonymous
 are recognised as anonymous logins.
 
-Default: YES
+Default: NO
 .TP
 .B ascii_download_enable
 When enabled, ASCII mode data transfers will be honoured on downloads.
-- 
2.52.0

