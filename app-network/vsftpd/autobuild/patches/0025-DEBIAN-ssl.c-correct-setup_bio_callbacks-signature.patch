From 3db7e2ecd40c2bbd4614da9772ed6f9a60965e4c Mon Sep 17 00:00:00 2001
From: Chris Hofstaedtler <zeha@debian.org>
Date: Sat, 4 Apr 2026 02:15:30 +0800
Subject: [PATCH 25/25] DEBIAN: ssl.c: correct setup_bio_callbacks signature

Fixes FTBFS with gcc-15

Closes: #1098073
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 ssl.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/ssl.c b/ssl.c
index 6e042aa..e0f3afd 100644
--- a/ssl.c
+++ b/ssl.c
@@ -34,7 +34,7 @@
 static char* get_ssl_error();
 static SSL* get_ssl(struct vsf_session* p_sess, int fd);
 static int ssl_session_init(struct vsf_session* p_sess);
-static void setup_bio_callbacks();
+static void setup_bio_callbacks(SSL* p_ssl);
 static long bio_callback(
   BIO* p_bio, int oper, const char* p_arg, int argi, long argl, long retval);
 static int ssl_verify_callback(int verify_ok, X509_STORE_CTX* p_ctx);
