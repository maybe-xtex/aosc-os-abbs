From 9e49c0a2902e96a1f524a9963ceee2caad20a06b Mon Sep 17 00:00:00 2001
From: eatradish <sakiiily@aosc.io>
Date: Fri, 4 Apr 2025 13:32:15 +0800
Subject: [PATCH 2/3] Remove unnecessary `nix` and `libc` dependency

---
 Cargo.lock | 29 ++---------------------------
 Cargo.toml |  2 --
 2 files changed, 2 insertions(+), 29 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index 4d25896..31a9f2f 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -143,10 +143,8 @@ version = "1.0.5"
 dependencies = [
  "anyhow",
  "interfaces",
- "libc",
  "log",
  "log4rs",
- "nix 0.25.1",
  "once_cell",
  "openssl",
  "parking_lot",
@@ -710,7 +708,7 @@ dependencies = [
  "handlebars",
  "lazy_static",
  "libc",
- "nix 0.26.4",
+ "nix",
  "serde",
  "serde_derive",
 ]
@@ -814,15 +812,6 @@ version = "2.7.4"
 source = "registry+https://github.com/rust-lang/crates.io-index"
 checksum = "78ca9ab1a0babb1e7d5695e3530886289c18cf2f87ec19a575a0abdce112e3a3"
 
-[[package]]
-name = "memoffset"
-version = "0.6.5"
-source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "5aa361d4faea93603064a027415f07bd8e1d5c88c9fbf68bf56a285428fd79ce"
-dependencies = [
- "autocfg",
-]
-
 [[package]]
 name = "memoffset"
 version = "0.7.1"
@@ -886,20 +875,6 @@ dependencies = [
  "version_check",
 ]
 
-[[package]]
-name = "nix"
-version = "0.25.1"
-source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "f346ff70e7dbfd675fe90590b92d59ef2de15a8779ae305ebcbfd3f0caf59be4"
-dependencies = [
- "autocfg",
- "bitflags 1.3.2",
- "cfg-if",
- "libc",
- "memoffset 0.6.5",
- "pin-utils",
-]
-
 [[package]]
 name = "nix"
 version = "0.26.4"
@@ -909,7 +884,7 @@ dependencies = [
  "bitflags 1.3.2",
  "cfg-if",
  "libc",
- "memoffset 0.7.1",
+ "memoffset",
  "pin-utils",
 ]
 
diff --git a/Cargo.toml b/Cargo.toml
index c309b3b..5fef843 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -30,8 +30,6 @@ windows-service = "0.8.0"
 tokio = { version = "1.44.0", features = ["full"] }
 serde = { version = "1.0.217", features = ["derive"] }
 sysinfo = "0.33.1"
-nix = "0.25.1"
-libc = "0.2.169"
 which = "7"
 
 [target.'cfg(target_os = "linux")'.dependencies]
-- 
