abinfo "Building localsend using fvm ..."
fvm install
fvm flutter build linux -v

abinfo "Copying the application bundle ..."
mkdir -pv "$PKGDIR"/usr/lib
cp -av "$SRCDIR"/build/linux/"$ARCH"/release/bundle "$PKGDIR"/usr/lib/localsend

abinfo "Copying icons ..."
for size in 32 128 256 512; do
    install -Dvm 644 \
       "$SRCDIR"/build/flutter_assets/assets/img/logo-${size}.png \
       "$PKGDIR"/usr/share/icons/hicolor/${size}x${size}/apps/localsend.png
done

abinfo "Making symlinks ..."
mkdir -pv "$PKGDIR"/usr/bin
ln -sv ../lib/localsend/localsend_app "$PKGDIR"/usr/bin/localsend
