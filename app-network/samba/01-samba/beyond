abinfo "Creating directories ..."
install -dvm700 "$PKGDIR"/etc/samba/private

abinfo "Symlinking and installing directories Samba CUPS backend ..."
mkdir -pv "$PKGDIR"/usr/lib/cups/backend
ln -sv ../../../bin/smbspool "$PKGDIR"/usr/lib/cups/backend/smb
install -dvm1777 "$PKGDIR"/var/spool/samba

# Prepare to package LDB
abinfo "Installing LDB executable files ..."
install -dvm755 "$SRCDIR"/package-ldb/usr/bin
for bin in ldb{add,del,edit,modify,rename,search}; do
    mv -v "$PKGDIR"/usr/bin/${bin} "$SRCDIR"/package-ldb/usr/bin/
done

abinfo "Installing LDB library ..."
install -dvm755 "$SRCDIR"/package-ldb/usr/lib
for lib in "$PKGDIR"/usr/lib/libldb*; do
    mv -v ${lib} "$SRCDIR"/package-ldb/usr/lib/
done

install -dvm755 "$SRCDIR"/package-ldb/usr/include/samba-4.0
for headers in ldb{.h,_errors.h,_handlers.h,_module.h,_version.h}; do
    mv -v "$PKGDIR"/usr/include/samba-4.0/${headers} "$SRCDIR"/package-ldb/usr/include/samba-4.0/
done

install -dvm755 "$SRCDIR"/package-ldb/usr/lib/samba
mv -v "$PKGDIR"/usr/lib/samba/ldb "$SRCDIR"/package-ldb/usr/lib/samba

install -dvm755 "$SRCDIR"/package-ldb/usr/lib/pkgconfig
mv -v "$PKGDIR"/usr/lib/pkgconfig/ldb.pc "$SRCDIR"/package-ldb/usr/lib/pkgconfig/

install -dvm755 "$SRCDIR"/package-ldb/usr/lib/python"$ABPY3VER"/site-packages
mv -v "$PKGDIR"/usr/lib/python"$ABPY3VER"/site-packages/{_ldb_text.py,ldb.cpython-*.so} \
        "$SRCDIR"/package-ldb/usr/lib/python"$ABPY3VER"/site-packages/
