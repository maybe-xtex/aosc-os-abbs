PKGNAME=cinnamon
PKGSEC=Cinnamon
PKGDEP="cinnamon-menus cjs gcr-3 gstreamer gtk-3 libsecret muffin \
    networkmanager polkit wayland xapps gsound python-pam pexpect pillow \
    tinycss2 pytz timezonemap gnome-icon-theme gnome-icon-theme-extras \
    gnome-icon-theme-symbolic"
BUILDDEP="gobject-introspection sassc"
PKGRECOM="cinnamon-settings-daemon libibus"
PKGDES="Desktop shell for Cinnamon"

ABTYPE=meson
MESON_AFTER=(
    '-Ddocs=false'
    '-Dbuild_recorder=true'
    '-Dnm_agent=internal'
    '-Dwayland=true'
    '-Dexclude_info_settings=false'
)
