From 6a57093f2c0aa5c629097283548e557353ac54fd Mon Sep 17 00:00:00 2001
From: tom <t.vitureau@purjus.fr>
Date: Thu, 16 Mar 2017 22:13:26 +0100
Subject: [PATCH 03/17] AZZRA: PyCObject_Check -> PyCapsule_CheckExact,
 PyBuffer_New -> malloc

Link: https://github.com/azzra/python3-wiimote/commits/master/
---
 python/Wiimote.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/python/Wiimote.c b/python/Wiimote.c
index 60e52a9..01a9606 100644
--- a/python/Wiimote.c
+++ b/python/Wiimote.c
@@ -199,7 +199,7 @@ static int Wiimote_init(Wiimote* self, PyObject* args, PyObject *kwds)
 	 * an existing CObject.  Otherwise, create a new one */
 	if (PyTuple_Size(args) == 1) {
 		PyObj = PyTuple_GET_ITEM(args, 0);
-		if (PyCObject_Check(PyObj)) {
+		if (PyCapsule_CheckExact(PyObj)) {
 			wiimote = PyCObject_AsVoidPtr(PyObj);
 			self->close_on_dealloc = 0;
 		}
@@ -805,7 +805,7 @@ static PyObject *Wiimote_read(Wiimote *self, PyObject *args, PyObject *kwds)
 		return NULL;
 	}
 
-	if (!(pyRetBuf = PyBuffer_New(len))) {
+	if (!(pyRetBuf = malloc(len))) {
 		return NULL;
 	}
 	if (PyObject_AsWriteBuffer(pyRetBuf, &buf, &len)) {
-- 
2.48.1

