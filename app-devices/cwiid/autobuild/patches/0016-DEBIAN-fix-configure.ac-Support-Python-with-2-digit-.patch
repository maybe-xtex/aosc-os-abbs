From 9608dc89860675b2c7c0ad4d63db4a4544c2e392 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sun, 9 Mar 2025 15:36:16 +0800
Subject: [PATCH 16/17] DEBIAN: fix(configure.ac): Support Python with 2-digit
 minor version

Fix build with Python >= 3.10 (two-digit minor versions).

Signed-off-by: Graham Inggs <ginggs@debian.org>
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 configure.ac | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configure.ac b/configure.ac
index 5f34940..b2e1260 100644
--- a/configure.ac
+++ b/configure.ac
@@ -41,7 +41,7 @@ if test $REQUIRE_PYTHON; then
 fi
 AC_SUBST(PYTHON)
 if test $PYTHON; then
-	PYTHON_VERSION=[`$PYTHON -c 'import sys; print(sys.version[:3])'`]
+	PYTHON_VERSION=[`$PYTHON -c 'import sys; print ("%d.%d" % sys.version_info[:2])'`]
 	AC_SUBST(PYTHON_VERSION)
 	AC_DEFINE([HAVE_PYTHON],1,[Define to 1 if python support is enabled])
 fi
-- 
2.48.1

