From f8f82841f24fb5898aef95ed07d5a36d92b189a5 Mon Sep 17 00:00:00 2001
From: tom <t.vitureau@purjus.fr>
Date: Sun, 19 Mar 2017 09:45:37 +0100
Subject: [PATCH 10/17] AZZRA: Fix make uninstall not removing properly
 extension

Link: https://github.com/azzra/python3-wiimote/commits/master/
---
 .gitignore         | 1 +
 python/Makefile.in | 4 ++--
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/.gitignore b/.gitignore
index 8fb83f5..20e7252 100644
--- a/.gitignore
+++ b/.gitignore
@@ -10,3 +10,4 @@ autom4te.cache
 config.*
 configure
 defs.mak
+python/installed_files.txt
diff --git a/python/Makefile.in b/python/Makefile.in
index 9cf853c..7d5004b 100644
--- a/python/Makefile.in
+++ b/python/Makefile.in
@@ -10,10 +10,10 @@ all:
 	$(PYTHON) setup.py build_ext $(DEBUGFLAGS) -I@top_builddir@/libcwiid -L@top_builddir@/libcwiid
 
 install:
-	$(PYTHON) setup.py install --install-lib=${libdir}/python@PYTHON_VERSION@/site-packages $(SET_ROOT_DIR)
+	$(PYTHON) setup.py install --install-lib=${libdir}/python@PYTHON_VERSION@/site-packages $(SET_ROOT_DIR)  --record installed_files.txt
 
 uninstall:
-	rm -f $(ROOTDIR)${libdir}/python@PYTHON_VERSION@/site-packages/cwiid.so
+	cat installed_files.txt | xargs rm -rf
 
 clean:
 	rm -rf build
-- 
2.48.1

