From bd2f6206a4baff5a06ba1c3f1546bd2853bc20f7 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sun, 9 Mar 2025 15:58:34 +0800
Subject: [PATCH 17/17] AOSCOS: fix(python/Makefile.in): reinstate setup.py
 installation parameters

Lest the install target would install Python modules to the sysroot (/).

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 python/Makefile.in | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/python/Makefile.in b/python/Makefile.in
index 02d6a18..3908cc4 100644
--- a/python/Makefile.in
+++ b/python/Makefile.in
@@ -10,7 +10,7 @@ all:
 	$(PYTHON) setup.py build_ext $(DEBUGFLAGS) -I@top_builddir@/libcwiid -L@top_builddir@/libcwiid
 
 install:
-	$(PYTHON) setup.py install --record installed_files.txt
+	$(PYTHON) setup.py install --install-lib=${libdir}/python@PYTHON_VERSION@/site-packages $(SET_ROOT_DIR) --record installed_files.txt
 
 uninstall:
 	cat installed_files.txt | xargs rm -rf
