From f4d17318179c38b598aa0efb1b21b14f8d7e92ac Mon Sep 17 00:00:00 2001
From: azzra <t.vitureau@purjus.fr>
Date: Thu, 27 Apr 2017 14:11:00 +0200
Subject: [PATCH 13/17] AZZRA: Python3* tests (#4)

* clean setup.py

* test on python3*

* let python work by itslef

* remove rests of config & plugin dir

Link: https://github.com/azzra/python3-wiimote/commits/master/
---
 .travis.yml          | 32 +++++++++++++++++++++++---------
 Makefile.in          | 16 ----------------
 configure.ac         | 20 +-------------------
 defs.mak.in          |  3 ---
 libcwiid/cwiid.pc.in |  2 --
 python/Makefile.in   |  2 +-
 python/setup.py      | 12 ++++++++----
 7 files changed, 33 insertions(+), 54 deletions(-)

diff --git a/.travis.yml b/.travis.yml
index 5d0bfb7..d8dcfb6 100644
--- a/.travis.yml
+++ b/.travis.yml
@@ -1,14 +1,28 @@
-language: c
+language: python
 
 before_install:
   - sudo apt-get -qq update
-  - sudo apt-get install -y python3-dev libbluetooth-dev
+  - sudo apt-get install -y libbluetooth-dev
+
+python:
+  - "3.2"
+  - "3.3"
+  - "3.4"
+  - "3.5"
+  - "3.5-dev"
+  - "3.6"
+  - "3.6-dev"
+  - "3.7-dev"
+  - "nightly"
 
 script:
-  - aclocal
-  - autoconf
-  - ./configure
-  - make
-  - sudo make install
-  - PYTHON_VERSION=$(python3 -c 'import sys; print(sys.version[:3])')
-  - PYTHONPATH=/usr/local/lib/python${PYTHON_VERSION}/site-packages python3 -c 'import cwiid' 
+  - |
+    aclocal
+    autoconf
+    ./configure
+    make
+    cd libcwiid/
+    sudo make install
+    cd ../python/
+    python setup.py install
+    python -c 'import cwiid' 
diff --git a/Makefile.in b/Makefile.in
index c2e058c..fbbfd9d 100644
--- a/Makefile.in
+++ b/Makefile.in
@@ -19,29 +19,13 @@ $(BIND_DIRS): $(LIB_DIRS)
 endif
 endif
 
-ifeq ($(MAKECMDGOALS),install)
-$(LIB_DIRS): $(CWIID_CONFIG_DIR) $(CWIID_PLUGINS_DIR)
-endif
-
 $(SUB_DIRS):
 	$(MAKE) $(TARGET) -C $@
 
-$(CWIID_CONFIG_DIR):
-	install -d $(CWIID_CONFIG_DIR)
-
-$(CWIID_PLUGINS_DIR):
-	install -d $(CWIID_PLUGINS_DIR)
-
 distclean:
 	rm -rf Makefile config.log config.status autom4te.cache \
 		defs.mak $(COMMON)/include/lib.mak $(COMMON)/include/config.h
 
-uninstall:
-	rm -r $(CWIID_PLUGINS_DIR); true
-
-uninstall_config:
-	rm -rf $(CWIID_CONFIG_DIR)
-
 .PHONY: all install clean distclean uninstall uninstall_config $(SUB_DIRS)
 
 .NOTPARALLEL:
diff --git a/configure.ac b/configure.ac
index d4c9d80..5f34940 100644
--- a/configure.ac
+++ b/configure.ac
@@ -1,4 +1,4 @@
-AC_INIT(CWiid,0.6.00,donnie.smith@gatech.edu)
+AC_INIT(CWiid,3.0.0,https://github.com/azzra/python3-wiimote/issues)
 AC_CONFIG_HEADER(common/include/config.h)
 
 AC_PROG_CC
@@ -71,24 +71,6 @@ AC_CHECK_HEADER([linux/uinput.h],,
 
 AC_ISC_POSIX
 
-AC_ARG_WITH(cwiid-config-dir,AC_HELP_STRING([--with-cwiid-config-dir],
-	[CWiid configuration directory, default to $(sysconfdir)/cwiid]))
-if test -z $with_cwiid_config_dir; then
-	CWIID_CONFIG_DIR='${sysconfdir}/cwiid'
-else
-	CWIID_CONFIG_DIR=$with_cwiid_config_dir
-fi
-AC_SUBST(CWIID_CONFIG_DIR)
-
-AC_ARG_WITH(cwiid-plugins-dir,AC_HELP_STRING([--with-cwiid-plugins-dir],
-	[CWiid plugins directory, default to $(libdir)/cwiid/plugins]))
-if test -n $with_cwiid_plugins_dir; then
-	CWIID_PLUGINS_DIR='${libdir}/cwiid/plugins'
-else
-	CWIID_PLUGINS_DIR=$with_cwiid_plugins_dir
-fi
-AC_SUBST(CWIID_PLUGINS_DIR)
-
 AC_ARG_WITH(ldconfig,AC_HELP_STRING([--disable-ldconfig],
 	[don't execute ldconfig after install]))
 if test "$enable_ldconfig" = "no"; then
diff --git a/defs.mak.in b/defs.mak.in
index fb2ff7c..07587fd 100644
--- a/defs.mak.in
+++ b/defs.mak.in
@@ -28,9 +28,6 @@ ifdef DESTDIR
 	ROOTDIR = $(DESTDIR:%/=%)
 endif
 
-CWIID_CONFIG_DIR = $(ROOTDIR)@CWIID_CONFIG_DIR@
-CWIID_PLUGINS_DIR = $(ROOTDIR)@CWIID_PLUGINS_DIR@
-
 DEBUGFLAGS = -g
 WARNFLAGS = -Wall -W
 CFLAGS = $(DEBUGFLAGS) $(WARNFLAGS) @DEFS@ -I$(COMMON)/include
diff --git a/libcwiid/cwiid.pc.in b/libcwiid/cwiid.pc.in
index 66e3346..8835c48 100644
--- a/libcwiid/cwiid.pc.in
+++ b/libcwiid/cwiid.pc.in
@@ -3,8 +3,6 @@ exec_prefix=@exec_prefix@
 libdir=@libdir@
 includedir=@includedir@
 sysconfdir=@sysconfdir@
-cwiid_config_dir=@CWIID_CONFIG_DIR@
-cwiid_plugins_dir=@CWIID_PLUGINS_DIR@
 
 Name: CWiid
 Description: CWiid Wiimote Interface
diff --git a/python/Makefile.in b/python/Makefile.in
index 3908cc4..02d6a18 100644
--- a/python/Makefile.in
+++ b/python/Makefile.in
@@ -10,7 +10,7 @@ all:
 	$(PYTHON) setup.py build_ext $(DEBUGFLAGS) -I@top_builddir@/libcwiid -L@top_builddir@/libcwiid
 
 install:
-	$(PYTHON) setup.py install --install-lib=${libdir}/python@PYTHON_VERSION@/site-packages $(SET_ROOT_DIR) --record installed_files.txt
+	$(PYTHON) setup.py install --record installed_files.txt
 
 uninstall:
 	cat installed_files.txt | xargs rm -rf
diff --git a/python/setup.py b/python/setup.py
index 9fe7eff..eb98019 100644
--- a/python/setup.py
+++ b/python/setup.py
@@ -1,6 +1,10 @@
 from distutils.core import setup, Extension
 
-setup(name='cwiid',
-	version='0.6.00',
-	ext_modules=[Extension('cwiid', ['cwiidmodule.c', 'Wiimote.c'], libraries=['cwiid', 'bluetooth'])]
-	)
+setup(
+    name='cwiid',
+    version='3.0.0',
+    description='Python3 module for libcwiid',
