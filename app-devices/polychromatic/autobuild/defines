PKGNAME=polychromatic
PKGDES="RGB lighting management application for Razer devices"
PKGDEP="colorama colour libappindicator openrazer pygobject-3 pyqt6 \
        pyqt6-webengine py-setproctitle python-3 qt-6 requests"
BUILDDEP="appstream meson ninja"
PKGSEC="x11"
ABTYPE="meson"

ABHOST=noarch

# Note: Limit to architectures with Qt6WebEngine support.
FAIL_ARCH="!(amd64|arm64|loongarch64|loongarch64_nosimd)"

# Note: Inheriting FAIL_ARCH requires removal of noarch flag, treating as
# architecture-specific.
ABSPLITDBG=0
