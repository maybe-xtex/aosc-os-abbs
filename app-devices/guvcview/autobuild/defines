PKGNAME=guvcview
PKGDES="A lightweight GTK+-based UVC camera viewer"
PKGSEC=utils
PKGDEP="sdl2 gsl ffmpeg gtk-3 pulseaudio portaudio"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DINSTALL_DEVKIT=ON'
    '-DUSE_DEBIANMENU=OFF'
    '-DUSE_GTK3=ON'
    '-DUSE_PULSE=ON'
    '-DUSE_QT6=OFF'
    '-DUSE_SDL2=ON'
    '-DUSE_SFML=ON'
)
