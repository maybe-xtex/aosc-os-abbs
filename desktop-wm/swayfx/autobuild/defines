PKGNAME=swayfx
PKGSEC=x11
PKGDEP="wayland gdk-pixbuf json-c cairo pcre2 pango wlroots scenefx xwayland \
        swaybg systemd"
BUILDDEP="wayland-protocols scdoc bash-completion fish"
PKGRECOM="foot wmenu dmenu"
PKGSUG="swaylock swayidle"
PKGDES="i3-compatible window manager for Wayland"
PKGCONFL="sway"
PKGPROV="sway"

ABTYPE=meson
MESON_AFTER=(
    '-Ddefault-wallpaper=true'
    '-Dzsh-completions=true'
    '-Dbash-completions=true'
    '-Dfish-completions=true'
    '-Dswaybar=true'
    '-Dswaynag=true'
    '-Dtray=enabled'
    '-Dgdk-pixbuf=enabled'
    '-Dman-pages=enabled'
    '-Dsd-bus-provider=libsystemd'
)
