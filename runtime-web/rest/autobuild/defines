PKGNAME=rest
PKGSEC=libs
PKGDEP="glib libxml2 libsoup-3"
BUILDDEP="gobject-introspection vala"
PKGDES="Helper library for RESTful services"

MESON_AFTER=(
    '-Dca_certificates=false'
    '-Dintrospection=true'
    '-Dvapi=true'
    '-Dexamples=false'
    '-Dgtk_doc=false'
    '-Dsoup2=false'
    '-Dtests=false'
)

# Note: Now named librest upstream.
PKGPROV="librest"
