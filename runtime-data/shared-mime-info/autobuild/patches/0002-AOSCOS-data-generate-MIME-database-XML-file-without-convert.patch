From 2574393060754e9352046c2031b4413af4c756a5 Mon Sep 17 00:00:00 2001
From: Xinhui Yang <cyan@cyano.uk>
Date: Fri, 10 Apr 2026 18:38:49 +0800
Subject: [PATCH] data: generate MIME database XML file without converting to
 BCP 47

This option is currently AOSC specific.
---
 data/meson.build | 14 ++++++++++----
 1 file changed, 10 insertions(+), 4 deletions(-)

diff --git a/data/meson.build b/data/meson.build
index d61df61..42e449a 100644
--- a/data/meson.build
+++ b/data/meson.build
@@ -3,12 +3,18 @@ if build_machine.system() != 'windows'
     install_man('update-mime-database.1')
 endif
 
-freedesktop_org_xml = i18n.merge_file(
+freedesktop_org_xml = custom_target(
     input: 'freedesktop.org.xml.in',
     output: 'freedesktop.org.xml',
-    data_dirs: '.',
-    po_dir: '../po',
-    type: 'xml',
+    command: [
+      'msgfmt', '--xml', '-d', meson.project_source_root() / 'po',
+      '--template', '@INPUT@',
+      '--preserve-tags',
+      '-o', '@OUTPUT@',
+    ],
+    env: {
+      'GETTEXTDATADIRS': meson.project_source_root() / 'data',
+    },
     install: true,
     install_dir: get_option('datadir') / 'mime' / 'packages',
 )
-- 
2.52.0

